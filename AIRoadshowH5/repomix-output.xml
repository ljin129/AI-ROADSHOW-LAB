    .voice_bar_bottom_divider {
        margin-top: 1px;
        height: 1px;
        background: rgba(255, 255, 255, 0.15);
        width: 100%;
    }

    &.is_attachment {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0.1) 100%);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 12px;
        padding: 6px 8px;
        color: inherit;

        .voice_bar_main {
            padding-bottom: 0;
        }

        .voice_bar_play_btn {
            background: rgba(255, 255, 255, 0.96);

            svg {
                fill: #1989fa;
            }
        }

        .voice_bar_wave_line {
            opacity: 0.72;
        }

        .voice_bar_duration,
        .voice_bar_text_toggle,
        .voice_bar_collapsed_wave {
            opacity: 0.82;
