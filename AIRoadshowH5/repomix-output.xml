```

- [ ] **Step 3: Emit `audio_data` for uploaded mp3 attachments and preserve `audio_url` for voice input**

Update the `inputParts` assembly in `onReply`.

```js
if (currentMessage.content_type === 'audio' && currentMessage.audio_url) {
  inputParts.push({
    part_type: 'audio_url',
    uri: currentMessage.audio_url,
    text_content: currentMessage.audio_text || '',
    payload: currentMessage.audio_payload || {},
  })
}

if (currentMessage.attachments && currentMessage.attachments.length > 0) {
  if (currentMessage.content_type !== 'audio' && currentMessage.raw_text) {
    inputParts.push({ part_type: 'text', text_content: currentMessage.raw_text })
  }

  currentMessage.attachments.forEach((a) => {
    if (a.type === 'image') {
      inputParts.push({ part_type: 'image_url', uri: a.url })
    } else if (a.type === 'audio_data') {
      inputParts.push({
        part_type: 'audio_data',
        uri: a.url,
        payload: { format: 'mp3' },
      })
    } else if (a.type === 'file') {
      inputParts.push({ part_type: 'file_url', uri: a.url })
    } else {
      inputParts.push({ part_type: 'text', text_content: `\n[${a.fileName}](${a.url})` })
    }
  })
}
```

- [ ] **Step 4: Normalize incoming `audio_data` parts into `audio_attachment` messages**

Update the `parts` parsing block so `audio_data` does not fall through to the generic file-link branch, then map it to explicit attachment-audio fields.

```js
if (Array.isArray(msgItem.parts) && msgItem.parts.length) {
  let reconstructedContent = ''
  msgItem.parts.forEach((part) => {
    const pType = part.partType || part.part_type
    if (pType === 'text') {
      const text = part.textContent || part.text_content || ''
      if (text) reconstructedContent += (reconstructedContent ? '\n' : '') + text
    } else if (pType === 'image_url') {
      const uri = part.uri || ''
      if (uri) {
        reconstructedContent += (reconstructedContent ? '\n' : '') + `![image](${uri})`
      }
    } else if (pType === 'audio_url' || pType === 'audio_data') {
      // audio parts do not get reconstructed into markdown text
    } else {
      const uri = part.uri || ''
      const text = part.textContent || part.text_content || '文件'
      if (uri) {
        reconstructedContent += (reconstructedContent ? '\n' : '') + `[${text}](${uri})`
      }
    }
  })

  if (reconstructedContent.trim()) {
    msgItem.content = reconstructedContent.trim()
  }

  const audioPart = msgItem.parts.find((p) => (p.partType || p.part_type) === 'audio_url')
  if (audioPart) {
    msgItem.content_type = 'audio'
    msgItem.audio_url = audioPart.uri || ''
    msgItem.audio_text = audioPart.textContent || audioPart.text_content || ''
    msgItem.audio_payload = audioPart.payload || {}
  }

  const audioAttachmentPart = msgItem.parts.find((p) => (p.partType || p.part_type) === 'audio_data')
  if (audioAttachmentPart && audioAttachmentPart.payload && audioAttachmentPart.payload.format === 'mp3') {
    msgItem.content_type = 'audio_attachment'
    msgItem.audio_data_url = audioAttachmentPart.uri || ''
    msgItem.audio_data_payload = audioAttachmentPart.payload || {}
  }
}
```

- [ ] **Step 5: Replace the single-purpose audio helpers with dual-source helpers**

Update the render helpers so the template can support both message types without duplicating playback UI.

```js
const isPlayableAudioMessage = (item) => {
  return !!(
    (item && item.content_type === 'audio' && item.audio_url) ||
    (item && item.content_type === 'audio_attachment' && item.audio_data_url)
