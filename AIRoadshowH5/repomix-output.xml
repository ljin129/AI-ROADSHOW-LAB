                if (msgInputFocused.value && msgInputRef.value) {
                    msgInputRef.value.blur()
                }
            }

            lastKnownViewportHeight = currentHeight
        })
    }
    window.visualViewport.addEventListener('resize', keyboardViewportResizeHandler)
}
