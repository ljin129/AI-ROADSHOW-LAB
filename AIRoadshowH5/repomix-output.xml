<script>
import { computed, nextTick, onBeforeUnmount, onMounted, reactive, ref } from 'vue'
import { useRouter } from 'vue-router'
import { Toast } from 'vant'
import PageHead from '@/components/pageHead'
import { GetUserIdentity, SaveUserIdentity, UpdateUserIdentity } from '@/api/user'
import { GetAsrProvider } from '@/api/index.js'
import { WXAppAudio } from '@/utils/wxAppAudio.js'

const identityOptions = [
    { value: 1, label: '保险经纪' },
    { value: 2, label: '理财顾问' },
    { value: 3, label: '软件销售' },
    { value: 4, label: '其他' },
]

const IDENTITY_TEXTS = {
    1: {
        tip: '可补充：客户类型、保障方向、沟通方式，或希望小络长期记住的沟通偏好。',
        placeholder: '比如「我主要服务企业主、高收入家庭等。我比较擅长把保险从“买产品”聊成“家庭风险安排”，常从孩子海外医疗、重疾断收入、长期储蓄和资产传承切入。我的风格是营销感很轻，先听后讲，用数据和真实案例建立信任，不靠焦虑逼客户马上决定。」',
    },
    2: {
        tip: '可补充：客户类型、资金关注点、跟进节奏，或希望小络长期记住的沟通偏好。',
        placeholder: '比如「我是银行理财顾问，客户多偏稳健，常会纠结收益、期限、流动性和风险。我希望小络帮我判断客户卡点，把复杂配置讲清楚，话术专业稳妥、短一点，不给客户压力。」',
    },
    3: {
        tip: '可补充：客户角色、业务痛点、推进方式，或希望小络长期记住的沟通偏好。',
        placeholder: '我是做企业软件销售的，客户决策链比较长，前期要先摸清业务流程、真实痛点和关键决策人。我希望小络多从业务价值和推进路径上帮我判断，少堆功能，多给我顾问式跟进话术。',
    },
    4: {
        tip: '请简单说说你是谁、能帮客户什么、希望小络怎么帮你沟通。',
        placeholder: '比如：「我主要靠长期关系和专业判断经营客户，希望小络先帮我看清关系状态、客户反应和下一步机会，再给我自然、不套路、但有方向感的推进建议。」',
    },
}

const DEFAULT_DESCRIPTION = ''

export default {
    name: 'UserIdentity',
    components: {
        PageHead,
    },
    setup() {
        const router = useRouter()
        const sdk = window.bjsdk || {}
        const isPc = ref((sdk.isWinPC || sdk.isMac) && !sdk.isWM)
        const pageTitle = ref(document.title || '身份设置')
        const textareaRef = ref(null)
        const isSaving = ref(false)
        const isRecording = ref(false)
        const isTranslating = ref(false)
        const isMini = ref(window.__wxjs_environment === 'miniprogram')
        const asrProviderInfo = ref('00')
        const voiceStatusText = ref('')
        const secCount = ref(0)
        const hasSavedIdentity = ref(false)
        const voiceFileId = ref('')
        const form = reactive({
            identityType: 1,
            description: DEFAULT_DESCRIPTION,
        })

        let wxAppAudio = null
        let timer = null
        let monitor = null
        let ignoreMouseUntil = 0
        let isStoppingRecord = false
        let isCancelRecord = false
        let voiceResultHandled = false

        const selectedIdentity = computed(() => {
            return identityOptions.find((item) => item.value === form.identityType) || identityOptions[0]
        })
        const shouldShowReference = computed(() => {
            return !!String(form.description || '').trim() || isRecording.value || isTranslating.value
        })
        const identityTip = computed(() => {
            return (IDENTITY_TEXTS[form.identityType] || IDENTITY_TEXTS[4]).tip
        })
        const identityPlaceholder = computed(() => {
            return (IDENTITY_TEXTS[form.identityType] || IDENTITY_TEXTS[4]).placeholder
        })
        const referenceExample = computed(() => identityPlaceholder.value)
        const isDescriptionRequired = computed(() => Number(form.identityType) === 4)
        const canSave = computed(() => {
            const hasValidIdentity = identityOptions.some((item) => item.value === Number(form.identityType))
            if (!hasValidIdentity) return false
            if (!isDescriptionRequired.value) return true
            return !!String(form.description || '').trim()
        })
        const saveButtonText = computed(() => {
            if (isDescriptionRequired.value && !String(form.description || '').trim()) {
                return '填写后保存'
            }
            return '保存资料'
        })

        const showLightTip = (message) => {
            Toast({
                message,
                duration: 1800,
            })
        }

        const normalizeWxActionData = (actionData = {}) => {
            if (actionData.Content && typeof actionData.Content === 'string') {
                try {
                    return JSON.parse(actionData.Content || '{}')
                } catch (error) {
                    return {}
                }
            }
            return actionData
        }

        const appendVoiceText = (text) => {
            const content = String(text || '').trim()
            if (!content) return
            form.description = content
            nextTick(resizeTextarea)
        }

        const clearTimer = () => {
            if (timer) {
                clearInterval(timer)
                timer = null
            }
        }

        const clearMonitor = () => {
            if (monitor) {
                clearTimeout(monitor)
                monitor = null
            }
        }

        const resizeTextarea = () => {
            const el = textareaRef.value
            if (!el) return
            el.style.height = 'auto'
            el.style.height = `${Math.min(Math.max(el.scrollHeight, 112), 220)}px`
        }

        const selectIdentity = (value) => {
            form.identityType = value
        }

        const getErrorMessage = (error, fallback) => {
            if (typeof error === 'string' && error.trim()) return error
            if (error && typeof error === 'object') {
                return error.ErrorMessage || error.errorMessage || error.message || fallback
            }
            return fallback
        }

        const getResponseData = (res) => {
            return (res && (res.Data !== undefined ? res.Data : res.data)) || null
        }

        const normalizeIdentityType = (value) => {
            const type = Number(value || 0)
            return identityOptions.some((item) => item.value === type) ? type : 0
        }

        const applyIdentityData = (data) => {
            if (!data || typeof data !== 'object') return false
            const type = normalizeIdentityType(data.IdentityType !== undefined ? data.IdentityType : data.identityType)
            const description = data.IdentityDescription !== undefined ? data.IdentityDescription : data.identityDescription
            const fileId = data.VoiceFileId !== undefined ? data.VoiceFileId : data.voiceFileId
            const hasData = type > 0 || !!String(description || '').trim() || !!String(fileId || '').trim()
            if (type > 0) form.identityType = type
            if (description !== undefined && description !== null) {
                form.description = String(description)
            }
            if (fileId !== undefined && fileId !== null) {
                voiceFileId.value = String(fileId)
            }
            hasSavedIdentity.value = hasData
            if (hasData) {
                nextTick(resizeTextarea)
            }
            return hasData
        }

        const fetchUserIdentity = async () => {
            try {
                const res = await GetUserIdentity()
                applyIdentityData(getResponseData(res))
            } catch (error) {
                console.error('GetUserIdentity failed', error)
            }
        }

        const startRecordTimer = () => {
            clearTimer()
            secCount.value = 0
            timer = setInterval(() => {
                secCount.value += 1
                if (secCount.value >= 60) {
                    stopRecord()
                }
            }, 1000)
        }

        const startWxAppRecord = () => {
            if (!wxAppAudio) {
                wxAppAudio = new WXAppAudio(sdk.query ? sdk.query('wsId') : '', wxSocketOnMessage, asrProviderInfo.value)
            }
            wxAppAudio.sendMessage({
                action: 30,
                action_data: {
                    content: JSON.stringify({
                        type: '30_1',
                    }),
                },
            })
        }

        const stopWxAppRecord = () => {
            if (!wxAppAudio) return
            wxAppAudio.sendMessage({
                action: 30,
                action_data: {
                    content: JSON.stringify({
                        type: '30_3',
                    }),
                },
            })
            startTranslateMonitor()
        }

        const cancelWxAppRecord = () => {
            if (!wxAppAudio) return
            wxAppAudio.sendMessage({
                action: 30,
                action_data: {
                    content: JSON.stringify({
                        type: '30_5',
                    }),
                },
            })
        }

        const startWxJsRecord = () => {
            const wx = window.wx
            if (!wx || typeof wx.startRecord !== 'function') {
                showLightTip('当前环境暂不支持语音输入')
                return false
            }
            wx.startRecord({
                success: () => {
                    isRecording.value = true
                    voiceStatusText.value = '松开后转文字'
                    startRecordTimer()
                },
                fail: () => {
                    isRecording.value = false
                    voiceStatusText.value = ''
                    showLightTip('录音启动失败')
                },
            })
            return true
        }

        const stopWxJsRecord = () => {
            const wx = window.wx
            if (!wx || typeof wx.stopRecord !== 'function') {
                resetVoiceState()
                return
            }
            wx.stopRecord({
                success: (res) => {
                    const localId = res.localId
                    translateWxJsVoice(localId)
                },
                fail: () => {
                    resetVoiceState()
                    showLightTip('录音结束失败')
                },
            })
        }

        const translateWxJsVoice = (localId) => {
            const wx = window.wx
            if (!localId || !wx || typeof wx.translateVoice !== 'function') {
                resetVoiceState()
                showLightTip('语音转文字失败，请重新录音')
                return
            }
            isTranslating.value = true
            voiceStatusText.value = '正在转文字...'
            wx.translateVoice({
                localId,
                isShowProgressTips: 0,
                success: (res) => {
                    appendVoiceText(res.translateResult || '')
                    resetVoiceState()
                },
                fail: () => {
                    resetVoiceState()
                    showLightTip('语音转文字失败，请重新录音')
                },
            })
        }

        const startTranslateMonitor = () => {
            clearMonitor()
            monitor = setTimeout(() => {
                resetVoiceState()
                isCancelRecord = true
                cancelWxAppRecord()
                showLightTip('语音转文字失败，请重新录音')
            }, 10000)
        }

        const resetVoiceState = () => {
            clearTimer()
            clearMonitor()
            isRecording.value = false
            isTranslating.value = false
            isStoppingRecord = false
            voiceStatusText.value = ''
        }

        const onVoiceStart = (event) => {
            if (event && event.type && event.type.indexOf('touch') === 0) {
                ignoreMouseUntil = Date.now() + 700
            }
            if (event && event.type && event.type.indexOf('mouse') === 0 && Date.now() < ignoreMouseUntil) {
                return
            }
            if (isRecording.value || isTranslating.value || isStoppingRecord) return
            isCancelRecord = false
            voiceResultHandled = false
            isRecording.value = true
            voiceStatusText.value = '松开后转文字'
            if (isMini.value) {
                startWxAppRecord()
                startRecordTimer()
                return
            }
            if (!startWxJsRecord()) {
                resetVoiceState()
            }
        }

        const stopRecord = () => {
            if (!isRecording.value || isStoppingRecord) return
            if (secCount.value < 1) {
                cancelRecord()
                showLightTip('录音时间太短')
                return
            }
            isStoppingRecord = true
            isRecording.value = false
            isTranslating.value = true
            voiceStatusText.value = '正在转文字...'
            clearTimer()
            if (isMini.value) {
                stopWxAppRecord()
                return
            }
            stopWxJsRecord()
        }

        const cancelRecord = () => {
            if (!isRecording.value && !isTranslating.value) return
            isCancelRecord = true
            if (isMini.value) {
                cancelWxAppRecord()
            }
            resetVoiceState()
        }

        const onVoiceEnd = (event) => {
            if (event && event.type && event.type.indexOf('mouse') === 0 && Date.now() < ignoreMouseUntil) {
                return
            }
            stopRecord()
        }

        const onVoiceCancel = () => {
            cancelRecord()
        }

        const onMouseLeaveVoice = (event) => {
            if (event && event.buttons === 1 && isRecording.value) {
                stopRecord()
            }
        }

        const wxSocketOnMessage = (message) => {
            const newMessage = JSON.parse(message || '{}')
            const { action, action_data = {} } = newMessage
            switch (action) {
                case 11:
                    resetVoiceState()
                    showLightTip('语音转文字失败，请重新录音')
                    break
                case 24:
                    if (voiceResultHandled || isCancelRecord) break
                    voiceResultHandled = true
                    voiceFileId.value = action_data.file_id || ''
                    appendVoiceText(action_data.audioText || '')
                    resetVoiceState()
                    break
                case 30:
                    {
                        const content = normalizeWxActionData(action_data)
                        if (content.type === '30_2') {
                            startRecordTimer()
                        }
                        if (content.type === '30_6') {
                            resetVoiceState()
                            showLightTip('录音失败，请重新录音')
                        }
                    }
                    break
                default:
                    break
            }
        }

        const validateForm = () => {
            if (!selectedIdentity.value) {
                showLightTip('请选择身份类型')
                return false
            }
            if (isDescriptionRequired.value && !String(form.description || '').trim()) {
                showLightTip('请填写身份说明')
                return false
            }
            return true
        }

        const handleCancel = () => {
            window.bjsdk.goTo(-1)
        }

        const handleSave = async () => {
            if (isSaving.value) return
            if (!validateForm()) return
            const payload = {
                identityType: form.identityType,
                identityDescription: String(form.description || '').trim(),
                voiceFileId: String(voiceFileId.value || '').trim(),
            }
            try {
                isSaving.value = true
                const res = hasSavedIdentity.value
                    ? await UpdateUserIdentity(payload)
                    : await SaveUserIdentity(payload)
                applyIdentityData(getResponseData(res))
                hasSavedIdentity.value = true
                showLightTip('保存成功')
                setTimeout(() => {
                    handleCancel()
                }, 500)
            } catch (error) {
                showLightTip(getErrorMessage(error, '保存失败'))
            } finally {
                isSaving.value = false
            }
        }

        const readQuery = (key) => {
            if (!window.bjsdk || typeof window.bjsdk.query !== 'function') return ''
            return window.bjsdk.query(key) || ''
        }

        onMounted(async () => {
            await fetchUserIdentity()
            const identityType = Number(readQuery('identityType') || readQuery('IdentityType'))
            const description = readQuery('identityDescription') || readQuery('IdentityDescription')
            if (!hasSavedIdentity.value && identityOptions.some((item) => item.value === identityType)) {
                form.identityType = identityType
            }
            if (!hasSavedIdentity.value && description) {
                form.description = String(description)
            }
            try {
                const res = await GetAsrProvider()
                if (res && res.Data) {
                    asrProviderInfo.value = res.Data
                }
            } catch (error) {
                console.error('GetAsrProvider failed', error)
            }
            if (isMini.value) {
                wxAppAudio = new WXAppAudio(readQuery('wsId'), wxSocketOnMessage, asrProviderInfo.value)
            }
            nextTick(resizeTextarea)
        })

        onBeforeUnmount(() => {
            resetVoiceState()
            if (wxAppAudio && typeof wxAppAudio.closeWXAppAudio === 'function') {
                wxAppAudio.closeWXAppAudio()
            }
        })

        return {
            isPc,
            pageTitle,
            textareaRef,
            identityOptions,
            form,
            isSaving,
            isRecording,
            isTranslating,
            voiceStatusText,
            identityTip,
            identityPlaceholder,
            canSave,
            saveButtonText,
            shouldShowReference,
            referenceExample,
            selectIdentity,
            resizeTextarea,
            onVoiceStart,
            onVoiceEnd,
            onVoiceCancel,
            onMouseLeaveVoice,
            handleCancel,
            handleSave,
        }
    },
}
</script>

