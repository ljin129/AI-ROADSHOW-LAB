<template>
    <div class="preview_page">
        <van-form class="preview_form" @submit="onSubmit">
            <van-cell-group inset>
                <van-field
                    v-model="form.relationName"
                    name="relationName"
                    label="关系名称"
                    placeholder="请输入关系名称"
                    maxlength="10"
                    show-word-limit
                />
                <van-field
                    v-model="form.mobile"
                    name="mobile"
                    type="tel"
                    label="手机号码"
                    placeholder="请输入手机号码"
                    maxlength="11"
                />
                <van-field
                    v-model="form.currentStatus"
                    name="currentStatus"
                    rows="3"
                    type="textarea"
                    label="关系现状"
                    placeholder="请输入关系现状"
                    maxlength="200"
                    show-word-limit
                />
                <van-field
                    v-model="form.remark"
                    name="remark"
                    rows="3"
                    type="textarea"
                    label="描述备注"
                    placeholder="请输入描述备注"
                    maxlength="200"
                    show-word-limit
                />
                <van-field
                    v-model="form.futureExpectation"
                    name="futureExpectation"
                    rows="3"
                    type="textarea"
                    label="未来预期"
                    placeholder="请输入未来预期"
                    maxlength="200"
                    show-word-limit
                />
            </van-cell-group>
            <div class="preview_form_actions">
                <van-button round block type="primary" native-type="submit">
                    保存关系
                </van-button>
            </div>
        </van-form>
    </div>
</template>
<script>
import { reactive } from 'vue'
import { Form, Field, CellGroup, Button, Toast } from 'vant'

const mobileReg = /^1[3-9]\d{9}$/

export default {
    components: {
        [Form.name]: Form,
        [Field.name]: Field,
        [CellGroup.name]: CellGroup,
        [Button.name]: Button
    },
    setup () {
        const form = reactive({
            relationName: '',
            mobile: '',
            currentStatus: '',
            remark: '',
            futureExpectation: ''
        })

        function validatePhone (phone) {
            return mobileReg.test((phone || '').trim())
        }

        function validateAllFilled () {
            const f = form
            if (!f.relationName || !String(f.relationName).trim()) {
                Toast('请填写关系名称')
                return false
            }
            if (!f.mobile || !String(f.mobile).trim()) {
                Toast('请填写手机号码')
                return false
            }
            if (!validatePhone(f.mobile)) {
                Toast('请输入正确的手机号码')
                return false
            }
            if (!f.currentStatus || !String(f.currentStatus).trim()) {
                Toast('请填写关系现状')
                return false
            }
            if (!f.remark || !String(f.remark).trim()) {
                Toast('请填写描述备注')
                return false
            }
            if (!f.futureExpectation || !String(f.futureExpectation).trim()) {
                Toast('请填写未来预期')
                return false
            }
            return true
        }

        function onSubmit () {
            if (!validateAllFilled()) {
                return
            }
            let list = []
            try {
                const cache = localStorage.getItem('pRelationList')
                list = cache ? JSON.parse(cache) : []
                if (!Array.isArray(list)) {
                    list = []
                }
            } catch (e) {
                list = []
            }
            list.push({
                relationName: form.relationName,
                mobile: form.mobile,
                currentStatus: form.currentStatus,
                remark: form.remark,
                futureExpectation: form.futureExpectation,
                createTime: Date.now()
            })
            localStorage.setItem('pRelationList', JSON.stringify(list))
            Toast.success('保存成功，待审核通过')
            bjsdk.goTo('/previewList', {})
        }

        return {
            form,
            onSubmit
        }
    }
}
</script>
