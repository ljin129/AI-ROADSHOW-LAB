            const touch = e.touches[0]
            const x = touch.clientX
            const y = touch.clientY
            const inside = x >= rect.left && x <= rect.right && y >= rect.top && y <= rect.bottom
            fingerOutsideOverlay.value = !inside
        }

        // fn:停止录音
		const onStopRecord = () => {
