<file path="src/views/home/components/customerList.vue">
<template>
	<div v-if="visible" class="customer-picker-mask" @click.self="onCancel">
		<div class="customer-picker-panel">
			<div class="customer-picker-header">
				<button class="header-btn" type="button" @click="onCancel">取消</button>
				<div class="header-title">从全部客户中选择</div>
				<button class="header-btn header-btn-confirm" type="button" @click="onConfirm">确认</button>
			</div>

			<div class="customer-picker-search">
				<input
					v-model="query"
					class="customer-picker-search-input"
					type="text"
					placeholder="搜索客户"
					@keyup.enter="triggerSearch"
				/>
			</div>

			<div class="customer-picker-list">
				<van-list
					v-model:loading="loading"
					:finished="finished"
					finished-text="没有更多了"
					@load="onLoad"
				>
					<div
						v-for="c in customers"
						:key="c.CustomerId"
						class="list-card"
						:class="{ selected: selectedCustomerId === c.CustomerId }"
						@click="onSelect(c)"
					>
						<div class="list-card-header">
							<div class="list-card-header-name">{{ c.Name }}</div>
							<span class="list-card-header-info" v-if="c.Gender || c.Age">{{ c.Gender ? c.Gender : '' }}{{ c.Gender && c.Age ? ' ' : '' }}{{ c.Age ? c.Age + '岁' : '' }}</span>
							<div class="radio-dot" :class="{ checked: selectedCustomerId === c.CustomerId }"></div>
						</div>
						<div class="list-card-meta">
							<div class="list-card-meta-contact" v-if="c.LastContactDate">最近联系：{{ c.LastContactDate }}</div>
							<div class="list-card-meta-org">{{ formatOrg(c) }}</div>
						</div>
						<div class="list-card-tag" v-if="c.OtherTags">
							<span
								v-for="(t, index) in parseTags(c.OtherTags).slice(0, c.Company || c.Position || c.Industry ? 3 : undefined)"
								:key="index"
								class="list-card-tag-item"
								:style="{
									backgroundColor: TAG_COLOR_POOL[index % TAG_COLOR_POOL.length].bg,
									color: TAG_COLOR_POOL[index % TAG_COLOR_POOL.length].text,
									border: '1px solid ' + TAG_COLOR_POOL[index % TAG_COLOR_POOL.length].border
								}"
							>
								{{ t.text || t }}
							</span>
						</div>
					</div>
				</van-list>
			</div>
		</div>
	</div>
</template>

<script>
import { reactive, ref, toRefs, watch } from 'vue'
import { List, Toast } from 'vant'
import { GetCustomerByUserIdPaged } from '@/api/custCustomer'

const TAG_COLOR_POOL = [
	{ bg: '#F8FAFC', text: '#64748B', border: '#E2E8F0' },
	{ bg: '#F7F9FF', text: '#5B6B9A', border: '#DCE4F7' },
	{ bg: '#F8FCF7', text: '#5E7D68', border: '#DDEBDF' },
	{ bg: '#FFF9F5', text: '#8B6B52', border: '#F1E1D4' },
	{ bg: '#FFF7FA', text: '#8B6278', border: '#F0DCE7' },
	{ bg: '#F6FBFB', text: '#5C7D80', border: '#D9EAEC' },
	{ bg: '#FAF8FF', text: '#6F658C', border: '#E5DFF3' },
]

export default {
	name: 'HomeCustomerList',
	components: {
		[List.name]: List,
		[Toast.name]: Toast,
	},
	props: {
		visible: {
			type: Boolean,
			default: false,
		},
	},
	emits: ['close', 'confirm'],
	setup(props, { emit }) {
		const query = ref('')
		const selectedCustomerId = ref('')
		const selectedCustomer = ref(null)

		const state = reactive({
			customers: [],
			loading: false,
			finished: false,
			pageIndex: 0,
			pageSize: 10,
			total: 0,
		})

		const loadData = async () => {
			try {
				const res = await GetCustomerByUserIdPaged({
					PageIndex: state.pageIndex,
					PageSize: state.pageSize,
					KeyWord: query.value,
					IncludeSessionId: true,
				})
				const list = (res && res.Data && res.Data.List) || []
				state.customers.push(...list)
				state.total = (res && res.Data && res.Data.TotalCount) || 0
				if (state.customers.length >= state.total || list.length === 0) {
					state.finished = true
				}
			} catch (error) {
				state.finished = true
				console.error(error)
			} finally {
				state.loading = false
			}
		}

		const resetAndSearch = () => {
			state.customers = []
			state.finished = false
			state.loading = false
			state.total = 0
			state.pageIndex = 0
			onLoad()
		}

		const onLoad = () => {
			if (state.finished) return
			state.loading = true
			state.pageIndex++
			loadData()
		}

		const onSelect = (c) => {
			selectedCustomerId.value = c.CustomerId
			selectedCustomer.value = c
		}

		const onCancel = () => {
			emit('close')
		}

		const onConfirm = () => {
			if (!selectedCustomer.value || !selectedCustomer.value.CustomerId) {
				Toast('请先选择客户')
				return
			}
			emit('confirm', selectedCustomer.value)
		}

		let searchTimer = null
		const triggerSearch = () => {
			if (!props.visible) return
			if (searchTimer) clearTimeout(searchTimer)
			resetAndSearch()
		}

		watch(query, () => {
			if (!props.visible) return
			if (searchTimer) clearTimeout(searchTimer)
			searchTimer = setTimeout(() => {
				resetAndSearch()
			}, 500)
		})

		watch(
			() => props.visible,
			(nextVisible) => {
				if (!nextVisible) return
				query.value = ''
				selectedCustomerId.value = ''
				selectedCustomer.value = null
				resetAndSearch()
			},
			{ immediate: true }
		)

		const formatOrg = (c) => {
			const parts = [c.Industry, c.Company, c.Position].filter(Boolean)
			return parts.join(' • ')
		}

		const parseTags = (tagStr) => {
			if (!tagStr) return []
			try {
				const parsed = JSON.parse(tagStr)
				if (Array.isArray(parsed)) return parsed
			} catch (e) {
				return []
			}
			return []
		}

		return {
			query,
			selectedCustomerId,
			onSelect,
			onCancel,
			onConfirm,
			triggerSearch,
			onLoad,
			formatOrg,
			parseTags,
			TAG_COLOR_POOL,
			...toRefs(state),
		}
	},
}
</script>

