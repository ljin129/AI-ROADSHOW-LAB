    }

    :deep(.markdown_copy_toggle) {
        padding: 0;
        border: 0;
        background: transparent;
        color: #1677ff;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.4;
        cursor: pointer;
    }

    :deep(.markdown_tabs_block) {
        margin: 12px 0;
        padding: 18px 20px;
        border: 1px solid #eef2f7;
        border-radius: 10px;
        background: #ffffff;
        box-shadow: 0 2px 10px rgba(15, 23, 42, 0.04);
        overflow: hidden;
    }

    :deep(.markdown_tabs_title) {
        margin-bottom: 12px;
        font-size: 16px;
        font-weight: 700;
        line-height: 1.35;
        color: #111827;
    }

    :deep(.markdown_tabs_nav) {
        display: flex;
        align-items: center;
        gap: 22px;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        border-bottom: 1px solid #edf2f7;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }

    :deep(.markdown_tabs_nav::-webkit-scrollbar) {
        display: none;
    }

    :deep(.markdown_tab_btn) {
        flex: 0 0 auto;
        position: relative;
        padding: 0 0 10px;
        border: 0;
        background: transparent;
        color: #64748b;
        font-size: 14px;
        font-weight: 700;
        line-height: 1.4;
        cursor: pointer;
    }

    :deep(.markdown_tab_btn.is_active) {
        color: #1677ff;
    }

    :deep(.markdown_tab_btn.is_active::after) {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -1px;
        height: 2px;
        border-radius: 2px;
        background: #1677ff;
    }

    :deep(.markdown_tabs_panes) {
        margin-top: 12px;
    }

    :deep(.markdown_tab_pane) {
        display: none;
        max-height: 200px;
        overflow-y: auto;
        padding: 2px 2px 0 0;
        color: #1f2937;
        scrollbar-width: thin;
    }

    :deep(.markdown_tab_pane.is_active) {
        display: block;
    }

    :deep(.markdown_tab_actions) {
        position: sticky;
        top: 0;
        z-index: 1;
        display: flex;
        justify-content: flex-end;
        padding: 0 0 4px;
        background: linear-gradient(180deg, #ffffff 74%, rgba(255, 255, 255, 0));
    }

    :deep(.markdown_tab_copy_btn) {
        padding: 0;
        border: 0;
        background: transparent;
        color: #1677ff;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.4;
        cursor: pointer;
    }

    :deep(.markdown_tab_content) {
        font-size: 14px;
        line-height: 1.7;
    }

    :deep(.markdown_tab_content > :first-child) {
        margin-top: 0;
    }

    :deep(.markdown_tab_content > :last-child) {
        margin-bottom: 0;
    }
}
