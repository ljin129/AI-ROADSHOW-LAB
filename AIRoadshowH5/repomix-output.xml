<template>
    <div class="example_container">
        <h3 class="example_title">说说你的客户</h3>

        <div class="question_grid">
            <div
                v-for="item in questionList"
                :key="item.text"
                class="question_pill"
                :class="item.type"
            >
                {{ item.text }}
            </div>
        </div>

        <section class="example_card">
            <div class="tab_bar">
                <button
                    v-for="tab in tabs"
                    :key="tab.key"
                    type="button"
                    class="tab_btn"
                    :class="{ is_active: activeTab === tab.key }"
                    @click="activeTab = tab.key"
                >
                    {{ tab.label }}
                </button>
            </div>

            <div class="example_hint">
                <span class="quote_mark">“</span>
                <span>比如你可以这样说</span>
            </div>

            <p class="example_text">
                <template v-for="(part, index) in currentExample.parts" :key="`${activeTab}_${index}`">
                    <span v-if="part.color" class="highlight_text" :class="part.color">{{ part.text }}</span>
                    <span v-else>{{ part.text }}</span>
                </template>
            </p>
        </section>

        <p class="example_footer">
            <template v-if="showIdentityEntry">
                <span>说多说少都行，小络会慢慢更懂你。想更精准，可</span>
                <button type="button" @click="goIdentitySetting">完善身份设置></button>
            </template>
            <template v-else>
                说多说少都行，小络会慢慢更懂你。想更精准，可完善身份设置
            </template>
        </p>
    </div>
</template>

<script>
import { computed, onMounted, ref } from 'vue'
import { GetUserIdentity } from '@/api/user'

const questionList = [
    { text: '你是做什么的', type: 'job' },
    { text: 'TA是谁、怎么认识', type: 'person' },
    { text: 'TA在乎什么', type: 'care' },
    { text: '你想推进什么', type: 'goal' },
]

const tabs = [
    {
        key: 'lead',
        label: '潜在客户破冰',
        parts: [
            { text: '我做香港保险的', color: 'job' },
            { text: '，' },
            { text: '张姐是老客户介绍的，上海做贸易的', color: 'person' },
            { text: '。' },
            { text: '她女儿下半年去美国读研，想了解留学的医疗保障', color: 'care' },
            { text: '。' },
            { text: '我想趁这个话题约她深聊一次，先把信任建起来', color: 'goal' },
            { text: '。' },
        ],
    },
    {
        key: 'reconnect',
        label: '老客户重联',
        parts: [
            { text: '我是银行理财经理', color: 'job' },
            { text: '，' },
            { text: '王总是以前服务过的老客户，做制造业的', color: 'person' },
            { text: '。' },
            { text: '最近市场波动大，他之前比较关注稳健配置和现金管理', color: 'care' },
            { text: '。' },
            { text: '我想找个不突兀的理由重新聊起来，先做一次资产检视', color: 'goal' },
            { text: '。' },
        ],
    },
    {
        key: 'noReply',
        label: '客户没回复',
        parts: [
            { text: '我是企业客户经理', color: 'job' },
            { text: '，' },
            { text: '刘总是上周聊过的潜在客户，之前说想看服务方案', color: 'person' },
            { text: '。' },
            { text: '方案发过去后他一直没回复，可能还在比较', color: 'care' },
            { text: '。' },
            { text: '我想低打扰跟进一次，把重点拎出来让他更容易判断', color: 'goal' },
            { text: '。' },
        ],
    },
]

export default {
    setup() {
        const activeTab = ref(tabs[0].key)
        const showIdentityEntry = ref(false)
        const currentExample = computed(() => tabs.find((item) => item.key === activeTab.value) || tabs[0])

        const getResponseData = (res) => {
            return (res && (res.Data !== undefined ? res.Data : res.data)) || null
        }
        const getIdentityDescription = (data) => {
            if (!data || typeof data !== 'object') return ''
            return data.IdentityDescription !== undefined ? data.IdentityDescription : data.identityDescription
        }
        const isUserIdentityNotExist = (error) => {
            if (typeof error === 'string') return error.indexOf('用户身份不存在') > -1
            if (!error || typeof error !== 'object') return false
            const state = error.State !== undefined ? error.State : error.state
            if (Number(state) === 1) return true
            const message = error.ErrorMessage || error.errorMessage || error.message || ''
            return String(message).indexOf('用户身份不存在') > -1
        }
        const refreshIdentityEntry = async () => {
            try {
                const res = await GetUserIdentity()
                const description = getIdentityDescription(getResponseData(res))
                showIdentityEntry.value = !String(description || '').trim()
            } catch (error) {
                showIdentityEntry.value = isUserIdentityNotExist(error)
                if (!showIdentityEntry.value) {
                    console.error('GetUserIdentity failed', error)
                }
            }
        }
        const goIdentitySetting = () => {
            if (window.bjsdk && typeof window.bjsdk.goTo === 'function') {
                window.bjsdk.goTo('/user/identity', {})
                return
            }
            window.location.hash = '#/user/identity'
        }

        onMounted(refreshIdentityEntry)

        return {
            activeTab,
            currentExample,
            goIdentitySetting,
            showIdentityEntry,
            questionList,
            tabs,
        }
    },
}
</script>

