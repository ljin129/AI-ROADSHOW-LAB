                }
            }
            if (inputType.value === 'text') {
                armKeyboardFollow()
                nextTick(() => {
                    resizeMsgInput()
                })
            }
        }

        const toggleTools = () => {
            if (!inputActionEnabled.value || attachments.value.length > 0) return
            showTools.value = !showTools.value
            if (showTools.value && msgInputRef.value && typeof msgInputRef.value.blur === 'function') {
                msgInputRef.value.blur()
            }
        }
        const IMG_COMPRESS_THRESHOLD = 2 * 1024 * 1024 // 2MB
        const IMG_MAX_EDGE = 1920
        const IMG_QUALITY = 0.85
        const MAX_UPLOAD_AUDIO_SIZE = 5 * 1024 * 1024
        const MAX_UPLOAD_FILE_SIZE = 1 * 1024 * 1024
        const ATTACHMENT_LIMITS = {
            image: 9,
            audio: 1,
            file: 1,
        }
        // const FILE_ACCEPT = '.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt'
        const FILE_ACCEPT = '.md,.txt'
        const FILENAME_SANITIZE_RE = /[^一-龥a-zA-Z0-9._-]/g
        const compressImageFile = (file) => {
            return new Promise((resolve) => {
                const reader = new FileReader()
                reader.onload = (e) => {
                    const img = new Image()
                    img.onload = () => {
                        let { width, height } = img
                        const originWidth = width
                        const originHeight = height
                        if (width > IMG_MAX_EDGE || height > IMG_MAX_EDGE) {
                            if (width > height) {
                                height = Math.round(height * (IMG_MAX_EDGE / width))
                                width = IMG_MAX_EDGE
                            } else {
                                width = Math.round(width * (IMG_MAX_EDGE / height))
                                height = IMG_MAX_EDGE
                            }
                        }
                        const canvas = document.createElement('canvas')
                        canvas.width = width
                        canvas.height = height
                        const ctx = canvas.getContext('2d')
                        ctx.drawImage(img, 0, 0, width, height)
                        canvas.toBlob(
                            (blob) => {
                                if (blob && (blob.size < file.size || width !== originWidth)) {
                                    const compressedFile = new File([blob], file.name, {
                                        type: 'image/jpeg',
                                        lastModified: Date.now(),
                                    })
                                    resolve(compressedFile)
                                } else {
                                    resolve(file)
                                }
                            },
                            'image/jpeg',
                            IMG_QUALITY
                        )
                    }
                    img.onerror = () => {
                        resolve(file)
                    }
                    img.src = e.target.result
                }
                reader.onerror = () => resolve(file)
                reader.readAsDataURL(file)
            })
        }
        const onFileOversize = (fileItem) => {
            const file = fileItem && fileItem.file ? fileItem.file : fileItem
            const mimeType = `${file && file.type ? file.type : ''}`.toLowerCase()
            if (mimeType.startsWith('image/')) {
                Toast.fail('单个图片不能超过50MB')
                return
            }
            if (isMp3AudioFile(file)) {
                Toast.fail('音频文件不能超过5MB')
                return
            }
            Toast.fail('文档类文件不能超过1MB')
        }
        const normalizeFileName = (name = '') => {
            const trimmed = `${name || ''}`.trim()
            const normalized = trimmed.replace(FILENAME_SANITIZE_RE, '_')
            return normalized || 'file'
        }
        const isMp3AudioFile = (file) => {
            if (!file) return false
            const mimeType = `${file.type || ''}`.toLowerCase()
            const fileName = `${file.name || ''}`.toLowerCase()
            return mimeType === 'audio/mpeg' || fileName.endsWith('.mp3')
        }
        const getAttachmentFormat = (fileLike = {}) => {
            const mimeType = `${fileLike.type || fileLike.mimeType || ''}`.toLowerCase()
            if (mimeType.includes('/')) {
                const subtype = mimeType.split('/').pop().split(';')[0].trim()
                if (subtype) return subtype
            }
            const fileName = normalizeFileName(fileLike.name || fileLike.fileName || '')
            const lastDotIndex = fileName.lastIndexOf('.')
            if (lastDotIndex > -1 && lastDotIndex < fileName.length - 1) {
                return fileName.slice(lastDotIndex + 1).toLowerCase()
            }
            return 'file'
        }
        const buildPayloadMeta = ({ fileName = '', format = '', size, source = '', extra = {} } = {}) => {
            const payload = {
                ...extra,
            }
            if (source) payload.source = source
            if (fileName) payload.filename = normalizeFileName(fileName)
            if (format) payload.format = format
            if (Number.isFinite(size) && size > 0) payload.size = size
            return payload
        }
        const getAudioFileDurationMs = (file) => {
            if (!(file instanceof File)) return Promise.resolve(0)
            return new Promise((resolve) => {
                const objectUrl = URL.createObjectURL(file)
                const audio = document.createElement('audio')
                const cleanup = () => {
                    audio.removeAttribute('src')
                    audio.load()
                    URL.revokeObjectURL(objectUrl)
                }
                audio.preload = 'metadata'
                audio.onloadedmetadata = () => {
                    const durationMs = Number.isFinite(audio.duration) && audio.duration > 0
                        ? Math.round(audio.duration * 1000)
                        : 0
                    cleanup()
                    resolve(durationMs)
                }
                audio.onerror = () => {
                    cleanup()
                    resolve(0)
                }
                audio.src = objectUrl
            })
        }
        const buildUserTextContent = (text = '') => {
            return text || ''
        }
        const buildRealtimeAsrTextContent = (text = '') => {
            return text || ''
        }
        const buildFileAsrTextContent = ({ text = '' } = {}) => {
            return text || ''
        }
        const extractUploadedFileId = (res) => {
            return `${
                (res && (res.fileId || res.FileId || res.fid || res.FId)) ||
                (res && res.Data && (res.Data.fileId || res.Data.FileId || res.Data.fid || res.Data.FId)) ||
                ''
            }`.trim()
        }
        const extractAsrText = (res) => {
            return `${
                (res && (res.text || res.Text || res.result || res.Result || res.content || res.Content || (bjsdk.isStr(res.Data) && res.Data))) ||
                (res && res.Data && (res.Data.text || res.Data.Text || res.Data.result || res.Data.Result || res.Data.content || res.Data.Content)) ||
                ''
            }`.trim()
        }
        const stripProtocolPrefix = (text = '') => {
            return `${text || ''}`
        }
        const requestUploadedAudioAsr = async (item) => {
            if (!item || item.type !== 'audio') return false
            if (item.status === 'uploading' || item.asrStatus === 'retrying') return false
            if (!item.fileId) {
                item.asrStatus = 'failed'
                throw new Error('missing fileId')
            }
            item.asrStatus = 'retrying'
            const res = await GetAsrResultFromFId({
                voiceFormat: 'mp3',
                engineType: '16k_zh_large',
                fileId: item.fileId,
            })
            const asrText = extractAsrText(res)
            if (!asrText) {
                item.asrStatus = 'failed'
                throw new Error('empty asr text')
            }
            item.textContent = buildFileAsrTextContent({
                text: asrText,
                fileName: item.fileName,
            })
            item.asrStatus = 'success'
            return true
        }
        const retryUploadedAudioAsr = async (item, maxAttempts = 1) => {
            if (!item || item.type !== 'audio') return false
            if (item.status === 'uploading' || item.asrStatus === 'retrying') return false
            let lastError = null
            const attempts = Math.max(1, maxAttempts)
            for (let attempt = 0; attempt < attempts; attempt++) {
                try {
                    return await requestUploadedAudioAsr(item)
                } catch (err) {
                    lastError = err
                }
            }
            if (lastError) {
                throw lastError
            }
            return false
        }
        const formatSize = (bytes) => {
            if (!Number.isFinite(bytes) || bytes < 0) return ''
            if (bytes === 0) return '0B'
            const k = 1024
            const sizes = ['B', 'KB', 'MB', 'GB']
            const i = Math.floor(Math.log(bytes) / Math.log(k))
            return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + sizes[i]
        }
        const FILE_TYPE_ICON_MAP = {
            pdf: { label: 'PDF', className: 'is_pdf' },
            doc: { label: 'DOC', className: 'is_doc' },
            docx: { label: 'DOC', className: 'is_doc' },
            xls: { label: 'XLS', className: 'is_xls' },
            xlsx: { label: 'XLS', className: 'is_xls' },
            ppt: { label: 'PPT', className: 'is_ppt' },
            pptx: { label: 'PPT', className: 'is_ppt' },
            txt: { label: 'TXT', className: 'is_txt' },
            file: { label: 'FILE', className: 'is_file' },
        }
        const getFileTypeInfo = (fileLike = {}) => {
            const format = `${getAttachmentFormat(fileLike) || 'file'}`.toLowerCase()
            return FILE_TYPE_ICON_MAP[format] || { label: format.toUpperCase() || 'FILE', className: 'is_file' }
        }
        const getFileMetaText = (fileLike = {}) => {
            const formattedSize = fileLike && fileLike.formattedSize ? fileLike.formattedSize : formatSize(Number(fileLike && fileLike.size))
            return formattedSize || ''
        }
        const getAttachmentCategory = (file) => {
            const mimeType = `${file && file.type ? file.type : ''}`.toLowerCase()
            if (mimeType.startsWith('image/')) return 'image'
            if (isMp3AudioFile(file)) return 'audio'
            return 'file'
        }
        const getAttachmentCountByType = (type) => {
            return attachments.value.filter((item) => item && item.type === type).length
        }
        const canAddMoreAttachmentType = (type) => {
            const limit = ATTACHMENT_LIMITS[type]
            if (!limit) return false
            return getAttachmentCountByType(type) < limit
        }
        const showAttachmentAddButton = (type) => {
            return getAttachmentCountByType(type) > 0 && canAddMoreAttachmentType(type)
        }
        const getAttachmentCountText = (type) => {
            const count = getAttachmentCountByType(type)
            if (!count) return ''
            const limit = ATTACHMENT_LIMITS[type]
            const labelMap = {
                image: '图片',
                audio: '音频',
                file: '文件',
            }
            return `${labelMap[type] || '附件'} ${count}/${limit}`
        }
        const getAttachmentPanelCountText = () => {
            return ['image', 'audio', 'file']
                .map((type) => getAttachmentCountText(type))
                .filter(Boolean)
                .join(' · ')
        }
        const getAttachmentLimitMessage = (type) => {
            if (type === 'image') return '图片最多上传9张'
            if (type === 'audio') return '音频最多上传1个'
            return '文件最多上传1个'
        }
        const afterReadFile = async (fileItem) => {
            const sourceFile = fileItem.file
            const category = getAttachmentCategory(sourceFile)
            const isImage = category === 'image'
            const isAudio = category === 'audio'
            let uploadFile = sourceFile
            let previewUrl = fileItem.content

            if (!canAddMoreAttachmentType(category)) {
                Toast.fail(getAttachmentLimitMessage(category))
                return
            }

            if (sourceFile && sourceFile.type && sourceFile.type.startsWith('audio/') && !isAudio) {
                Toast.fail('仅支持上传 mp3 音频')
                return
            }

            if (isAudio && uploadFile.size > MAX_UPLOAD_AUDIO_SIZE) {
                Toast.fail('音频文件不能超过5MB')
                return
            }

            if (!isImage && !isAudio && uploadFile.size > MAX_UPLOAD_FILE_SIZE) {
                Toast.fail('文档类文件不能超过1MB')
                return
            }

            if (isImage && uploadFile.size > IMG_COMPRESS_THRESHOLD) {
                Toast.loading({ message: '正在处理图片...', forbidClick: true, duration: 0 })
                try {
                    const compressed = await compressImageFile(uploadFile)
                    if (compressed !== uploadFile) {
                        uploadFile = compressed
                        previewUrl = URL.createObjectURL(uploadFile)
                    }
                } finally {
                    Toast.clear()
                }
            }

            const normalizedFileName = normalizeFileName(uploadFile.name || 'file')
            const durationMs = isAudio ? await getAudioFileDurationMs(uploadFile) : 0
            const item = {
                id: Date.now() + Math.random().toString(36).substring(2, 9),
                type: isImage ? 'image' : (isAudio ? 'audio' : 'file'),
                file: uploadFile,
                fileName: normalizedFileName,
                format: isAudio ? 'mp3' : getAttachmentFormat({ ...uploadFile, name: normalizedFileName }),
                size: uploadFile.size,
                source: 'file',
                formattedSize: formatSize(uploadFile.size),
                url: previewUrl,
                progress: 0,
                status: 'uploading',
                fileId: '',
                textContent: '',
                asrStatus: isAudio ? 'pending' : 'success',
                asrAutoRetried: false,
                asrSendRetried: false,
                payload: isAudio ? buildPayloadMeta({
                    fileName: normalizedFileName,
                    format: 'mp3',
                    size: uploadFile.size,
                    source: 'file',
                    extra: durationMs > 0 ? { duration_ms: durationMs } : {},
                }) : {},
            }
            attachments.value.push(item)
            showTools.value = false

            const params = {
                files: item.file
            }

            try {
                const res = await UploadFile(params, (progressEvent) => {
                    if (progressEvent.total) {
                        const progress = Math.round((progressEvent.loaded * 100) / progressEvent.total)
                        item.progress = progress > 99 ? 99 : progress
                    }
                })
                let url = ''
                if (res && res.remoteUrl) {
                    url = res.remoteUrl
                } else if (res && res.Data && res.Data.url) {
                    url = res.Data.url
                } else if (res && res.url) {
                    url = res.url
                } else if (typeof res === 'string' && res.indexOf('http') > -1) {
                    url = res
                } else if (res && res.Data && typeof res.Data === 'string') {
                    url = res.Data
                }

                if (url && (res.state === 0 || res.State === 0 || res.remoteUrl)) {
                    item.url = url
                    item.fileId = extractUploadedFileId(res)
                    item.status = 'done'
                    item.progress = 100

                    if (item.type === 'audio') {
                        try {
                            await requestUploadedAudioAsr(item)
                        } catch (err) {
                            if (!item.asrAutoRetried) {
                                item.asrAutoRetried = true
                                try {
                                    await retryUploadedAudioAsr(item, 1)
                                } catch (retryErr) {
                                    item.asrStatus = 'failed'
                                    Toast.fail('音频转写失败，请点击发送重试一次')
                                }
                            } else {
                                item.asrStatus = 'failed'
                                Toast.fail('音频转写失败，请点击发送重试一次')
                            }
                        }
                    }
                } else {
                    throw new Error('Upload failed')
                }
            } catch (error) {
                Toast.fail('上传失败')
                removeAttachment(item.id)
            }
        }
        const removeAttachment = (id) => {
            attachments.value = attachments.value.filter(a => a.id !== id)
        }
        const clearAttachments = () => {
            attachments.value = []
        }

        const handleKeydownSend = (e) => {
            if (!inputActionEnabled.value) return
            if (!msgTextTrimmed.value && attachments.value.length === 0) return
            handleSend()
        }

        const handleSend = async () => {
            if (!inputActionEnabled.value) return
            if (!msgTextTrimmed.value && attachments.value.length === 0) return
            if ([1].includes(recordStatus.value) || replyController.value || isReplying.value) {
				Toast.fail('AI正在分析中')
				return false
			}
            if (attachments.value.some(a => a.status === 'uploading')) {
                Toast('请等待附件上传完成')
                return
            }
            if (attachments.value.some(a => a.type === 'audio' && a.source === 'file' && a.asrStatus === 'retrying')) {
                Toast('请等待音频转写完成')
                return
            }

            isTextSending.value = true
            const failedAudioAttachments = attachments.value.filter(a => a.type === 'audio' && a.source === 'file' && a.asrStatus !== 'success')
            if (failedAudioAttachments.length > 0) {
                let hasRetryFailure = false
                try {
                    for (const item of failedAudioAttachments) {
                        if (item.asrSendRetried) {
                            hasRetryFailure = true
                            continue
                        }
                        item.asrSendRetried = true
                        await retryUploadedAudioAsr(item, 1)
                    }
                } catch (err) {
                    hasRetryFailure = true
                }
                if (hasRetryFailure || attachments.value.some(a => a.type === 'audio' && a.source === 'file' && a.asrStatus !== 'success')) {
                    isTextSending.value = false
                    Toast.fail('音频转写失败，请重新上传')
                    return
                }
            }
            try {
                if (messageStream.value.length === 0) {
                    await addCustSession()
                }

                let finalContent = msgText.value
                if (attachments.value.length > 0) {
                    const mdAttachments = attachments.value.map(a => {
                        if (a.type === 'image') {
                            return `\n![image](${a.url})`
                        }
                        return ''
                    }).filter(s => !!s).join('')
                    finalContent += mdAttachments
                }

                messageStream.value.push({
                    ...recordInfo,
                    role: 'user',
                    content: finalContent,
                    raw_text: msgText.value,
                    attachments: [...attachments.value],
                    created_at: new Date().toISOString(),
                })
                applyMessageTimeDividers()
                msgText.value = ''
                attachments.value = []
                msgInputFocused.value = false
                nextTick(() => {
                    resizeMsgInput()
                })
                recordIndex.value = messageStream.value.length
                scrollToBottom()
                onReply()
            } finally {
                isTextSending.value = false
            }
        }
        const addCustSession = (content = '') => {
            return AddCustSession({
                customerId: currentRecord.value.CustomerId || '',
                sessionName: (content || msgText.value || '').slice(0, 14),
            }).then((res) => {
                if (res.State === 0 && res.Data) {
                    document.title = (content || msgText.value || '').slice(0, 14) || '关系经营助手'
                    sessionId.value = res.Data.SessionId
                    currentRecord.value = res.Data
                }
            }).catch((err) => {
                console.error('AddCustSession error:', err &&(err.ErrorMessage || err.message) || '请求失败')
            })
        }
        const addRecordDetail = ({ msgContent = '', fileId = '' } = {}) => {
            const normalizedFileId = `${fileId || ''}`.trim()
            if (!normalizedFileId) return
            AddRecordDetail({
                sessionId: sessionId.value || '',
                msgContent: `${msgContent || ''}`,
                fileId: normalizedFileId,
            }).catch(() => {})
        }
        const replyController = ref(null)
        const getOptionValueText = (opt) => {
            const raw = opt && Object.prototype.hasOwnProperty.call(opt, 'value') ? opt.value : ''
            if (raw === null || raw === undefined) return ''
            if (typeof raw === 'string') return raw.trim()
            if (typeof raw === 'object') {
                try {
                    return JSON.stringify(raw)
                } catch (e) {
                    return ''
                }
            }
            return `${raw}`.trim()
        }
        const normalizeInteractionValue = (value) => {
            if (value === null || value === undefined) return ''
            if (typeof value === 'object') {
                try {
                    return JSON.stringify(value)
                } catch (e) {
                    return ''
                }
            }
            const text = `${value}`.trim()
            if (!text) return ''
            try {
                const parsed = JSON.parse(text)
                if (parsed && typeof parsed === 'object') {
                    return JSON.stringify(parsed)
                }
            } catch (e) {
                // ignore
            }
            return text
        }
        const parseIdentifyEntityValue = (valueText) => {
            const text = ((valueText || '') + '').trim()
            if (!text) return null
            try {
                const parsed = JSON.parse(text)
                if (parsed && typeof parsed === 'object') {
                    const entityId = ((parsed.entity_id || parsed.entityId || parsed.customer_id || parsed.customerId || '') + '').trim()
                    const sessionId = ((parsed.session_id || parsed.sessionId || '') + '').trim()
                    if (entityId) {
                        return {
                            entityId,
                            sessionId,
                        }
                    }
                }
            } catch (e) {
                // ignore
            }
            const matchResult = text.match(/entity_id\s*[:=]\s*["']?([0-9a-zA-Z-]+)["']?/)
            if (matchResult && matchResult[1]) {
                return {
                    entityId: matchResult[1].trim(),
                    sessionId: '',
                }
            }
            return null
        }
        /** identify_entity：按 entity_id 拉客户并合并进 options（返回新数组） */
        const mergeIdentifyEntityCustomersByGetByIds = (options) => {
            if (!Array.isArray(options)) {
                return Promise.resolve(options)
            }
            const optionEntityList = options.map((opt) => {
                const parsed = parseIdentifyEntityValue(getOptionValueText(opt))
                return {
                    option: opt,
                    parsed,
                }
            })
            const ids = [...new Set(optionEntityList.map((item) => item.parsed && item.parsed.entityId).filter(Boolean))]
            if (!ids.length) {
                return Promise.resolve(options)
            }
            return GetByIds({ customerIds: ids })
                .then((byRes) => {
                    if (byRes.State === 0 && Array.isArray(byRes.Data) && byRes.Data.length) {
                        const customerMap = new Map(byRes.Data.map((c) => [c.CustomerId, c]))
                        return options.map((o) => {
                            const parsed = parseIdentifyEntityValue(getOptionValueText(o))
                            if (!parsed || !parsed.entityId) return o
                            const customer = customerMap.get(parsed.entityId)
                            if (!customer) return o
                            return {
                                ...o,
                                ...customer,
                                SessionId: customer.SessionId || parsed.sessionId || customer.sessionId || o.SessionId || '',
                            }
                        })
                    }
                    return options
                })
                .catch((err) => {
                    console.error('GetByIds', err)
                    return options
                })
        }
        // 对话
        const normalizeStructuredType = (value) => {
            return ((value || '') + '')
                .trim()
                .toLowerCase()
                .replace(/[\s-]+/g, '_')
        }
        const parseMaybeJsonObject = (value) => {
            if (!value) return null
            if (typeof value === 'object') return value
            if (typeof value !== 'string') return null
            const text = value.trim()
            if (!text) return null
            try {
                const parsed = JSON.parse(text)
                return parsed && typeof parsed === 'object' ? parsed : null
            } catch (e) {
                return null
            }
        }
        const getCustTaskIdsFromBusinessContent = (payload) => {
            const rootObj = parseMaybeJsonObject(payload)
            if (!rootObj) return []

            const candidates = []
            const pushCandidate = (value) => {
                const nextObj = parseMaybeJsonObject(value)
                if (nextObj) {
                    candidates.push(nextObj)
                }
            }

            pushCandidate(rootObj)
            pushCandidate(rootObj.content)
            pushCandidate(rootObj.data)
            if (rootObj.content && typeof rootObj.content === 'object') {
                pushCandidate(rootObj.content.data)
            }

            for (let i = 0; i < candidates.length; i++) {
                const item = candidates[i]
                const contentType = normalizeStructuredType(item.type || item.componentType || item.component_type)
                if (contentType !== 'component_cust_tasks') {
                    continue
                }
                if (!Array.isArray(item.tasks)) {
                    continue
                }
                const ids = item.tasks
                    .map((task) => {
                        if (typeof task === 'string' || typeof task === 'number') {
                            return `${task}`.trim()
                        }
                        if (task && typeof task === 'object') {
                            return `${task.taskId || task.TaskId || task.id || task.Id || ''}`.trim()
                        }
                        return ''
                    })
                    .filter(Boolean)
                if (ids.length) {
                    return [...new Set(ids)]
                }
            }

            return []
        }
        const getBusinessPayloadFromMessage = (messageItem) => {
            if (!messageItem) return null
            if (messageItem.content) return messageItem.content
            const metadata = messageItem.metadata || {}
            if (metadata.content) return metadata.content
            if (metadata.data) return metadata.data
            if (metadata.Data) return metadata.Data
            return null
        }
        const applyCustTaskBusinessData = (messageItem, payload, source = BIZ_RENDER_SOURCE.STREAM) => {
            if (!messageItem) return false
            const taskIds = getCustTaskIdsFromBusinessContent(payload)
            if (!taskIds.length) {
                const existingTaskIds = messageItem.metadata &&
                    messageItem.metadata.cust_task_data &&
                    Array.isArray(messageItem.metadata.cust_task_data.taskIds)
                    ? messageItem.metadata.cust_task_data.taskIds.filter(Boolean)
                    : []
                if (existingTaskIds.length) {
                    messageItem.__bizRenderSource = source
                    return true
                }
                return false
            }
            existsAny()
            messageItem.showLoading = false
            messageItem.metadata = {
                ...(messageItem.metadata || {}),
                cust_task_data: {
                    taskIds,
                },
            }
            messageItem.structured_stream_raw = ''
            messageItem.content = ''
            messageItem.__bizRenderSource = source
            return true
        }
        const onReply = async (cb = null, interimContent = '') => {
            if (isReplying.value) {
                Toast.fail('AI正在分析中')
                return
            }
            const url = bjsdk.url(`//{web}/Beta.AIRelation.H5Api/LLMChat/Reply`,true)
            const curIndex = messageStream.value.length - 1
            const currentMessage = messageStream.value[curIndex] || {}
            let messageContent = currentMessage.content
            if (currentMessage.type === 'interaction' && Array.isArray(messageContent)) {
                messageContent = JSON.stringify(messageContent)
            }
            // 构建 input_parts 多模态格式
            let inputParts = []
            if (interimContent) {
                inputParts = [{
                    part_type: 'text',
                    text_content: interimContent,
                    payload: { source: 'realtime' },
                }]
            } else {
                if (currentMessage.content_type === 'audio' && currentMessage.audio_url) {
                    inputParts.push({
                        part_type: 'audio_url',
                        uri: currentMessage.audio_url,
                        text_content: currentMessage.audio_text || '',
                        payload: currentMessage.audio_payload || {},
                    })
                }

                if (currentMessage.attachments && currentMessage.attachments.length > 0) {
                    if (currentMessage.content_type !== 'audio' && currentMessage.raw_text) {
                        inputParts.push({
                            part_type: 'text',
                            text_content: buildUserTextContent(currentMessage.raw_text),
                            payload: { source: 'realtime' },
                        })
                    }
                    currentMessage.attachments.forEach(a => {
                        if (a.type === 'image') {
                            inputParts.push({
                                part_type: 'image_url',
                                uri: a.url,
                                payload: buildPayloadMeta({
                                    fileName: a.fileName,
                                    format: a.format,
                                    size: a.size,
                                    source: 'file',
                                }),
                            })
                        } else if (a.type === 'audio') {
                            inputParts.push({
                                part_type: 'audio_url',
                                uri: a.url,
                                text_content: a.textContent,
                                payload: buildPayloadMeta({
                                    fileName: a.fileName,
                                    format: 'mp3',
                                    size: a.size,
                                    source: 'file',
                                    extra: a.payload || {},
                                }),
                            })
                        } else if (a.type === 'file') {
                            inputParts.push({
                                part_type: 'file_url',
                                uri: a.url,
                                payload: buildPayloadMeta({
                                    fileName: a.fileName,
                                    format: a.format || getAttachmentFormat(a),
                                    size: a.size,
                                    source: 'file',
                                }),
                            })
                        }
                    })
                }

                if (inputParts.length === 0) {
                    inputParts.push({
                        part_type: 'text',
                        text_content: messageContent || '',
                        payload: { source: 'realtime' },
                    })
                }
            }
			const params = {
				sessionId: sessionId.value,
				customerId: currentRecord.value.CustomerId || '',
                inputParts: inputParts,
			}
            clearStreamHeartbeatTimer()
            streamAutoFollowBottom.value = true
            messageStream.value.push({
                ...recordInfo,
                role: 'assistant',
                showLoading: true,
                streaming: true,
                showHeartbeat: false,
                content: '',
                created_at: new Date().toISOString(),
            })
            startAssistantThinkingTimer()
            applyMessageTimeDividers()
            scrollToBottom()
            const addLength = messageStream.value.length
            const assistantIndex = messageStream.value.length - 1
            recordIndex.value = assistantIndex
            markStreamHeartbeatActive(assistantIndex)
            canRecord.value = true
            isReplying.value = true
            let localReplyController = null
            const getAssistantStreamItem = () => {
                const item = messageStream.value[assistantIndex]
                if (!item || item.role !== 'assistant') return null
                return item
            }
            try {
                await fetchHttp({ url, params}, async (res,controller)=>{
				localReplyController = controller
                replyController.value = controller
				// messageStream.value[recordIndex.value]['ShowRefresh'] = false
				if (bjsdk.isObj(res)) {
					// 流式数据最后一段发送
                    console.warn('流式结束')
                    stopStreamHeartbeat(assistantIndex)
                    if (replyController.value === localReplyController) {
					    replyController.value = null
                    }
                    isReplying.value = false
					Toast.clear()
				} else {
					if (Array.isArray(res)) {
						for (let i = 0; i < res.length; i++) {
							const part = res[i];
							const cleanedPart = part.replace(/^data:\s*/, '').trim();
							if (cleanedPart) {
								try {
									const response = JSON.parse(cleanedPart);
                                    console.warn('response', response)
									const { type = '', content = '', message = '' } = response
                                    const normalizedType = normalizeStructuredType(type)
                                    const streamTypeItem = getAssistantStreamItem()
                                    if (streamTypeItem) {
                                        streamTypeItem.type = type
                                    }
                                    switch (normalizedType) {
                                        // 上一条语音的信息
                                        case 'start':
                                            if (cb && typeof cb === 'function') {
                                                cb()
                                            }
                                            break;
                                        case 'text_chunk': {
                                            const streamItem = getAssistantStreamItem()
                                            if (!streamItem) break
                                            streamItem.showLoading = false
                                            streamItem.streaming = true
                                            streamItem.showHeartbeat = false
                                            clearAssistantThinkingTimer()
                                            streamItem.structured_stream_raw = (streamItem.structured_stream_raw || '') + (content || '')
                                            streamItem.content = getStreamingVisibleForStructuredData(streamItem.structured_stream_raw)
                                            markStreamHeartbeatActive(assistantIndex)
                                            scheduleStreamScrollToBottom()
                                            break
                                        }
                                        case 'complete': {
                                            stopStreamHeartbeat(assistantIndex)
                                            const streamItem = getAssistantStreamItem()
                                            if (!streamItem) break
                                            const fullReplyContent = (content || '') + ''
                                            clearAssistantThinkingTimer()
                                            streamItem.showLoading = false
                                            streamItem.content = stripStructuredDataFromText(fullReplyContent)
                                            streamItem.structured_stream_raw = ''
                                            scrollToBottomIfStreamFollowing()
                                            await maybeShowIdentityPromptAfterReply(fullReplyContent)
                                            break
                                        }
                                        case 'interaction': {
                                            stopStreamHeartbeat(assistantIndex)
                                            // 选择客户
                                            if (content?.event === 'identify_entity' && Array.isArray(content.options)) {
                                                content.options = await mergeIdentifyEntityCustomersByGetByIds(content.options)
                                            }
                                            console.log('content', content)
                                            const streamItem = getAssistantStreamItem()
                                            if (!streamItem) break
                                            clearAssistantThinkingTimer()
                                            streamItem.showLoading = false
                                            streamItem.metadata = {
                                                interaction_data: content
                                            }
                                            streamItem.structured_stream_raw = ''
                                            streamItem.content = ''
                                            streamItem.selected_option_values = []
                                            streamItem.selected_option_value = ''
                                            streamItem.interaction_submitted = false
                                            streamItem.select_locked = false
                                            streamItem.select_submit_locked = false
                                            streamItem.text_input_locked = false
                                            streamItem.text_input_value = ''
                                            canRecord.value = true
                                            break
                                        }
                                        case 'business_data': {
                                            stopStreamHeartbeat(assistantIndex)
                                            const messageItem = getAssistantStreamItem()
                                            if (!messageItem) break
                                            const matchedCustTask = applyCustTaskBusinessData(messageItem, content, BIZ_RENDER_SOURCE.STREAM)
                                            if (!matchedCustTask) {
                                                clearAssistantThinkingTimer()
                                                messageItem.showLoading = false
                                                messageItem.structured_stream_raw = ''
                                                messageItem.content = typeof content === 'string' ? content : ''
                                            }
                                            scrollToBottomIfStreamFollowing()
                                            break
                                        }
                                        case 'forking':
                                            stopStreamHeartbeat(assistantIndex)
                                            clearAssistantThinkingTimer()
                                            Toast.loading({
                                                duration: 0,
                                                forbidClick: true,
                                                message: '创建中...',
                                            })
                                            if (addLength === messageStream.value.length) {
                                                messageStream.value.pop()
                                                recordIndex.value = messageStream.value.length - 1
                                            }
                                            const sessionRes = await GetById({
                                                sessionId: content.new_thread_id,
                                                customerId: content.subject_id || '',
                                            })
                                            Toast.clear()
                                            if (sessionRes.State === 0 && sessionRes.Data) {
                                                onSelectDialog(sessionRes.Data, true)
                                            } else {
                                                if (replyController.value) {
                                                    replyController.value.abort()
                                                    replyController.value = null
                                                }
                                                isReplying.value = false
                                            }
                                            break;
                                        case 'error':
                                            stopStreamHeartbeat(assistantIndex)
                                            clearAssistantThinkingTimer()
                                            // 删除最后一条客户回复
                                            // if (addLength === messageStream.value.length) {
                                            //     messageStream.value.pop()
                                            //     recordIndex.value = messageStream.value.length - 1
                                            // }
                                            {
                                                const streamItem = getAssistantStreamItem()
                                                if (streamItem) {
                                                    streamItem.showLoading = false
                                                    streamItem.structured_stream_raw = ''
                                                    streamItem.content = `刚刚出了点小问题，请稍后再试，或换种说法继续。${bjsdk.isDev ? '<br />' + message : ''}`
                                                }
                                            }
                                            Toast.clear()
                                            // Toast.fail(message)
                                            break;
                                        case 'empty':
                                            stopStreamHeartbeat(assistantIndex)
                                            clearAssistantThinkingTimer()
                                            // 删除最后一条客户回复
                                            if (addLength === messageStream.value.length) {
                                                messageStream.value.pop()
                                                recordIndex.value = messageStream.value.length - 1
                                            }
                                            Toast.clear()
                                            break;
                                    }
								} catch (error) {
                                    stopStreamHeartbeat(assistantIndex)
                                    clearAssistantThinkingTimer()
									// 删除最后一条客户回复
									if (addLength === messageStream.value.length) {
										messageStream.value.pop()
										recordIndex.value = messageStream.value.length - 1
									}
									// messageStream.value[lastMessageIndex]['showLoading'] = false
									Toast.clear()
									console.error(error)
									break;
								}
							}
						}
					}
				}
			    })
            } catch (error) {
                stopStreamHeartbeat(assistantIndex)
                if (replyController.value === localReplyController) {
                    replyController.value = null
                }
                isReplying.value = false
                Toast.clear()
                console.error(error)
            }
        }
        const onSelectOption = (item, option, event = '') => {
            if (isInteractionItemDisabled(item)) return
            if (!item || !option || item.select_locked) return
            const optionValue = getOptionValueText(option)
            if (!optionValue) return

            const interactionData = item.metadata && item.metadata.interaction_data ? item.metadata.interaction_data : {}
            const isMultiple = interactionData.allow_multiple === true
            const selectedOptionValues = Array.isArray(item.selected_option_values) ? [...item.selected_option_values] : []

            if (isMultiple) {
                const valueIndex = selectedOptionValues.indexOf(optionValue)
                if (valueIndex > -1) {
                    selectedOptionValues.splice(valueIndex, 1)
                } else {
                    selectedOptionValues.push(optionValue)
                }
                item.selected_option_values = selectedOptionValues
                item.selected_option_value = selectedOptionValues[0] || ''
                item.text_input_value = ''
                return
            }

            item.select_locked = true
            item.selected_option_values = [optionValue]
            item.selected_option_value = optionValue
            item.text_input_value = ''
            
            submitInteraction(item, [optionValue], event, option)
        }
        const onSubmitSelectOption = (item) => {
            if (isInteractionItemDisabled(item)) return
            if (!item || item.select_submit_locked) return
            const selectedOptionValues = Array.isArray(item.selected_option_values) ? item.selected_option_values : []
            const submitValues = selectedOptionValues.map((v) => ((v || '') + '').trim()).filter(Boolean)
            if (!submitValues.length) return

            item.text_input_value = ''
            submitInteraction(item, submitValues)
        }
        const onSubmitTextInput = (item) => {
            if (isInteractionItemDisabled(item)) return
            if (!item || item.text_input_locked) return
            const inputValue = ((item.text_input_value || '') + '').trim()
            if (!inputValue) return

            submitInteraction(item, inputValue)
        }
        const submitInteraction = async (item, submitContent, event = '', option = null) => {
            if (!item || item.interaction_submitted === true) return
            const isArrayContent = Array.isArray(submitContent)
            const submitSummary = isArrayContent
                ? submitContent.map((v) => normalizeInteractionValue(v)).filter(Boolean).join(' / ')
                : ((submitContent || '') + '').trim()
            if (!submitSummary) return

            item.select_locked = true
            item.select_submit_locked = true
            item.text_input_locked = true

            const sendInteraction = () => {
                item.content = isArrayContent ? JSON.stringify(submitContent) : submitSummary
                item.interaction_submitted = true
                item.text_input_value = ''
                scrollToBottom()
                // if (event === 'identify_entity' && isArrayContent) {
                //     // if (submitContent.includes('create_new')) {
                //     //     onCreateCustomer(submitContent.join(''))
                //     // } else 
                //     if (submitContent.find(s => s.includes('entity_id'))) {
                //         onReply(() => {
                //             if (replyController.value) {
                //                 replyController.value.abort()
                //                 replyController.value = null
                //             }
                //             if (option && option.SessionId) {
                //                 onSelectDialog(option)
                //             } else {
                //                 onCreateSession()
                //                 currentRecord.value = {
                //                     CustomerId: option.CustomerId,
                //                 }
                //             }
                //         })
                //     } else {
                //         onReply()
                //     }
                // } else {
                // }
                onReply()
            }

            if (!sessionId.value) {
                addCustSession(submitSummary).then(() => {
                    sendInteraction()
                }).catch(() => {
                    item.select_locked = false
                    item.select_submit_locked = false
                    item.text_input_locked = false
                })
                return
            }

            sendInteraction()
        }
        const onInteractionTextInput = (e) => {
            const el = e && e.target
            if (!el) return
            const lineHeight = 22
            const verticalPadding = 16
            const minHeight = lineHeight + verticalPadding
            const maxHeight = lineHeight * 5 + verticalPadding
            el.style.height = 'auto'
            const nextHeight = Math.min(Math.max(el.scrollHeight, minHeight), maxHeight)
            el.style.height = nextHeight + 'px'
        }
        const parseInteractionContent = (content) => {
            if (Array.isArray(content)) return content
            if (typeof content !== 'string') return content
            const text = content.trim()
            if (!text) return ''
            try {
                const parsed = JSON.parse(text)
                return parsed
            } catch (e) {
                return content
            }
        }
        const hasInteractionContent = (item) => {
            if (!item) return false
            const normalized = parseInteractionContent(item.content)
            if (Array.isArray(normalized)) return normalized.length > 0
            if (typeof normalized === 'string') return normalized.trim() !== ''
            if (normalized && typeof normalized === 'object') return true
            return false
        }
        const isInteractionLastItem = (item) => {
            if (!item || !Array.isArray(messageStream.value) || !messageStream.value.length) return false
            return messageStream.value[messageStream.value.length - 1] === item
        }
        const isInteractionItemDisabled = (item) => {
            if (!item) return true
            if (hasInteractionContent(item)) return true
            return !isInteractionLastItem(item)
        }
        const getInteractionContentValues = (item) => {
            if (!item) return []
            const normalized = parseInteractionContent(item.content)
            if (Array.isArray(normalized)) {
                return normalized.map((v) => normalizeInteractionValue(v)).filter(Boolean)
            }
            if (typeof normalized === 'string' && normalized.trim()) {
                return [normalizeInteractionValue(normalized)]
            }
            if (normalized && typeof normalized === 'object') {
                const normalizedValue = normalizeInteractionValue(normalized)
                return normalizedValue ? [normalizedValue] : []
            }
            return []
        }
        const hasInteractionOptionMatch = (item) => {
            const interactionData = item && item.metadata ? item.metadata.interaction_data : null
            const optionList = interactionData && Array.isArray(interactionData.options) ? interactionData.options : []
            const contentValues = getInteractionContentValues(item)
            if (!optionList.length || !contentValues.length) return false
            const optionValueSet = new Set(
                optionList.map((opt) => normalizeInteractionValue(getOptionValueText(opt))).filter(Boolean)
            )
            return contentValues.some((v) => optionValueSet.has(v))
        }
        const isInteractionOptionSelected = (item, opt) => {
            const optionValue = normalizeInteractionValue(getOptionValueText(opt))
            if (!optionValue) return false
            if (hasInteractionContent(item)) {
                return getInteractionContentValues(item).includes(optionValue)
            }
            const selectedValues = Array.isArray(item && item.selected_option_values) ? item.selected_option_values : []
            return selectedValues.includes(optionValue)
        }
        const hasRenderableAttachments = (item) => {
            return !!(item && Array.isArray(item.attachments) && item.attachments.length > 0)
        }
        const hasVisibleMessageBody = (item) => {
            if (!item || item.metadata?.interaction_data) return false
            if (isPlayableAudioMessage(item)) return true
            if (hasRenderableAttachments(item)) return true
            const content = item.content
            if (typeof content !== 'string' || !content.trim()) return false
            if (item && item.content_type === 'audio' && item.audio_url) {
                return /!\[.*?\]\(.*?\)|\[.*?\]\(.*?\)/.test(content)
            }
            return true
        }
        const shouldShowMessageContent = (item) => {
            if (!item || item.metadata?.interaction_data) return false
            const content = item.content
            if (typeof content !== 'string' || !content.trim()) return false

            if (item && item.content_type === 'audio' && item.audio_url) {
                return /!\[.*?\]\(.*?\)|\[.*?\]\(.*?\)/.test(content)
            }
            return true
        }
        // ---- 多模态/语音条 helpers ----
        const getAudioSource = (item) => {
            return `${(item && item.audio_payload && item.audio_payload.source) || ''}`.trim()
        }
        const getAttachmentAudioSource = (item) => {
            return `${(item && (item.source || (item.payload && item.payload.source))) || ''}`.trim()
        }
        const isPlayableAudioMessage = (item) => {
            return !!(item && item.content_type === 'audio' && item.audio_url)
        }
        const getAudioUri = (item) => (item && item.audio_url) || ''
        const getAudioText = (item) => stripProtocolPrefix((item && item.audio_text) || '')
        const getAttachmentAudioText = (item) => stripProtocolPrefix((item && item.textContent) || '')
        const getAudioDuration = (item) => {
            if (item && item.audio_payload && item.audio_payload.duration_ms) return item.audio_payload.duration_ms
            return 0
        }
        const getAttachmentAudioDuration = (item) => {
            if (item && item.payload && item.payload.duration_ms) return item.payload.duration_ms
            return 0
        }
        const getAudioMimeType = (item) => {
            const format = item && item.audio_payload && item.audio_payload.format
            return format ? `audio/${String(format).toLowerCase()}` : ''
        }
        const getAttachmentAudioMimeType = (item) => {
            const format = (item && item.format) || (item && item.payload && item.payload.format)
            return format ? `audio/${String(format).toLowerCase()}` : ''
        }
        const getAudioPayload = (item) => (item && item.audio_payload) || {}
        const getAttachmentAudioPayload = (item) => (item && item.payload) || buildPayloadMeta({
            fileName: item && item.fileName,
            format: item && item.format,
            size: item && item.size,
            source: getAttachmentAudioSource(item),
        })
        const getAudioVariant = (item) => getAudioSource(item) === 'file' ? 'attachment' : 'voice'
        const getAttachmentAudioVariant = (item) => getAttachmentAudioSource(item) === 'file' ? 'attachment' : 'voice'
        const getAudioLabel = (item) => getAudioSource(item) === 'file' ? '附件' : ''
        const getAttachmentAudioLabel = (item) => getAttachmentAudioSource(item) === 'file' ? '附件' : ''
        const shouldShowAudioTextToggle = (item) => !!(item && getAudioText(item))
        const shouldShowAttachmentAudioTextToggle = (item) => !!(item && getAttachmentAudioText(item))
        // ---- end 多模态 helpers ----
        const shouldShowInteractionReply = (item) => {
            if (!hasInteractionContent(item)) return false
            return !hasInteractionOptionMatch(item)
        }
        const getInteractionReplyText = (item) => {
            const values = getInteractionContentValues(item)
            return values.join('、')
        }
        const getInteractionQuestion = (item) => {
            if (!item || !item.metadata || !item.metadata.interaction_data) return ''
            return ((item.metadata.interaction_data.question || '') + '').trim()
        }
        const shouldShowAllCustomerEntry = (item) => {
            if (!item || !item.metadata || !item.metadata.interaction_data) return false
            const interactionData = item.metadata.interaction_data
            if (interactionData.event !== 'identify_entity') return false
            const options = Array.isArray(interactionData.options) ? interactionData.options : []
            if (!options.length) return false
            const hasCustomerOption = options.some((opt) => !!(opt && opt.CustomerId))
            if (hasCustomerOption) return true
            const optionValues = options.map((opt) => getOptionValueText(opt))
            return optionValues.includes('create_new') && optionValues.includes('no_create')
        }
        const shouldShowInteractionSubmit = (item) => {
            if (!item || hasInteractionContent(item)) return false
            const interactionData = item.metadata && item.metadata.interaction_data ? item.metadata.interaction_data : {}
            const allowMultiple = interactionData.allow_multiple === true
            const allowCustom = interactionData.allow_custom === true
            return allowMultiple || (!isPc.value && allowCustom)
        }
        const onSubmitInteraction = (item) => {
            if (!item) return
            const interactionData = item.metadata && item.metadata.interaction_data ? item.metadata.interaction_data : {}
            const allowCustom = interactionData.allow_custom === true
            const inputValue = ((item.text_input_value || '') + '').trim()
            if (allowCustom && inputValue) {
                onSubmitTextInput(item)
                return
            }
            if (interactionData.allow_multiple === true) {
                onSubmitSelectOption(item)
            }
        }
        // 关闭示例
        const onCloseExample = () => {
            bannerExpanded.value = false
            showExample.value = false
        }
        const onExampleShadowClick = () => {
            bannerExpanded.value = false
        }
        const showMenu = ref(false)
        const showCustomerPicker = ref(false)
        const customerPickerInteractionItem = ref(null)

        const openCustomerPicker = (item) => {
            if (!item || isInteractionItemDisabled(item)) return
            customerPickerInteractionItem.value = item
            showCustomerPicker.value = true
        }

        const closeCustomerPicker = () => {
            showCustomerPicker.value = false
            customerPickerInteractionItem.value = null
        }

        const onCustomerPickerConfirm = (selectedCustomer) => {
            if (!selectedCustomer || !selectedCustomer.CustomerId) return
            showCustomerPicker.value = false
            const item={entity_id:selectedCustomer.CustomerId,session_id:selectedCustomer.SessionId}
            const msg_content=JSON.stringify([JSON.stringify(item)])
            onReply(null,msg_content)
        }
        // 展示菜单
        const changeMenuState = () => {
            showMenu.value = !showMenu.value
        }

        const closeMenu = () => {
            showMenu.value = false
        }
        // isCCustomer: 是否是新建客户
        const onSelectDialog = (item, isCCustomer = false) => {
            if (!item || !item.SessionId) return
            stopStreamHeartbeat()
            if (replyController.value) {
                replyController.value.abort()
                replyController.value = null
            }
            isReplying.value = false
            document.title = item.SessionName || '关系经营助手'
            const prevSessionId = sessionId.value
            sessionId.value = item.SessionId
            currentRecord.value = item
            bannerExpanded.value = false
            showExample.value = !!isCCustomer
            if (prevSessionId !== item.SessionId || isCCustomer) {
                taskCardAnchorIndex.value = -1
                shouldShowCustTaskCard.value = false
                taskCardLoadedOnce.value = false
                showIdentityPromptCard.value = false
                hasUserScrolledContent.value = false
                streamAutoFollowBottom.value = true
                historyCursor.value = ''
                historyHasMore.value = true
                historyLoading.value = false
                resetHistoryPullState()
                messageStream.value = []
                msgText.value = ''
                nextTick(() => {
                    resizeMsgInput()
                })
                fetchHistoryBySessionId(item.SessionId, item.CustomerId || '', isCCustomer, item.SessionName)
                existsAny()
            }
        }

        const onCreateSession = () => {
            stopStreamHeartbeat()
            if (replyController.value) {
                replyController.value.abort()
                replyController.value = null
            }
            isReplying.value = false
            sessionId.value = ''
            msgText.value = ''
            messageStream.value = []
            taskCardAnchorIndex.value = -1
            shouldShowCustTaskCard.value = false
            taskCardLoadedOnce.value = false
            showIdentityPromptCard.value = false
            hasUserScrolledContent.value = false
            streamAutoFollowBottom.value = true
            historyCursor.value = ''
            historyHasMore.value = true
            historyLoading.value = false
            resetHistoryPullState()
            recordIndex.value = 0
            isCreateCustomer = false
            currentRecord.value = {
                CustomerId: '',
            }
            document.title = '关系经营助手'
            canRecord.value = true
            bannerExpanded.value = false
            showExample.value = false
            nextTick(() => {
                resizeMsgInput()
                const contentAreaDom = document.querySelector('#contentArea')
                if (contentAreaDom) {
                    contentAreaDom.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    })
                }
            })
        }

        const getHistoryMessageId = (msg) => {
            if (!msg || typeof msg !== 'object') return ''
            const raw = msg.id ?? msg.Id ?? msg.messageId ?? msg.MessageId ?? ''
            return `${raw || ''}`.trim()
        }
        const getMessageRenderKey = (msg, index = 0) => {
            const msgId = getHistoryMessageId(msg)
            if (msgId) {
                return `${sessionId.value || 'session'}_reply_${msgId}`
            }
            return `${sessionId.value || 'session'}_reply_idx_${index}`
        }
        const TIME_DIVIDER_GAP_MS = 15 * 60 * 1000
        const padDateNum = (value) => `${value}`.padStart(2, '0')
        const isSameDate = (a, b) => {
            if (!(a instanceof Date) || !(b instanceof Date)) return false
            return a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth() && a.getDate() === b.getDate()
        }
        const parseMessageTimeMs = (value) => {
            if (value === null || value === undefined) return NaN
            if (value instanceof Date) {
                const ms = value.getTime()
                return Number.isFinite(ms) ? ms : NaN
            }
            if (typeof value === 'number') {
                if (!Number.isFinite(value)) return NaN
                return value > 1e12 ? value : value * 1000
            }
            const text = `${value || ''}`.trim()
            if (!text) return NaN

            if (/^\d+$/.test(text)) {
                const num = Number(text)
                if (!Number.isFinite(num)) return NaN
                return num > 1e12 ? num : num * 1000
            }

            const directMs = new Date(text).getTime()
            if (Number.isFinite(directMs)) return directMs

            const isoLike = text.replace(' ', 'T').replace(/\.(\d{3})\d+/, '.$1')
            const isoMs = new Date(isoLike).getTime()
            if (Number.isFinite(isoMs)) return isoMs

            const normalized = text.replace(/\//g, '-')
            const match = normalized.match(/^(\d{4})-(\d{1,2})-(\d{1,2})(?:[ T](\d{1,2})(?::(\d{1,2})(?::(\d{1,2}))?)?)?$/)
            if (!match) return NaN
            const year = Number(match[1])
            const month = Number(match[2]) - 1
            const day = Number(match[3])
            const hour = Number(match[4] || 0)
            const minute = Number(match[5] || 0)
            const second = Number(match[6] || 0)
            const ms = new Date(year, month, day, hour, minute, second).getTime()
            return Number.isFinite(ms) ? ms : NaN
        }
        const getMessageTimeMs = (msg) => {
            if (!msg || typeof msg !== 'object') return NaN
            const createdAtRaw = `${msg.created_at || ''}`.trim()
            if (!createdAtRaw) return NaN
            const localTimeText = utcToLocal(createdAtRaw)
            const ms = parseMessageTimeMs(localTimeText)
            return Number.isFinite(ms) ? ms : NaN
        }
        const formatTimeDividerText = (ms) => {
            if (!Number.isFinite(ms)) return ''
            const date = new Date(ms)
            const now = new Date()
            const hhmm = `${padDateNum(date.getHours())}:${padDateNum(date.getMinutes())}`
            if (isSameDate(date, now)) {
                return hhmm
            }
            const yesterday = new Date(now.getFullYear(), now.getMonth(), now.getDate() - 1)
            if (isSameDate(date, yesterday)) {
                return `昨天 ${hhmm}`
            }
            const md = `${padDateNum(date.getMonth() + 1)}-${padDateNum(date.getDate())}`
            if (date.getFullYear() === now.getFullYear()) {
                return `${md} ${hhmm}`
            }
            return `${date.getFullYear()}-${md} ${hhmm}`
        }
        const applyMessageTimeDividers = (messages = messageStream.value) => {
            if (!Array.isArray(messages)) return
            let prevMs = NaN
            for (let i = 0; i < messages.length; i++) {
                const item = messages[i]
                if (!item || typeof item !== 'object') continue
                const currentMs = getMessageTimeMs(item)
                let showDivider = false
                if (Number.isFinite(currentMs)) {
                    if (i === 0) {
                        showDivider = true
                    } else if (!Number.isFinite(prevMs)) {
                        showDivider = true
                    } else {
                        const crossDay = !isSameDate(new Date(currentMs), new Date(prevMs))
                        const timeGap = Math.abs(currentMs - prevMs)
                        showDivider = crossDay || timeGap >= TIME_DIVIDER_GAP_MS
                    }
                }
                item.showTimeDivider = showDivider
                item.timeDividerText = showDivider ? formatTimeDividerText(currentMs) : ''
                if (Number.isFinite(currentMs)) {
                    prevMs = currentMs
                }
            }
        }
        const normalizeGetMessagesData = (res) => {
            const state = res && (res.State !== undefined ? res.State : res.state)
            const data = res && (res.Data || res.data || {})
            const messages = Array.isArray(data.messages) ? data.messages : (Array.isArray(data.Messages) ? data.Messages : [])
            const interaction = data.interaction || data.Interaction || null
            return { state, data, messages, interaction }
        }
        const normalizeAndEnhanceHistoryMessages = async (messages = [], mode = 'replace') => {
            const normalized = Array.isArray(messages) ? [...messages] : []
            const source = mode === 'prepend' ? BIZ_RENDER_SOURCE.HISTORY_PREPEND : BIZ_RENDER_SOURCE.INIT
            for (let msgIdx = 0; msgIdx < normalized.length; msgIdx++) {
                const msgItem = normalized[msgIdx]
                if (Array.isArray(msgItem.parts) && msgItem.parts.length) {
                    let reconstructedContent = ''
                    const existingAttachments = Array.isArray(msgItem.attachments) ? [...msgItem.attachments] : []
                    const mappedFileAttachments = []
                    msgItem.parts.forEach((part) => {
                        const pType = part.partType || part.part_type
                        if (pType === 'text') {
                            const text = stripProtocolPrefix(part.textContent || part.text_content || '')
                            if (text) reconstructedContent += (reconstructedContent ? '\n' : '') + text
                        } else if (pType === 'image_url') {
                            const uri = part.uri || ''
                            if (uri) {
                                reconstructedContent += (reconstructedContent ? '\n' : '') + `![image](${uri})`
                            }
                        } else if (pType === 'audio_url') {
                        } else if (pType === 'file_url') {
                            const uri = part.uri || ''
                            if (!uri) return
                            const payload = part.payload || {}
                            const fileName = payload.filename || stripProtocolPrefix(part.textContent || part.text_content || '') || '文件'
                            const format = payload.format || getAttachmentFormat({ fileName })
                            const size = Number(payload.size) || 0
                            mappedFileAttachments.push({
                                id: `${msgItem.id || msgItem.message_id || msgIdx}-file-${mappedFileAttachments.length + 1}`,
                                type: 'file',
                                url: uri,
                                fileName,
                                format,
                                size,
                                formattedSize: formatSize(size),
                                source: payload.source || 'file',
                                payload: buildPayloadMeta({
                                    fileName,
                                    format,
                                    size,
                                    source: payload.source || 'file',
                                    extra: payload,
                                }),
                                status: 'done',
                            })
                        } else {
                            const uri = part.uri || ''
                            const text = stripProtocolPrefix(part.textContent || part.text_content || '文件')
                            if (uri) {
                                reconstructedContent += (reconstructedContent ? '\n' : '') + `[${text || '文件'}](${uri})`
                            }
                        }
                    })

                    if (reconstructedContent.trim()) {
                        msgItem.content = reconstructedContent.trim()
                    }
                    if (mappedFileAttachments.length > 0) {
                        msgItem.attachments = [...existingAttachments, ...mappedFileAttachments]
                    }

                    const audioParts = msgItem.parts.filter((p) => (p.partType || p.part_type) === 'audio_url' && (p.uri || ''))
                    if (audioParts.length > 0) {
                        const [primaryAudioPart, ...remainingAudioParts] = audioParts
                        msgItem.content_type = 'audio'
                        msgItem.audio_url = primaryAudioPart.uri || ''
                        msgItem.audio_text = primaryAudioPart.textContent || primaryAudioPart.text_content || ''
                        msgItem.audio_payload = primaryAudioPart.payload || {}

                        if (remainingAudioParts.length > 0) {
                            const existingAudioAttachments = Array.isArray(msgItem.attachments) ? msgItem.attachments : []
                            const mappedAudioAttachments = remainingAudioParts.map((part, audioIdx) => {
                                const partPayload = part.payload || {}
                                const payload = buildPayloadMeta({
                                    fileName: partPayload.filename || '',
                                    format: partPayload.format || 'mp3',
                                    size: partPayload.size || 0,
                                    source: partPayload.source || 'file',
                                    extra: partPayload,
                                })
                                return {
                                    id: `${msgItem.id || msgItem.message_id || msgIdx}-audio-${audioIdx + 1}`,
                                    type: 'audio',
                                    url: part.uri || '',
                                    fileName: partPayload.filename || '附件',
                                    format: partPayload.format || 'mp3',
                                    size: partPayload.size || 0,
                                    source: partPayload.source || 'file',
                                    textContent: part.textContent || part.text_content || '',
                                    payload,
                                    status: 'done',
                                    asrStatus: 'success',
                                }
                            })
                            msgItem.attachments = [...existingAudioAttachments, ...mappedAudioAttachments]
                        }
                    }
                }
                applyCustTaskBusinessData(msgItem, getBusinessPayloadFromMessage(msgItem), source)
                if (!msgItem || !msgItem.metadata || !msgItem.metadata.interaction_data) {
                    continue
                }
                const inter = msgItem.metadata.interaction_data
                if (inter.event !== 'identify_entity' || !Array.isArray(inter.options)) {
                    continue
                }
                inter.options = await mergeIdentifyEntityCustomersByGetByIds(inter.options)
            }
            return normalized
        }
        const mergeHistoryMessages = (incoming = [], current = []) => {
            const merged = []
            const seenIds = new Set()
            const source = [...incoming, ...current]
            for (let i = 0; i < source.length; i++) {
                const item = source[i]
                const msgId = getHistoryMessageId(item)
                if (msgId) {
                    if (seenIds.has(msgId)) continue
                    seenIds.add(msgId)
                }
                merged.push(item)
            }
            return merged
        }
        const loadHistoryPageByCursor = async ({ sid = '', cId = '', cursor = '', mode = 'replace', applyInteraction = false } = {}) => {
            if (!sid) return { loadedCount: 0, interaction: null }
            if (historyLoading.value) return { loadedCount: 0, interaction: null }
            historyLoading.value = true
            try {
                const res = await GetMessages({
                    SessionId: sid,
                    CustomerId: cId,
                    Cursor: cursor || '',
                    PageSize: HISTORY_PAGE_SIZE,
                })
                const { state, messages, interaction } = normalizeGetMessagesData(res)
                if (!(state === 0)) {
                    return { loadedCount: 0, interaction: null }
                }

                const pageMessages = await normalizeAndEnhanceHistoryMessages(messages, mode)
                if (mode === 'replace') {
                    messageStream.value = pageMessages
                } else {
                    messageStream.value = mergeHistoryMessages(pageMessages, messageStream.value)
                }
                applyMessageTimeDividers()

                const nextCursorId = pageMessages.length ? getHistoryMessageId(pageMessages[0]) : ''
                if (!pageMessages.length || !nextCursorId || nextCursorId === (cursor || '')) {
                    historyHasMore.value = false
                } else {
                    historyCursor.value = nextCursorId
                    historyHasMore.value = pageMessages.length >= HISTORY_PAGE_SIZE
                }

                if (applyInteraction) {
                    if (interaction) {
                        canRecord.value = true
                        const newInterAction = JSON.parse(JSON.stringify(interaction))
                        if (newInterAction?.event === 'identify_entity' && Array.isArray(newInterAction.options)) {
                            newInterAction.options = await mergeIdentifyEntityCustomersByGetByIds(newInterAction.options)
                        }
                        messageStream.value.push({
                            ...recordInfo,
                            role: 'assistant',
                            showLoading: false,
                            metadata: {
                                interaction_data: newInterAction,
                            },
                            selected_option_values: [],
                            selected_option_value: '',
                            interaction_submitted: false,
                            select_locked: false,
                            select_submit_locked: false,
                            text_input_locked: false,
                            text_input_value: '',
                        })
                        applyMessageTimeDividers()
                    } else {
                        canRecord.value = true
                    }
                }

                return {
                    loadedCount: pageMessages.length,
                    interaction,
                }
            } finally {
                historyLoading.value = false
            }
        }
        const loadMoreHistoryByCursor = async () => {
            if (!sessionId.value || historyLoading.value || !historyHasMore.value) return
            suppressAutoScrollDuringHistoryPrepend.value = true
            const el = getScrollTargetDom('#contentArea')
            const beforeTop = el ? el.scrollTop : 0
            const beforeHeight = el ? el.scrollHeight : 0
            const cursor = historyCursor.value || ''
            try {
                const result = await loadHistoryPageByCursor({
                    sid: sessionId.value,
                    cId: currentRecord.value.CustomerId || '',
                    cursor,
                    mode: 'prepend',
                    applyInteraction: false,
                })
                if (result.loadedCount > 0 && el) {
                    nextTick(() => {
                        const afterHeight = el.scrollHeight
                        const delta = afterHeight - beforeHeight
                        el.scrollTop = beforeTop + Math.max(delta, 0)
                        updateScrollBottomBtnVisibility(el)
                    })
                }
            } catch (err) {
                console.error('LoadMore GetMessages error:', err && (err.ErrorMessage || err.message) || '请求失败')
            } finally {
                nextTick(() => {
                    requestAnimationFrame(() => {
                        suppressAutoScrollDuringHistoryPrepend.value = false
                    })
                })
            }
        }
        const fetchHistoryBySessionId = async (id, cId = '', isCCustomer = false, sessionName = '') => {
            stopStreamHeartbeat()
            if (!id) {
                Toast.clear()
                return
            }
            historyCursor.value = ''
            historyHasMore.value = true
            historyLoading.value = false
            resetHistoryPullState()
            try {
                await loadHistoryPageByCursor({
                    sid: id,
                    cId,
                    cursor: '',
                    mode: 'replace',
                    applyInteraction: true,
                })
                currentRecord.value = {
                    CustomerId: cId,
                }
                scrollToBottom()
                if (isCCustomer) {
                    if (!sessionName) {
                        UpdateSessionName({
                            sessionId: id,
                            sessionName: (messageStream.value[0] && messageStream.value[0].content || '').slice(0, 14),
                        })
                    }
                    onReply(null, '/retry')
                }
            } catch (err) {
                console.error('GetById error:', err && (err.ErrorMessage || err.message) || '请求失败')
            } finally {
                if (!taskCardHistoryReady.value) {
                    taskCardHistoryReady.value = true
                }
                tryInitCustTaskCardOnPageRender()
                Toast.clear()
            }
        }

        // 获取历史数据
        const getByUserIdPaged = () => {
            GetByUserIdPaged({ PageIndex: 1, PageSize: 1 }).then((res) => {
                if (res.State === 0 && res.Data && res.Data.List && res.Data.List.length > 0) {
                    const first = res.Data.List[0]
                    currentRecord.value = first
                    const sid = first.SessionId ?? first.sessionId ?? ''
                    document.title = first.SessionName || '关系经营助手'
                    if (sid) {
                        sessionId.value = sid
                        fetchHistoryBySessionId(sid, first.CustomerId || '')
                    } else {
                        if (!taskCardHistoryReady.value) {
                            taskCardHistoryReady.value = true
                        }
                        tryInitCustTaskCardOnPageRender()
                        Toast.clear()
                    }
                } else {
                    document.title = '关系经营助手'
                    if (!taskCardHistoryReady.value) {
                        taskCardHistoryReady.value = true
                    }
                    tryInitCustTaskCardOnPageRender()
                    Toast.clear()
                }
            }).catch(() => {
                if (!taskCardHistoryReady.value) {
                    taskCardHistoryReady.value = true
                }
                tryInitCustTaskCardOnPageRender()
                Toast.clear()
            })
        }
        let openTolerance = false // 触发了降级容错
		// 微信小程序交互回调
		const wxSocketOnMessage = async (message) => {
			console.log('wxSocketOnMessage', message)
			const newMessage = JSON.parse(message || '{}')
			const { action, action_data = {} } = newMessage
			switch (action) {
				case 11: // 腾讯翻译不出来
					{
                        if (monitor) {
                            clearTimeout(monitor)
                            monitor = null
                        }
                        const LastIndex = messageStream.value.length - 1
                        if (messageStream.value[LastIndex] && messageStream.value[LastIndex].role === 'user') {
                            messageStream.value.pop()
                        }
                        recordStatus.value = 2
                        recordIndex.value = messageStream.value.length - 1
						Toast.fail('语音转文字失败，请重新录音')
					}
					break;
				case 24: // 最终翻译结果
					{
                        if (voiceFinalResultHandled) {
                            break
                        }
                        voiceFinalResultHandled = true
                        if (monitor) {
                            clearTimeout(monitor)
                            monitor = null
                        }
                        const index = messageStream.value.length - 1
                        console.log('微信翻译最终结果', action_data)
                        if (!isCancelRecord) {
                            if (action_data.audioText) {
                                if (messageStream.value[index].role === 'user') {
                                    const fileId = (action_data.file_id || '').trim()
                                    const audioUrl = fileId ? bjsdk.url(`//{ecdn}/Beta.FileService/f/${fileId}`, true) : ''
                                    const audioDurationMs = (secCount.value || 0) * 1000
                                    const providerVal = asrProviderInfo.value || '00'
                                    const sampleRateVal = providerVal.endsWith('1') ? 16000 : 8000
                                    const audioPayload = buildPayloadMeta({
                                        fileName: fileId ? `${fileId}.pcm` : '',
                                        format: 'pcm',
                                        size: 0,
                                        source: 'realtime',
                                        extra: {
                                            duration_ms: audioDurationMs,
                                            sampleRate: sampleRateVal,
                                            channels: 1,
                                            encoding: 16,
                                        },
                                    })
                                    const audioText = buildRealtimeAsrTextContent(action_data.audioText || '')
                                    let finalContent = ''
                                    const currentItem = messageStream.value[index]
                                    // 合并附件到内容中以便渲染
                                    if (currentItem.attachments && currentItem.attachments.length > 0) {
                                        const mdImages = currentItem.attachments.map(a => {
                                            if (a.type === 'image') return `\n![image](${a.url})`
                                            return ''
                                        }).join('')
                                        finalContent += mdImages
                                    }

                                    currentItem.content = finalContent
                                    currentItem.showLoading = false
                                    // 多模态：保存语音信息
                                    if (audioUrl) {
                                        currentItem.content_type = 'audio'
                                        currentItem.audio_url = audioUrl
                                        currentItem.audio_text = audioText
                                        currentItem.audio_payload = audioPayload
                                    }
                                    if (messageStream.value.length === 1) {
                                        await addCustSession(action_data.audioText || '')
                                    }
                                    addRecordDetail({
                                        msgContent: action_data.audioText || '',
                                        fileId: fileId,
                                    })
                                    scrollToBottom()
                                    recordStatus.value = 2
                                    onReply()
                                }
                            } else {
                                if (messageStream.value[index] && messageStream.value[index].role === 'user') {
                                    messageStream.value.pop()
                                }
                                recordIndex.value = messageStream.value.length - 1
                                recordStatus.value = 2 //关闭loading
                                Toast.fail('语音转文字失败，请重新录音')
                            }
                        }
					}
					break;
				case 26: // 翻译数据
					console.log('微信翻译结果', action_data)
					break;
				case 30:
					const content = JSON.parse(action_data.Content || '{}')
					console.log('收到消息为', content)
					if (content && content.type) {// 开启录音成功
						switch (content.type) {
							case '30_2':
                                secCount.value = 0 //重新计时
                                // 录音计时
                                timer.value = setInterval(() => {
                                    secCount.value++
                                }, 1000)
								break;
							case '30_4': // 停止录音成功
								isStoped = true
								break;
							case '30_7': // 录音准备好了
								isStoped = true
								break;
							case '30_6': // 录音出错
								isCancelRecord = true
								const length = messageStream.value.length
								if (messageStream.value[length - 1] && messageStream.value[length - 1].role === 'user') {
									messageStream.value.pop()
								}
								recordIndex.value = messageStream.value.length - 1
								recordStatus.value = 2 //关闭loading
								onCancelRecord(true)
								// Toast.fail(`录音出错: ${content.msg}`)
								break;
						}
					}
					break;
				case 31: // 服务端给的结束请求
					break;
				case 32: // 取消录音后，服务端的回调
					break;
				case 40: // 降级处理, 重启计时器
					console.warn('触发降级了')
					openTolerance = true
					if (monitor) {
						extremelyMonitor()
					}
					break;
			}
		}
		// 微信录音容错处理 // 增加异常监控，7s服务端没有给翻译文案，则不再等待
		const extremelyMonitor = () => {
			if (monitor) {
				clearTimeout(monitor)
				monitor = null
			}
			monitor = setTimeout(() => {
                stopStreamHeartbeat()
                if (replyController.value) {
                    replyController.value.abort()
                    replyController.value = null
                }
                isReplying.value = false
				isStoped = true
				isCancelRecord = true
				const index = messageStream.value.length - 1
				if (messageStream.value[index] && messageStream.value[index].role === 'user') {
					messageStream.value.pop()
				}
				recordIndex.value = messageStream.value.length - 1
				Toast.fail('语音转文字失败，请重新录音')
				// 
				wxAppAudio.sendMessage({
					action: 30,
					action_data: {
						content: JSON.stringify({
							type: '30_5',
						}),
					},
				})
				clearTimeout(monitor)
				monitor = null
			}, openTolerance ? 16000 : 8000)
		}
        // 我的客户列表
        const goCustomerList = () => {
            bjsdk.goTo('/customerList', {})
        }
        // 我的待办列表
        const goTaskList = () => {
            bjsdk.goTo('/tasks', {})
        }
        const goUserCenter = () => {
            if (window.bjsdk && typeof window.bjsdk.goTo === 'function') {
                window.bjsdk.goTo('/user/center', {})
            }
        }
        const goIdentitySetting = () => {
            showIdentityPromptCard.value = false
            if (window.bjsdk && typeof window.bjsdk.goTo === 'function') {
                window.bjsdk.goTo('/user/identity', {})
                return
            }
            window.location.hash = '#/user/identity'
        }
        // 客户画像
        const goCustomer = () => {
            bjsdk.goTo('/customerDetail', {
                append: {
                    CustomerId: currentRecord.value.CustomerId,
                },
            })
        }
        const getBjwtFromHash = (hKey = '') => {
            const hash = window.location.hash || ''
            const pureHash = hash.replace(/^#/, '')
            if (!pureHash) return ''

            let query = pureHash
            if (pureHash.includes('?')) {
                query = pureHash.split('?')[1] || ''
            } else if (pureHash.includes('/')) {
                query = pureHash.split('/').pop() || ''
            }

            const params = new URLSearchParams(query)
            return (params.get(hKey) || '').trim()
        }
        const checkBjwtAndSetShadow = () => {
            const bjwt = getBjwtFromHash('bjwt')
            const bjwte = getBjwtFromHash('bjwte')
            const invalidValueList = ['undefined', 'null', '', '0']
            const normalizedBjwt = (bjwt || '').trim().toLowerCase()
            showJwtLoginShadow.value = (invalidValueList.includes(normalizedBjwt) || !bjwte || bjwte < Date.now()) && isMini.value
        }
        const goMiniProgramLogin = () => {
            if (window.wx && wx.miniProgram && wx.miniProgram.navigateTo) {
                wx.miniProgram.navigateTo({
                    url: '/pages/login/index'
                })
            }
        }
        const showCustomerListBtn = ref(false)
        const showMyTaskBtn = ref(false)
        const taskCardShownToday = ref(false)
        const shouldShowCustTaskCard = ref(false)
        const taskCardAnchorIndex = ref(-1)
        const taskCardInitSettled = ref(false)
        const taskCardExistsAnyReady = ref(false)
        const taskCardHistoryReady = ref(false)
        const TASK_CARD_SHOWN_DATE_KEY = 'home_cust_task_card_shown_date'
        const getTodayKey = () => {
            const now = new Date()
            const year = now.getFullYear()
            const month = `${now.getMonth() + 1}`.padStart(2, '0')
            const day = `${now.getDate()}`.padStart(2, '0')
            return `${year}-${month}-${day}`
        }
        const syncTaskCardShownStateByDate = () => {
            try {
                taskCardShownToday.value = localStorage.getItem(TASK_CARD_SHOWN_DATE_KEY) === getTodayKey()
            } catch (e) {
                taskCardShownToday.value = false
            }
        }
        const markTaskCardShownToday = () => {
            const today = getTodayKey()
            taskCardShownToday.value = true
            try {
                localStorage.setItem(TASK_CARD_SHOWN_DATE_KEY, today)
            } catch (e) {
                // ignore
            }
        }
        const tryInitCustTaskCardOnPageRender = () => {
            if (taskCardInitSettled.value) return
            if (!taskCardExistsAnyReady.value || !taskCardHistoryReady.value) return
            if (showMyTaskBtn.value && messageStream.value.length > 0 && !taskCardShownToday.value) {
                shouldShowCustTaskCard.value = true
                taskCardAnchorIndex.value = messageStream.value.length - 1
                taskCardLoadedOnce.value = false
                markTaskCardShownToday()
            } else {
                shouldShowCustTaskCard.value = false
                taskCardAnchorIndex.value = -1
                taskCardLoadedOnce.value = false
            }
            taskCardInitSettled.value = true
        }
        watch([showLongRecord, isSelectionDisabled], ([v1, v2]) => {
            if (v1 || v2) {
                document.body.classList.add('is_recording')
            } else {
                document.body.classList.remove('is_recording')
            }
        })
        watch(() => messageStream.value.length, (length) => {
            if (length === 0) {
                taskCardAnchorIndex.value = -1
                showScrollBottomBtn.value = false
                hasUserScrolledContent.value = false
                streamAutoFollowBottom.value = true
                return
            }
            nextTick(() => {
                updateScrollBottomBtnVisibility()
            })
        })
        // 判断当前是否有客户
        const existsAny = () => {
            ExistsAny({}).then(res => {
                const state = res.State !== undefined ? res.State : res.state
                const data = res.Data || res.data || {}
                if (state === 0) {
                    showCustomerListBtn.value = !!(data.HasAny !== undefined ? data.HasAny : data.hasAny)
                    showMyTaskBtn.value = !!(data.HasAnyTask !== undefined ? data.HasAnyTask : data.hasAnyTask)
                }
            }).catch(() => {
                showCustomerListBtn.value = false
                showMyTaskBtn.value = false
            }).finally(() => {
                taskCardExistsAnyReady.value = true
                tryInitCustTaskCardOnPageRender()
            })
        }
        const asrProviderInfo = ref('00')
        // 初始化
        const initWxApp = () => {
            wxAppAudio = new WXAppAudio(bjsdk.query('wsId'), wxSocketOnMessage, asrProviderInfo.value)
        }
        // 解析markdown插件
		const markdown = MarkdownConfig();
        const onViewportResize = () => {
            const viewport = window.visualViewport
            if (!viewport) return
            // 如果高度显著减少，通常意味着软键盘打开了，此时可以触发滚动随动
            if (lastViewportHeight && viewport.height < lastViewportHeight - 100) {
                runKeyboardFollowScroll()
            }
            lastViewportHeight = viewport.height
        }
        let lastViewportHeight = window.visualViewport ? window.visualViewport.height : window.innerHeight

        onMounted(async () => {
            if (window.visualViewport) {
                window.visualViewport.addEventListener('resize', onViewportResize)
            }
            try {
                const res = await GetAsrProvider()
                if (res && res.Data) {
                    asrProviderInfo.value = res.Data
                }
            } catch (err) {
                console.error('获取 GetAsrProvider 失败', err)
            }
            checkBjwtAndSetShadow()
            if (showJwtLoginShadow.value) {
                return
            }
            Toast.loading({ message: '加载中...', forbidClick: true, duration: 0, })
            console.log('window.__wxjs_environment', window.__wxjs_environment)
            syncTaskCardShownStateByDate()
            existsAny()
            if (window.__wxjs_environment === 'miniprogram') {
                initWxApp()
            }
            // initWxApp()
            if (bjsdk.query('sessionId')) {
                sessionId.value = bjsdk.query('sessionId')
                fetchHistoryBySessionId(sessionId.value, bjsdk.query('customerId') || '')
            } else {
                if (bjsdk.query('customerId')) {
                    onCreateSession()
                    currentRecord.value = {
                        CustomerId: bjsdk.query('customerId') || '',
                    }
                    if (!taskCardHistoryReady.value) {
                        taskCardHistoryReady.value = true
                    }
                    tryInitCustTaskCardOnPageRender()
                    Toast.clear()
                } else {
                    getByUserIdPaged()
                }
            }
            nextTick(() => {
                resizeMsgInput()
                bindContentAreaScroll()
            })
        })

        onUnmounted(() => {
            if (window.visualViewport) {
                window.visualViewport.removeEventListener('resize', onViewportResize)
            }
            unbindContentAreaScroll()
            unbindKeyboardViewportResize()
            stopStreamHeartbeat()
            isReplying.value = false
            if (programmaticScrollTimer) {
                clearTimeout(programmaticScrollTimer)
                programmaticScrollTimer = null
            }
            if (streamScrollRafId !== null) {
                cancelAnimationFrame(streamScrollRafId)
                streamScrollRafId = null
            }
        })

        return {
            isMini,
            isPc,
            pageTitle,
            exampleWidth,
            inputType,
            showTools,
            attachments,
            toggleTools,
            afterReadFile,
            onFileOversize,
            MAX_UPLOAD_AUDIO_SIZE,
            MAX_UPLOAD_FILE_SIZE,
            FILE_ACCEPT,
            removeAttachment,
            showAttachmentAddButton,
            getAttachmentPanelCountText,
            clearAttachments,
            msgText,
            msgTextTrimmed,
            inputActionEnabled,
            handleKeydownSend,
            showSendBtn,
            showMsgInputOverlay,
            textInputPlaceholder,
            hasVisibleMessageBody,
            getFileTypeInfo,
            getFileMetaText,
            shouldShowMessageContent,
            previewImgUrl,
            onContentClick,
            closeImagePreview,
            showJwtLoginShadow,
            showVoiceOverlay,
            fingerOutsideOverlay,
            voiceOverlayRef,
            contentAreaRef,
            msgInputRef,
            showScrollBottomBtn,
            onScrollBottomBtnClick,
            historyLoading,
            historyPullDistance,
            historyPullVisualHeight,
            historyPullText,
            onContentAreaTouchStart,
            onContentAreaUserTouchStart,
            onContentAreaTouchMove,
            onContentAreaWheel,
            onHistoryPullTouchEnd,
            onOverlayTouchStart,
            onOverlayTouchMove,
            onOverlayTouchEnd,
            onToolBtnTouchStart,
            onToolBtnTouchMove,
            onToolBtnTouchEnd,
            onSendBtnTouchStart,
            onSendBtnTouchMove,
            onSendBtnTouchEnd,
            onToggleBtnTouchStart,
            onToggleBtnTouchMove,
            onToggleBtnTouchEnd,
            resizeMsgInput,
            onMsgInputFocus,
            onMsgInputBlur,
            bannerExpanded,
            isSelectionDisabled,
            toggleBannerExpand,
            onVoiceTouchStart,
            onVoiceTouchEnd,
            onVoiceOverlayTouchMove,
            toggleInputType,
            handleSend,
            onCustTaskLoaded,
            shouldShowTaskCreatedHint,
            onCustTaskCardLoaded,
            onCloseExample,
            onExampleShadowClick,
            onSelectOption,
            onSubmitSelectOption,
            onSubmitTextInput,
            onInteractionTextInput,
            hasInteractionContent,
            isInteractionItemDisabled,
            isInteractionOptionSelected,
            shouldShowInteractionReply,
            getInteractionReplyText,
            getInteractionQuestion,
            shouldShowAllCustomerEntry,
            shouldShowInteractionSubmit,
            onSubmitInteraction,
            showLongRecord,
            secCount,
            showCountdown,
            showCount,
            showExample,
            assistantThinkingElapsedText,
            assistantThinkingStatusText,
            showMenu,
            showCustomerPicker,
            canRecord,
            changeMenuState,
            closeMenu,
            openCustomerPicker,
            closeCustomerPicker,
            onCustomerPickerConfirm,
            onSelectDialog,
            onCreateSession,
            sessionId,
            messageStream,
            getMessageRenderKey,
            fetchHistoryBySessionId,
            menuMRight,
            markdown,
            goCustomer,
            // onCreateCustomer,
            goMiniProgramLogin,
            showCustomerListBtn,
            showMyTaskBtn,
            shouldShowCustTaskCard,
            taskCardAnchorIndex,
            showIdentityPromptCard,
            goIdentitySetting,
            currentRecord,
            goCustomerList,
            goTaskList,
            goUserCenter,
            isPlayableAudioMessage,
            getAudioUri,
            getAudioText,
            getAudioDuration,
            getAudioMimeType,
            getAudioPayload,
            getAudioVariant,
            getAudioLabel,
            shouldShowAudioTextToggle,
            getAttachmentAudioText,
            getAttachmentAudioDuration,
            getAttachmentAudioMimeType,
            getAttachmentAudioPayload,
            getAttachmentAudioVariant,
            getAttachmentAudioLabel,
            shouldShowAttachmentAudioTextToggle,
        }
    }
}
</script>
