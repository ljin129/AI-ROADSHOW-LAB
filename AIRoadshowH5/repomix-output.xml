<file path="src/views/tasks/index.vue">
<template>
	<div class="page-tasks" :class="[isPc ? 'pc_page_container' : '']">
		<page-head :title="pageTitle" v-if="isPc" />

		<section ref="taskSearchRef" class="task-search" :class="[isPc ? 'pc_container' : '']" :style="{ top: searchTop }">
			<div class="task-search-wrap">
				<span class="task-search-wrap-icon">
					<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
						<path fill="currentColor" d="M15.5 14h-.79l-.28-.27a6.5 6.5 0 1 0-.7.7l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9z" />
					</svg>
				</span>
				<input
					v-model="query"
					class="task-search-wrap-input"
					type="text"
					placeholder="输入关键词搜索"
					@keyup.enter="onSearch"
				/>
				<button v-if="query" type="button" class="task-search-wrap-clear" @click="onCancel" aria-label="清空搜索">
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M7 7l10 10"></path>
						<path d="M17 7l-10 10"></path>
					</svg>
				</button>
			</div>
		</section>

		<section ref="taskPriorityRef" class="task-priority" :class="[isPc ? 'pc_container' : '']" :style="{ top: priorityTop }">
			<button
				v-for="item in priorityTabs"
				:key="`priority_${item.value || 'all'}`"
				type="button"
				class="task-priority-item"
				:class="{ active: queryType === item.value }"
				@click="onChangePriority(item.value)"
			>
				<span class="task-priority-item-icon" :class="[`icon-${item.value || 'all'}`]">
					<svg v-if="item.value === ''" viewBox="0 0 24 24" aria-hidden="true">
						<rect x="4.5" y="5.5" width="15" height="14" rx="2"></rect>
						<path d="M8 3.8v3"></path>
						<path d="M16 3.8v3"></path>
						<path d="M7 10.5h10"></path>
					</svg>
					<svg v-else-if="item.value === '1'" viewBox="0 0 24 24" aria-hidden="true">
						<circle cx="12" cy="12" r="8.5"></circle>
						<path d="M12 7.8v4.5l3.1 1.8"></path>
					</svg>
					<svg v-else-if="item.value === '2'" viewBox="0 0 24 24" aria-hidden="true">
						<rect x="4.5" y="5.5" width="15" height="14" rx="2"></rect>
						<path d="M8 3.8v3"></path>
						<path d="M16 3.8v3"></path>
						<path d="M7 10.5h10"></path>
					</svg>
					<svg v-else-if="item.value === '3'" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M12 4.8l8.1 14.1H3.9L12 4.8z"></path>
						<path d="M12 9.4v4.5"></path>
						<circle cx="12" cy="16.5" r="0.9" fill="currentColor" stroke="none"></circle>
					</svg>
					<svg v-else viewBox="0 0 24 24" aria-hidden="true">
						<circle cx="12" cy="12" r="8.5"></circle>
						<path d="M8.3 12.1l2.3 2.3 5.1-5.2"></path>
					</svg>
				</span>
				<span class="task-priority-item-label">{{ item.label }}</span>
				<span class="task-priority-item-count">{{ getTabCount(item.value) }}</span>
				
			</button>
		</section>

		<section class="task-list" :class="[isPc ? 'pc_container' : '']" :style="{ paddingTop: listPaddingTop }">
			<van-pull-refresh v-model="refreshing" @refresh="onRefresh">
				<van-list
					v-model:loading="loading"
					:finished="finished"
					:finished-text="tasks.length ? '没有更多了' : ''"
					@load="onLoad"
				>
					<div
						v-for="task in tasks"
						:key="task.taskId"
						class="task-card"
						:class="[getTaskCardClass(task)]"
					>
						<div class="task-card-top">
							<div class="task-card-meta-line">
								<span class="task-card-priority-text" :class="getTaskStatusTagClass(task)">{{ getTaskStatusTagText(task) }}</span>
								<span class="task-card-reason-text">
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path d="M12 20s6.2-5.2 6.2-10A6.2 6.2 0 0 0 5.8 10C5.8 14.8 12 20 12 20z"></path>
										<circle cx="12" cy="10" r="2.3"></circle>
									</svg>
									{{ getTaskSceneText(task) }}
								</span>
							</div>
							<div v-if="getTopRightTimeText(task) || getOverdueDaysText(task)" class="task-card-time">
								<span v-if="getOverdueDaysText(task)" class="task-card-overdue-days">
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path d="M12 4.8l8.1 14.1H3.9L12 4.8z"></path>
										<path d="M12 9.4v4.5"></path>
										<circle cx="12" cy="16.5" r="0.9" fill="currentColor" stroke="none"></circle>
									</svg>
									{{ getOverdueDaysText(task) }}
								</span>
								<span
									v-if="getTopRightTimeText(task)"
									class="task-card-deadline"
									:class="[getDeadlineClass(task), { 'is-overdue-sub': !!getOverdueDaysText(task) }]"
								>
									{{ getTopRightTimeText(task) }}
								</span>
							</div>
						</div>

						<div class="task-card-title">{{ task.taskTitle || '待执行任务' }}</div>

						<div
							class="task-card-customer"
							:class="{ 'is-clickable': !!task.customerId }"
							v-if="task.customerName || task.customerCompany || task.customerPosition || task.customerIndustry"
							@click="goCustomerDetail(task)"
						>
							<!-- <div class="task-card-avatar" :class="getTaskCardClass(task)">{{ getCustomerAvatarText(task) }}</div> -->
							<div class="task-card-customer-main">
								<div class="task-card-customer-name">{{ task.customerName || '未知客户' }}</div>
								<div class="task-card-customer-meta">
									{{ formatCustomerMeta(task) }}
								</div>
							</div>
							<div class="task-card-customer-contact" v-if="task.customerLastContactDate">
								最近联系 {{ task.customerLastContactDate }}
							</div>
						</div>

						<div class="task-card-summary" v-if="task.taskSummary">
							{{ task.taskSummary }}
						</div>

						<div class="task-card-actions">
							<button
								v-if="isCompletedTask(task)"
								type="button"
								class="task-card-btn task-card-btn-complete is-disabled"
								disabled
							>
								<svg viewBox="0 0 24 24" aria-hidden="true">
									<circle cx="12" cy="12" r="8"></circle>
									<path d="M8.5 12.2l2.2 2.2 4.8-4.8"></path>
								</svg>
								已完成
							</button>
							<template v-else>
								<button type="button" class="task-card-btn task-card-btn-delete" :disabled="isTaskOperating(task)" @click.stop="onClickDelete(task)">
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path d="M4.5 7.5h15"></path>
										<path d="M9 7.5V6a1.5 1.5 0 0 1 1.5-1.5h3A1.5 1.5 0 0 1 15 6v1.5"></path>
										<path d="M7.8 7.5l.7 10a1.2 1.2 0 0 0 1.2 1.1h4.6a1.2 1.2 0 0 0 1.2-1.1l.7-10"></path>
										<path d="M10 10.5v5.5"></path>
										<path d="M14 10.5v5.5"></path>
									</svg>
									删除
								</button>
								<button type="button" class="task-card-btn task-card-btn-complete" :disabled="isTaskOperating(task)" @click.stop="onClickComplete(task)">
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<circle cx="12" cy="12" r="8"></circle>
										<path d="M8.5 12.2l2.2 2.2 4.8-4.8"></path>
									</svg>
									完成
								</button>
							</template>
						</div>
					</div>
				</van-list>
			</van-pull-refresh>

			<div v-if="finished && !tasks.length" class="task-empty">
				<img class="task-empty-image" :src="taskEmptyImg" alt="暂无待办数据" />
			</div>
		</section>
	</div>
</template>

<script>
import { ref, reactive, toRefs, watch, onMounted, onUnmounted, nextTick, computed } from 'vue'
import pageHead from '@/components/pageHead'
import { PullRefresh, List, Toast, Dialog } from 'vant'
import { GetByUserIdPaged, GetSummaryByUserId, DeleteByTaskId, CompleteByTaskId } from '@/api/custTask'
import { utcToLocal } from '@/utils/util'
import taskEmptyImg from '@/assets/img/tasks/task_empty.png'

export default {
	name: 'Tasks',
	components: {
		pageHead,
		[PullRefresh.name]: PullRefresh,
		[List.name]: List,
	},
	setup() {
		const isPc = ref((window.bjsdk.isWinPC || window.bjsdk.isMac) && !window.bjsdk.isWM)
		const pageTitle = ref(document.title || '待办列表')
		const query = ref('')
		const queryType = ref('')
		const taskSearchRef = ref(null)
		const taskPriorityRef = ref(null)
		const searchBarHeight = ref(53)
		const priorityBarHeight = ref(54)
		let searchTimer = null
		const priorityTabs = [
			{ label: '全部', value: '' },
			{ label: '今日待办', value: '1' },
			{ label: '近期待办', value: '2' },
			{ label: '逾期待办', value: '3' },
			//{ label: '已完成', value: '4' },
		]
		const tabCountMap = reactive({
			all: 0,
			'1': 0,
			'2': 0,
			'3': 0,
			'4': 0,
		})
		let tabCountRequestId = 0

		const state = reactive({
			tasks: [],
			loading: false,
			finished: false,
			refreshing: false,
			pageIndex: 0,
			pageSize: 10,
			total: 0,
		})
		const taskOperatingId = ref('')
		const searchTop = computed(() => (isPc.value ? '65px' : '0px'))
		const priorityTop = computed(() => `${(isPc.value ? 65 : 0) + searchBarHeight.value}px`)
		const listPaddingTop = computed(() => `${(isPc.value ? 65 : 0) + searchBarHeight.value + priorityBarHeight.value + 12}px`)

		const updateHeaderHeights = () => {
			nextTick(() => {
				if (taskSearchRef.value && taskSearchRef.value.offsetHeight) {
					searchBarHeight.value = taskSearchRef.value.offsetHeight
				}
				if (taskPriorityRef.value && taskPriorityRef.value.offsetHeight) {
					priorityBarHeight.value = taskPriorityRef.value.offsetHeight
				}
			})
		}

		const toDisplayText = (value) => {
			if (value === null || value === undefined) return ''
			return `${value}`.trim()
		}
		const getTabCountKey = (value) => (value === '' ? 'all' : `${value}`)
		const setTabCount = (value, total) => {
			const count = Number(total)
			tabCountMap[getTabCountKey(value)] = Number.isFinite(count) ? count : 0
		}
		const getTabCount = (value) => {
			return tabCountMap[getTabCountKey(value)] || 0
		}

		const toLocalTimeText = (value) => {
			const raw = toDisplayText(value)
			if (!raw) return ''
			const local = utcToLocal(raw)
			const normalized = toDisplayText(local) || raw
			if (!normalized) return ''
			const dateMatch = normalized.match(/\d{4}-\d{2}-\d{2}/)
			if (dateMatch && dateMatch[0]) return dateMatch[0]
			return normalized.split(' ')[0]
		}

		const normalizePriorityValue = (value) => {
			const text = toDisplayText(value)
			const lower = text.toLowerCase()
			if (text === '1' || text.includes('重要') || lower.includes('important') || text.includes('高') || lower.includes('high')) return '1'
			if (text === '2' || text.includes('普通') || lower.includes('normal') || text.includes('中') || lower.includes('medium') || text.includes('低') || lower.includes('low')) return '2'
			return ''
		}

		const formatPriorityLevelText = (value) => {
			const normalized = normalizePriorityValue(value)
			if (normalized === '1') return '重要'
			if (normalized === '2') return '普通'
			return toDisplayText(value)
		}

		const getPriorityToneClass = (level) => {
			const normalized = normalizePriorityValue(level)
			if (normalized === '1') return 'is-important'
			if (normalized === '2') return 'is-normal'
			return ''
		}

		const formatCustomerMeta = (task) => {
			const parts = [task.customerCompany, task.customerIndustry, task.customerPosition].filter(Boolean)
			return parts.join(' · ')
		}
		const getCustomerAvatarText = (task) => {
			const name = toDisplayText(task && task.customerName)
			if (!name) return '客'
			return Array.from(name)[0] || '客'
		}

		const parseDateParts = (value) => {
			const text = toDisplayText(value)
			if (!text) return null
			const match = text.match(/(\d{4})[-/.](\d{1,2})[-/.](\d{1,2})/)
			if (!match) return null
			const year = match[1]
			const month = match[2].padStart(2, '0')
			const day = match[3].padStart(2, '0')
			return {
				year,
				month,
				day,
				full: `${year}-${month}-${day}`,
				short: `${month}-${day}`,
			}
		}

		const getDeadlineRangeText = (task) => {
			const startRaw = task && task.suggestedStart
			const endRaw = task && task.suggestedEnd
			const start = parseDateParts(startRaw)
			const end = parseDateParts(endRaw)

			if (start && end) {
				if (start.full === end.full) return start.short
				if (start.year === end.year) return `${start.short} ~ ${end.short}`
				return `${start.full} ~ ${end.full}`
			}
			if (start) return start.short
			if (end) return end.short

			const startText = toDisplayText(startRaw)
			const endText = toDisplayText(endRaw)
			if (startText && endText) {
				return startText === endText ? startText : `${startText} ~ ${endText}`
			}
			return startText || endText
		}
		const normalizeTaskStatusValue = (value) => {
			const text = toDisplayText(value)
			if (text === '2') return '2'
			if (text === '1') return '1'
			return '0'
		}

		const isOverdueTask = (task) => {
			if (!task || typeof task !== 'object') return false
			return normalizeTaskStatusValue(task.taskStatus) === '2'
		}
		const isCompletedTask = (task) => {
			if (!task || typeof task !== 'object') return false
			return normalizeTaskStatusValue(task.taskStatus) === '1'
		}
		const getTaskStatusTagText = (task) => {
			if (isCompletedTask(task)) return '已完成'
			return toDisplayText(task && task.priorityLevelText) || '普通'
		}
		const getTaskStatusTagClass = (task) => {
			if (isCompletedTask(task)) return 'tag-completed'
			const priorityClass = getPriorityToneClass(task && task.priorityLevel)
			if (priorityClass === 'is-important') return 'tag-important'
			return 'tag-normal'
		}
		const getTaskSceneText = (task) => {
			return toDisplayText(task && task.priorityReason) || '待跟进窗口'
		}
		const getTopRightTimeText = (task) => {
			const deadlineText = getDeadlineRangeText(task)
			return deadlineText ? `截至：${deadlineText}` : ''
		}
		const getOverdueDaysText = (task) => {
			if (!isOverdueTask(task)) return ''
			const end = parseDateParts(task && task.suggestedEnd)
			if (!end) return '逾期'
			const endDate = new Date(Number(end.year), Number(end.month) - 1, Number(end.day))
			const today = new Date()
			const todayDate = new Date(today.getFullYear(), today.getMonth(), today.getDate())
			const dayMs = 24 * 60 * 60 * 1000
			const diff = Math.floor((todayDate.getTime() - endDate.getTime()) / dayMs)
			const overdueDays = diff > 0 ? diff : 0
			return overdueDays > 0 ? `逾期：${overdueDays}天` : '逾期'
		}
		const getTaskCardClass = (task) => {
			if (isOverdueTask(task)) return 'is-overdue'
			if (isCompletedTask(task)) return 'is-completed'
			return getPriorityToneClass(task && task.priorityLevel)
		}

		const getDeadlineClass = (task) => {
			if (isOverdueTask(task)) return 'is-overdue'
			if (isCompletedTask(task)) return 'is-completed'
			const priorityClass = getPriorityToneClass(task && task.priorityLevel)
			if (priorityClass === 'is-important') return 'is-important'
			if (priorityClass === 'is-normal') return 'is-normal'
			return 'is-normal'
		}
		const isTaskOperating = (task) => {
			if (!task || typeof task !== 'object') return false
			return toDisplayText(task.taskId) && toDisplayText(task.taskId) === toDisplayText(taskOperatingId.value)
		}

		const getPageData = (res) => {
			return res.Data || res.data || {}
		}
		const loadTabCounts = async () => {
			const requestId = ++tabCountRequestId
			try {
				const res = await GetSummaryByUserId({})
				if (requestId !== tabCountRequestId) return
				const data = getPageData(res)
				const totalCount = Number(data.TotalCount ?? data.totalCount ?? 0)
				const groups = Array.isArray(data.QueryTypeGroups)
					? data.QueryTypeGroups
					: (Array.isArray(data.queryTypeGroups) ? data.queryTypeGroups : [])

				setTabCount('', totalCount)
				setTabCount('1', 0)
				setTabCount('2', 0)
				setTabCount('3', 0)
				setTabCount('4', 0)

				groups.forEach((group) => {
					const qType = `${group.QueryType ?? group.queryType ?? ''}`
					const count = Number(group.Count ?? group.count ?? 0)
					if (qType === '0') {
						setTabCount('', count)
						return
					}
					if (qType === '1' || qType === '2' || qType === '3' || qType === '4') {
						setTabCount(qType, count)
					}
				})
			} catch (error) {
				if (requestId !== tabCountRequestId) return
				setTabCount('', 0)
				setTabCount('1', 0)
				setTabCount('2', 0)
				setTabCount('3', 0)
				setTabCount('4', 0)
			}
		}

		const loadData = async () => {
			try {
				const params = {
					PageIndex: state.pageIndex,
					PageSize: state.pageSize,
					KeyWord: query.value || '',
				}
				if (queryType.value !== '') {
					params.QueryType = Number(queryType.value)
				}
				const res = await GetByUserIdPaged(params)
				const data = getPageData(res)
				const list = Array.isArray(data.List) ? data.List : []
				const normalizedList = list.map((item) => ({
					taskId: toDisplayText(item.TaskId),
					userId: toDisplayText(item.UserId),
					customerId: toDisplayText(item.CustomerId),
					taskTitle: toDisplayText(item.TaskTitle),
					taskSummary: toDisplayText(item.TaskSummary),
					priorityLevel: normalizePriorityValue(item.PriorityLevel),
					priorityLevelText: formatPriorityLevelText(item.PriorityLevel),
					priorityReason: toDisplayText(item.PriorityReason),
					suggestedStart: toLocalTimeText(item.SuggestedStart),
					suggestedEnd: toLocalTimeText(item.SuggestedEnd),
					isDelete: item.IsDelete,
					isUserAdd: item.IsUserAdd,
					createTime: toDisplayText(item.CreateTime),
					taskStatus: normalizeTaskStatusValue(item.TaskStatus),
					customerName: toDisplayText(item.CustomerName),
					customerCompany: toDisplayText(item.CustomerCompany),
					customerIndustry: toDisplayText(item.CustomerIndustry),
					customerPosition: toDisplayText(item.CustomerPosition),
					customerLastContactDate: toDisplayText(item.CustomerLastContactDate),
				}))
				const total = Number(data.TotalCount || 0)

				if (state.refreshing) {
					state.tasks = []
					state.refreshing = false
				}

				state.tasks.push(...normalizedList)
				state.total = total

				if (state.tasks.length >= state.total || normalizedList.length === 0) {
					state.finished = true
				}
			} catch (error) {
				console.error(error)
				state.finished = true
			} finally {
				state.loading = false
				if (state.refreshing) state.refreshing = false
			}
		}

		const resetAndSearch = () => {
			state.tasks = []
			state.finished = false
			state.loading = true
			state.refreshing = true
			state.pageIndex = 1
			loadTabCounts()
			loadData()
		}

		const onLoad = () => {
			if (state.finished) return
			state.pageIndex += 1
			loadData()
		}

		const onRefresh = async () => {
			state.finished = false
			state.loading = true
			state.pageIndex = 1
			loadTabCounts()
			loadData()
		}

		const onSearch = () => {
			if (searchTimer) clearTimeout(searchTimer)
			resetAndSearch()
		}

		const onCancel = () => {
			query.value = ''
			onSearch()
		}

		const onChangePriority = (value) => {
			if (queryType.value === value) return
			queryType.value = value
			resetAndSearch()
		}
		const goCustomerDetail = (task) => {
			if (!task || !task.customerId) return
			window.bjsdk.goTo('/customerDetail', {
				append: {
					CustomerId: task.customerId,
				},
			})
		}
		const onClickComplete = async (task) => {
			const taskId = toDisplayText(task && task.taskId)
			if (!taskId || isTaskOperating(task) || isCompletedTask(task)) return
			taskOperatingId.value = taskId
			try {
				await CompleteByTaskId({ taskId })
				const index = state.tasks.findIndex((item) => toDisplayText(item.taskId) === taskId)
				if (index > -1) {
					state.tasks.splice(index, 1)
				}
				state.total = Math.max(0, Number(state.total || 0) - 1)
				if (state.tasks.length === 0) {
					state.finished = true
				} else if (state.tasks.length < state.total) {
					state.finished = false
				} else {
					state.finished = true
				}
				loadTabCounts()
				Toast('已完成')
			} catch (error) {
				const message = error && (error.ErrorMessage || error.errorMessage || error.message)
				Toast(message || '更新失败，请稍后重试')
			} finally {
				if (toDisplayText(taskOperatingId.value) === taskId) {
					taskOperatingId.value = ''
				}
			}
		}
		const onClickDelete = async (task) => {
			const taskId = toDisplayText(task && task.taskId)
			if (!taskId || isTaskOperating(task)) return
			try {
				await Dialog.confirm({
					title: '确认删除',
					message: '确认删除该待办吗？',
				})
			} catch (error) {
				return
			}
			taskOperatingId.value = taskId
			try {
				await DeleteByTaskId({ taskId })
				const index = state.tasks.findIndex((item) => toDisplayText(item.taskId) === taskId)
				if (index > -1) {
					state.tasks.splice(index, 1)
				}
				state.total = Math.max(0, Number(state.total || 0) - 1)
				if (state.tasks.length === 0) {
					state.finished = true
				} else if (state.tasks.length < state.total) {
					state.finished = false
				} else {
					state.finished = true
				}
				loadTabCounts()
				Toast('删除成功')
			} catch (error) {
				const message = error && (error.ErrorMessage || error.errorMessage || error.message)
				Toast(message || '删除失败，请稍后重试')
			} finally {
				if (toDisplayText(taskOperatingId.value) === taskId) {
					taskOperatingId.value = ''
				}
			}
		}

		watch(query, () => {
			if (searchTimer) clearTimeout(searchTimer)
			searchTimer = setTimeout(() => {
				resetAndSearch()
			}, 500)
		})

		onMounted(() => {
			onRefresh()
			updateHeaderHeights()
			window.addEventListener('resize', updateHeaderHeights)
		})

		onUnmounted(() => {
			window.removeEventListener('resize', updateHeaderHeights)
		})

		return {
			taskSearchRef,
			taskPriorityRef,
			isPc,
			pageTitle,
			taskEmptyImg,
			query,
			queryType,
			priorityTabs,
			getTabCount,
			searchTop,
			priorityTop,
			listPaddingTop,
			...toRefs(state),
			getPriorityToneClass,
			isOverdueTask,
			isCompletedTask,
			getTaskCardClass,
			getTaskStatusTagText,
			getTaskStatusTagClass,
			getTaskSceneText,
			getTopRightTimeText,
			getOverdueDaysText,
			getCustomerAvatarText,
			formatCustomerMeta,
			getDeadlineClass,
			isTaskOperating,
			goCustomerDetail,
			onClickComplete,
			onClickDelete,
			onLoad,
			onRefresh,
			onSearch,
			onCancel,
			onChangePriority,
		}
	},
}
</script>

