- [ ] **Step 3: Add mp3-only attachment classification in `afterReadFile`**

Keep the existing image compression flow. Add an explicit mp3 validator and change uploaded audio attachments from `audio` to `audio_data`.

```js
const isMp3AudioFile = (file) => {
  const mime = `${file && file.type || ''}`.toLowerCase()
  const name = `${file && file.name || ''}`.toLowerCase()
  return mime === 'audio/mpeg' || name.endsWith('.mp3')
}

const afterReadFile = async (fileItem) => {
  const sourceFile = fileItem.file
  const isImage = sourceFile && sourceFile.type && sourceFile.type.startsWith('image/')
  const isAudio = sourceFile && sourceFile.type && sourceFile.type.startsWith('audio/')
  let uploadFile = sourceFile
  let previewUrl = fileItem.content

  if (isAudio && !isMp3AudioFile(uploadFile)) {
    Toast.fail('仅支持上传 mp3 音频')
    return
  }

  if (!isImage && !isAudio && uploadFile.size > 20 * 1024 * 1024) {
    Toast.fail('文档类文件不能超过20MB')
    return
  }

  if (isImage && uploadFile.size > IMG_COMPRESS_THRESHOLD) {
    Toast.loading({ message: '正在处理图片...', forbidClick: true, duration: 0 })
    try {
      const compressed = await compressImageFile(uploadFile)
      if (compressed !== uploadFile) {
        uploadFile = compressed
        previewUrl = URL.createObjectURL(uploadFile)
      }
    } finally {
      Toast.clear()
    }
  }

  const item = {
    id: Date.now() + Math.random().toString(36).substring(2, 9),
    type: isImage ? 'image' : (isAudio ? 'audio_data' : 'file'),
    file: uploadFile,
    fileName: uploadFile.name || 'file',
    formattedSize: formatSize(uploadFile.size),
    url: previewUrl,
    progress: 0,
    status: 'uploading',
  }

  attachments.value.push(item)
  showTools.value = false
  // keep the existing upload flow below
}
```

