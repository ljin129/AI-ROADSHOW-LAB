<template>
	<div class="page-customer-edit" :class="[isPc ? 'pc_page_container' : '']">
		<PageHead :title="pageTitle" v-if="isPc" />

		<main class="form-main" :class="[isPc ? 'pc_container' : '']">
			<section class="edit-hero">
				<div class="edit-hero-main">
					<div class="edit-hero-title">编辑客户信息</div>
					<div class="edit-hero-subtitle">完善资料，便于后续持续经营与跟进</div>
					<div class="edit-hero-progress-head">
						<span class="edit-hero-progress-label">资料完整度 {{ completePercent }}%</span>
						<span class="edit-hero-progress-count">{{ completeCount }}/{{ completeTotal }}</span>
					</div>
					<div class="edit-hero-progress-track">
						<span class="edit-hero-progress-value" :style="{ width: `${completePercent}%` }"></span>
					</div>
				</div>
				<div class="edit-hero-avatar">{{ profileInitial }}</div>
			</section>

			<form class="form-card" @submit.prevent>
				<div class="form-item">
					<label class="form-item-label">姓名</label>
					<input
						v-model="form.Name"
						class="form-item-input"
						type="text"
						placeholder="请输入姓名"
					/>
				</div>

				<div class="form-item">
					<label class="form-item-label">性别</label>
					<div class="gender-box">
						<button
							type="button"
							class="gender-btn"
							:class="{ active: form.Gender === '男' }"
							@click="form.Gender = '男'"
						>
							男
						</button>
						<button
							type="button"
							class="gender-btn"
							:class="{ active: form.Gender === '女' }"
							@click="form.Gender = '女'"
						>
							女
						</button>
					</div>
				</div>

				<div class="form-item">
					<label class="form-item-label">年龄</label>
					<input
						v-model="form.Age"
						class="form-item-input"
						type="number"
						placeholder="请输入年龄"
					/>
				</div>

				<div class="form-item">
					<label class="form-item-label">公司</label>
					<input
						v-model="form.Company"
						class="form-item-input"
						type="text"
						placeholder="请输入公司名称"
					/>
				</div>

				<div class="form-item">
					<label class="form-item-label">职位</label>
					<input
						v-model="form.Position"
						class="form-item-input"
						type="text"
						placeholder="请输入职位"
					/>
				</div>

				<div class="form-item">
					<label class="form-item-label">行业</label>
					<input
						v-model="form.Industry"
						class="form-item-input"
						type="text"
						placeholder="请输入所属行业"
					/>
				</div>

				<div class="form-item">
					<label class="form-item-label">生日</label>
					<input
						v-model="form.Birthday"
						class="form-item-input"
						type="date"
					/>
				</div>
			</form>
		</main>

		<footer class="footer-bar" :class="[isPc ? 'pc_container' : '']">
			<div class="footer-actions">
				<button class="footer-btn footer-btn-cancel" type="button" @click="handleBack">取消</button>
				<button class="footer-btn footer-btn-save" type="button" :disabled="isSaving" @click="handleSaveClick">保存资料</button>
			</div>
		</footer>
	</div>
</template>

<script>
import { reactive, ref, onMounted, computed } from 'vue'
import PageHead from '@/components/pageHead'
import { Dialog } from 'vant'
import { GetCustomerById, UpdateCustomerInfoByUser } from '@/api/custCustomer'

export default {
	name: 'CustomerEdit',
	components: {
		PageHead,
	},
	setup() {
		const isPc = ref((window.bjsdk.isWinPC || window.bjsdk.isMac) && !window.bjsdk.isWM)
		const pageTitle = ref(document.title)
		const isSaving = ref(false)
		const customerId = ref(window.bjsdk.query('CustomerId') || window.bjsdk.query('customerId') || '')

		const form = reactive({
			Name: '',
			Gender: '男',
			Age: '',
			Company: '',
			Position: '',
			Industry: '',
			Birthday: '',
		})

		const completeTotal = 6
		const completeCount = computed(() => {
			let count = 0
			if (`${form.Name || ''}`.trim()) count += 1
			if (`${form.Age || ''}`.trim()) count += 1
			if (`${form.Company || ''}`.trim()) count += 1
			if (`${form.Position || ''}`.trim()) count += 1
			if (`${form.Industry || ''}`.trim()) count += 1
			if (`${form.Birthday || ''}`.trim()) count += 1
			return count
		})
		const completePercent = computed(() => {
			return Math.round((completeCount.value / completeTotal) * 100)
		})
		const profileInitial = computed(() => {
			const name = `${form.Name || ''}`.trim()
			return name ? name.slice(0, 1) : '客'
		})

		const formatDateInput = (value) => {
			if (!value) return ''
			const text = String(value)
			const matched = text.match(/\d{4}-\d{2}-\d{2}/)
			if (matched) return matched[0]
			const date = new Date(text)
			if (Number.isNaN(date.getTime())) return ''
			const y = date.getFullYear()
			const m = `${date.getMonth() + 1}`.padStart(2, '0')
			const d = `${date.getDate()}`.padStart(2, '0')
			return `${y}-${m}-${d}`
		}

		const normalizeGender = (gender) => {
			if (!gender) return '男'
			if (gender === '男' || gender === 'Male') return '男'
			if (gender === '女' || gender === 'Female') return '女'
			return '男'
		}

		const loadCustomer = async () => {
			if (!customerId.value) return

			try {
				const res = await GetCustomerById({ customerId: customerId.value })
				const data = res.Data || {}
				form.Name = data.Name || ''
				form.Gender = normalizeGender(data.Gender)
				form.Age = data.Age !== undefined && data.Age !== null ? String(data.Age) : ''
				form.Company = data.Company || ''
				form.Position = data.Position || ''
				form.Industry = data.Industry || ''
				form.Birthday = formatDateInput(data.Birthday)
			} catch (error) {
				console.error(error)
			}
		}

		const handleBack = () => {
			window.bjsdk.goTo(-1)
		}

		const handleSaveClick = async () => {
			const tip = '温馨提示：手动修改并保存后，系统将不再通过自动提取更新客户信息。'
			try {
				await Dialog.confirm({
					title: '提示',
					message: `${tip}\n\n是否确认保存资料？`,
				})
			} catch (error) {
				return
			}
			if (!customerId.value || isSaving.value) return

			try {
				isSaving.value = true
				const ageValue = form.Age === '' || form.Age === null || form.Age === undefined ? null : Number(form.Age)
				await UpdateCustomerInfoByUser({
					customerId: customerId.value,
					name: form.Name || '',
					gender: form.Gender || '男',
					age: Number.isNaN(ageValue) ? null : ageValue,
					position: form.Position || '',
					company: form.Company || '',
					industry: form.Industry || '',
					birthday: form.Birthday || '',
				})
				window.bjsdk.goTo(-1)
			} catch (error) {
				window.alert((error && (error.ErrorMessage || error.errorMessage || error.message)) || '保存失败')
			} finally {
				isSaving.value = false
			}
		}

		onMounted(() => {
			loadCustomer()
		})

		return {
			isPc,
			pageTitle,
			isSaving,
			form,
			completeCount,
			completeTotal,
			completePercent,
			profileInitial,
			handleBack,
			handleSaveClick,
		}
	},
}
</script>

