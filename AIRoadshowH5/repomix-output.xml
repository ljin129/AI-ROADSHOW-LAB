/**
 * 判断字符串是否是json字符串
 * @param {*} str 
 * @returns Boolean
 */
function IsJsonStr(str) {  
    if (typeof str !== 'string' || str.trim() === '') {  
        return false;  
    }  
    try {  
        JSON.parse(str);  
