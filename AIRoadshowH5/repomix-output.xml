export const SendSMS = (params) => {
	return new Promise((resolve, reject) => {
		getData(`/Beta.AIRelationAuth.H5Api/User/SendSMS`, params, 'get')
			.then((res) => {
				const state = res.State !== undefined ? res.State : res.state
				if (state === 0) resolve(res)
				else reject(res.ErrorMessage || res.errorMessage || '请求失败')
			})
			.catch((err) => {
				reject(err.ErrorMessage || err.errorMessage || '请求失败')
			})
	})
}

