<file path="src/views/user/center.vue">
<template>
    <div class="page-user-center" :class="[isPc ? 'pc_page_container' : '']">
        <PageHead :title="pageTitle" v-if="isPc" />

        <main class="center-main" :class="[isPc ? 'pc_container' : '']">
            <section class="profile-card">
                <div class="profile-top">
                    <div class="avatar-wrap">
                        <span class="avatar-text">{{ avatarText }}</span>
                    </div>
                    <div class="profile-info">
                        <h1 class="profile-name">{{ displayName }}</h1>
                        <p class="profile-slogan">让关系更有价值</p>
                        <div class="identity-badge">当前身份：{{ identityLabel }}</div>
                    </div>
                </div>

                <div class="summary-grid summary-grid-two">
                    <button class="summary-item" type="button" @click="goCustomerList">
                        <strong>{{ summary.customerCount }}</strong>
                        <span>客户关系</span>
                    </button>
                    <button class="summary-item" type="button" @click="goTaskList">
                        <strong>{{ summary.taskCount }}</strong>
                        <span>待办事项</span>
                    </button>
                </div>
            </section>

            <h2 class="section-title">账号与资料</h2>

            <section class="menu-card">
                <button class="menu-row" type="button" @click="goProfile">
                    <span class="menu-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="8" r="3.2"></circle>
                            <path d="M6.2 19c1.4-3 3.3-4.5 5.8-4.5s4.4 1.5 5.8 4.5"></path>
                        </svg>
                    </span>
                    <span class="menu-main">
                        <strong>个人资料</strong>
                        <em>昵称、手机号等基础账号信息</em>
                    </span>
                    <span class="menu-arrow">›</span>
                </button>
                <button class="menu-row" type="button" @click="goIdentity">
                    <span class="menu-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="5" y="6" width="14" height="12" rx="2.5"></rect>
                            <path d="M8.5 10h7"></path>
                            <path d="M8.5 14h4.5"></path>
                        </svg>
                    </span>
                    <span class="menu-main">
                        <strong>身份设置</strong>
                        <em>用于让小络按你的身份生成策略</em>
                    </span>
                    <span class="menu-badge">{{ identityLabel }}</span>
                    <span class="menu-arrow">›</span>
                </button>
            </section>
        </main>
    </div>
</template>

<script>
import { computed, onMounted, reactive, ref } from 'vue'
import { useRouter } from 'vue-router'
import PageHead from '@/components/pageHead'
import { GetUserIdentity, GetUserInfo } from '@/api/user'
import { GetValidSummary } from '@/api/custCustomer'

const identityOptions = [
    { value: 1, label: '保险经纪' },
    { value: 2, label: '理财顾问' },
    { value: 3, label: '软件销售' },
    { value: 4, label: '其他' },
]

export default {
    name: 'UserCenter',
    components: {
        PageHead,
    },
    setup() {
        const router = useRouter()
        const sdk = window.bjsdk || {}
        const isPc = ref((sdk.isWinPC || sdk.isMac) && !sdk.isWM)
        const pageTitle = ref(document.title || '个人中心')
        const profile = reactive({
            nickName: '',
        })
        const identityType = ref(0)
        const summary = reactive({
            customerCount: 0,
            taskCount: 0,
        })

        const getResponseData = (res) => {
            return (res && (res.Data !== undefined ? res.Data : res.data)) || null
        }
        const getField = (data, upperKey, lowerKey) => {
            if (!data || typeof data !== 'object') return ''
            return data[upperKey] !== undefined ? data[upperKey] : data[lowerKey]
        }
        const toCount = (value) => {
            const num = Number(value || 0)
            return Number.isFinite(num) && num > 0 ? num : 0
        }
        const identityLabel = computed(() => {
            const item = identityOptions.find((opt) => opt.value === Number(identityType.value))
            return item ? item.label : '未设置'
        })
        const displayName = computed(() => {
            return String(profile.nickName || '').trim() || '用户'
        })
        const avatarText = computed(() => {
            const name = displayName.value
            return name ? name.slice(0, 1) : '用'
        })

        const loadUserInfo = async () => {
            try {
                const res = await GetUserInfo()
                const data = getResponseData(res) || {}
                profile.nickName = getField(data, 'NickName', 'nickName') || ''
            } catch (error) {
                console.error('GetUserInfo failed', error)
            }
        }
        const loadIdentity = async () => {
            try {
                const res = await GetUserIdentity()
                const data = getResponseData(res) || {}
                identityType.value = getField(data, 'IdentityType', 'identityType') || 0
            } catch (error) {
                console.error('GetUserIdentity failed', error)
            }
        }
        const loadSummary = async () => {
            try {
                const res = await GetValidSummary()
                const data = getResponseData(res) || {}
                summary.customerCount = toCount(getField(data, 'ValidCustomerCount', 'validCustomerCount'))
                summary.taskCount = toCount(getField(data, 'ValidTaskCount', 'validTaskCount'))
            } catch (error) {
                console.error('GetValidSummary failed', error)
                summary.customerCount = 0
                summary.taskCount = 0
            }
        }

        const goTo = (path, queryObj = {}) => {
            if (window.bjsdk && typeof window.bjsdk.goTo === 'function') {
                window.bjsdk.goTo(path, {
                    append: queryObj,
                })
                return
            }
            router.push({ path, query: queryObj })
        }
        const goProfile = () => goTo('/user', { from: 'userCenter' })
        const goIdentity = () => goTo('/user/identity')
        const goCustomerList = () => goTo('/customerList')
        const goTaskList = () => goTo('/tasks')

        onMounted(() => {
            loadUserInfo()
            loadIdentity()
            loadSummary()
        })

        return {
            isPc,
            pageTitle,
            profile,
            summary,
            identityLabel,
            displayName,
            avatarText,
            goProfile,
            goIdentity,
            goCustomerList,
            goTaskList,
        }
    },
}
</script>

