Read this block in `src/views/home/index.vue` and verify the auto-`blur()` happens only inside `bindKeyboardViewportResize()`:

```js
const bindKeyboardViewportResize = () => {
    if (!window.visualViewport || keyboardViewportResizeHandler) return
    lastKnownViewportHeight = window.visualViewport.height
    keyboardViewportResizeHandler = () => {
        if (keyboardViewportResizeRaf !== null) {
            cancelAnimationFrame(keyboardViewportResizeRaf)
        }
        keyboardViewportResizeRaf = requestAnimationFrame(() => {
            keyboardViewportResizeRaf = null

            const currentHeight = window.visualViewport.height
            const totalHeight = window.innerHeight

