<file path="src/components/markdown/markdownConf.js">
/**
 * markdown 初始化相关配置 
 * @returns 
 */
import MarkdownIt from "markdown-it";
import MarkdownItHighlightjs from "markdown-it-highlightjs"
import MarkdownItAbbr from "markdown-it-abbr";
import MarkdownItFootnote from "markdown-it-footnote";
import multimdTable from "markdown-it-multimd-table"
import MarkdownItSub from "markdown-it-sub";
import MarkdownItSup from "markdown-it-sup";
import MarkdownItTasklists from "markdown-it-task-lists";
import MarkdownItTOC from "markdown-it-toc-done-right";
import MarkdownItContainer from "markdown-it-container";
import { Toast } from 'vant'
import hljs from 'highlight.js';
import 'highlight.js/styles/atom-one-dark.css';
import { AddUserOperationLog } from '@/api/user'

const STRUCTURED_DATA_BLOCK_RE = /<!--STRUCTURED_DATA_START-->[\s\S]*?<!--STRUCTURED_DATA_END-->/g
const STRUCTURED_DATA_START = '<!--STRUCTURED_DATA_START-->'

/** 去掉已完整的结构化注释块（与 markdown 渲染前过滤一致） */
export function stripStructuredDataFromText(text) {
    if (!text || typeof text !== 'string') return text
    return text.replace(STRUCTURED_DATA_BLOCK_RE, '')
}

/**
 * 流式拼接过程中：完整块直接剔除；已出现起始标记但未闭合则整段隐藏；
 * 末尾若可能是 <!--STRUCTURED_DATA_START--> 的前缀则暂不展示，避免打字机露出半段注释。
 */
export function getStreamingVisibleForStructuredData(raw) {
    if (!raw || typeof raw !== 'string') return ''
    let s = raw.replace(STRUCTURED_DATA_BLOCK_RE, '')
    const startIdx = s.indexOf(STRUCTURED_DATA_START)
    if (startIdx !== -1) {
        s = s.slice(0, startIdx)
    }
    const maxLen = Math.min(s.length, STRUCTURED_DATA_START.length)
    let ambiguousLen = 0
    for (let len = maxLen; len >= 1; len--) {
        const suf = s.slice(s.length - len)
        if (STRUCTURED_DATA_START.startsWith(suf)) {
            ambiguousLen = len
            break
        }
    }
    if (ambiguousLen > 0) {
        s = s.slice(0, s.length - ambiguousLen)
    }
    return s
}

/**
 * 预处理：将 #tag1 #tag2 形式的行中的 # 转义，避免被解析为 ATX 标题
 */
function preprocessTagLines(text) {
    if (!text || typeof text !== 'string') return text
    return text.split('\n').map((line) => {
        const prefixMatch = line.match(/^(\s*(?:>\s*)*)/)
        const prefix = prefixMatch ? prefixMatch[1] : ''
        const content = line.slice(prefix.length)

        // 保留标准标题（### 标题）不处理
        if (/^#{1,6}\s/.test(content)) return line

        // 处理 #标签 形式：将 # 后文本转成可渲染标签片段
        if (/^#\S+(?:\s+#\S+)*\s*$/.test(content)) {
            const tagTextList = content
                .split(/\s+/)
                .filter(Boolean)
                .map((item) => item.replace(/^#/, ''))
                .filter(Boolean)
            return `${prefix}${tagTextList.map((item) => `<span class="markdown_tag_item">${item}</span>`).join(' ')}`
        }

        return line
    }).join('\n')
}

/**
 * 预处理：将 1）2）等全角括号转为 1. 2. 以正确解析为有序列表
 */
function preprocessOrderedList(text) {
    if (!text || typeof text !== 'string') return text
    return text.replace(/^(\d+)）\s*/gm, '$1. ')
}

/**
 * 预处理：还原被转义的加粗标记 \*\*text\*\*
 */
function preprocessEscapedStrong(text) {
    if (!text || typeof text !== 'string') return text
    return text
        .replace(/\\\*\\\*([\s\S]*?)\\\*\\\*/g, '**$1**')
        .replace(/\\\*\\\*/g, '**')
}
/**
 * 预处理：过滤结构化数据注释块（含包裹标记）
 */
function preprocessStructuredData(text) {
    return stripStructuredDataFromText(text)
}

let markdownCopyDelegationBound = false
let markdownCopyMeasureTimer = null
function getCurrentCustomerId() {
    if (typeof window === 'undefined') return ''
    try {
        if (window.bjsdk && typeof window.bjsdk.query === 'function') {
            const bySdk = window.bjsdk.query('CustomerId') || window.bjsdk.query('customerId')
            if (bySdk) return `${bySdk}`.trim()
        }
        if (window.location && typeof window.location.search === 'string') {
            const params = new URLSearchParams(window.location.search || '')
            const byUrl = params.get('CustomerId') || params.get('customerId')
            if (byUrl) return `${byUrl}`.trim()
        }
    } catch (e) {
        return ''
    }
    return ''
}
function logCopyOperation(text) {
    if (!text) return
    // 仅记录操作，不阻塞复制流程，也不依赖返回结果
    AddUserOperationLog({
        operationType: 1,
        operationContent: text,
        customerId: getCurrentCustomerId() || '',
    }).catch(() => {})
}
function getContainerAttr(info, name) {
    if (!info || !name) return ''
    const attrReg = new RegExp(`${name}\\s*=\\s*(?:"([^"]*)"|'([^']*)'|(\\S+))`)
    const match = info.match(attrReg)
    return match ? (match[1] || match[2] || match[3] || '') : ''
}
function isContainerName(info, name) {
    return ((info || '') + '').trim().split(/\s+/)[0] === name
}
function isTruthyAttr(value) {
    return `${value || ''}`.toLowerCase() === 'true'
}
function getCopyTextFromElement(el) {
    if (!el) return ''
    if (typeof document === 'undefined' || !document.body || !el.cloneNode) {
        return ((el.innerText || el.textContent || '') + '').trim()
    }
    const clone = el.cloneNode(true)
    clone.querySelectorAll('button,.markdown_tab_actions,.markdown_copy_foot').forEach((item) => {
        item.parentNode && item.parentNode.removeChild(item)
    })
    clone.style.position = 'fixed'
    clone.style.left = '-9999px'
    clone.style.top = '-9999px'
    clone.style.width = `${el.offsetWidth || 320}px`
    clone.style.pointerEvents = 'none'
    document.body.appendChild(clone)
    const text = ((clone.innerText || clone.textContent || '') + '').trim()
    document.body.removeChild(clone)
    return text
}
function copyMarkdownText(text) {
    if (!text) return
    logCopyOperation(text)
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(() => {
            Toast('复制成功')
        }).catch(() => {
            Toast('复制失败')
        })
    } else {
        Toast('当前环境不支持复制')
    }
}
function scheduleMarkdownCopyMeasure(root) {
    if (typeof document === 'undefined') return
    if (markdownCopyMeasureTimer) return
    const run = () => {
        markdownCopyMeasureTimer = null
        measureMarkdownCopyBlocks(root || document)
    }
    if (typeof window !== 'undefined' && window.requestAnimationFrame) {
        markdownCopyMeasureTimer = window.requestAnimationFrame(run)
    } else {
        markdownCopyMeasureTimer = setTimeout(run, 16)
    }
}
function measureMarkdownCopyBlocks(root) {
    if (!root || !root.querySelectorAll) return
    root.querySelectorAll('.markdown_copy_block[data-copy-lines]').forEach((block) => {
        const body = block.querySelector('.markdown_copy_body')
        const toggleBtn = block.querySelector('.markdown_copy_toggle')
        if (!body || !toggleBtn || body.offsetParent === null) return
        const maxHeight = parseFloat(block.style.getPropertyValue('--markdown-copy-max-height')) || 0
        const needsToggle = maxHeight > 0 && body.scrollHeight > maxHeight + 1
        block.classList.remove('is_toggle_pending')
        if (!needsToggle) {
            block.classList.add('is_toggle_hidden')
            block.classList.remove('is_collapsed', 'is_expanded')
            toggleBtn.innerText = '展开'
            toggleBtn.setAttribute('aria-expanded', 'false')
            return
        }
        block.classList.remove('is_toggle_hidden')
        if (!block.classList.contains('is_expanded')) {
            block.classList.add('is_collapsed')
        }
    })
}
function bindMarkdownCopyDelegation() {
    if (typeof document === 'undefined' || markdownCopyDelegationBound) return
    markdownCopyDelegationBound = true
    const onCopyClick = (e) => {
        const el = e.target
        if (!el || !el.closest) return
        const tabBtn = el.closest('.markdown_tab_btn')
        if (tabBtn) {
            e.preventDefault()
            e.stopPropagation()
            const block = tabBtn.closest('.markdown_tabs_block')
            if (!block) return
            const index = tabBtn.getAttribute('data-tab-index')
            block.querySelectorAll('.markdown_tab_btn').forEach((item) => {
                if (item.closest('.markdown_tabs_block') !== block) return
                const active = item.getAttribute('data-tab-index') === index
                item.classList.toggle('is_active', active)
                item.setAttribute('aria-selected', active ? 'true' : 'false')
            })
            block.querySelectorAll('.markdown_tab_pane').forEach((item) => {
                if (item.closest('.markdown_tabs_block') !== block) return
                item.classList.toggle('is_active', item.getAttribute('data-tab-index') === index)
            })
            scheduleMarkdownCopyMeasure(block)
            return
        }
        const tabCopyBtn = el.closest('.markdown_tab_copy_btn')
        if (tabCopyBtn) {
            e.preventDefault()
            e.stopPropagation()
            const pane = tabCopyBtn.closest('.markdown_tab_pane')
            const body = pane && pane.querySelector('.markdown_tab_content')
            const text = getCopyTextFromElement(body)
            copyMarkdownText(text)
            return
        }
        const toggleBtn = el.closest('.markdown_copy_toggle')
        if (toggleBtn) {
            e.preventDefault()
            e.stopPropagation()
            const block = toggleBtn.closest('.markdown_copy_block')
            if (!block) return
            const expanded = block.classList.toggle('is_expanded')
            block.classList.toggle('is_collapsed', !expanded)
            toggleBtn.innerText = expanded ? '收起' : '展开'
            toggleBtn.setAttribute('aria-expanded', expanded ? 'true' : 'false')
            return
        }
        const btn = el.closest('.markdown_copy_btn')
        if (!btn) return
        e.preventDefault()
        e.stopPropagation()
        const block = btn.closest('.markdown_copy_block')
        const body = block && block.querySelector('.markdown_copy_body')
        const text = getCopyTextFromElement(body)
        if (!text) return
        copyMarkdownText(text)
    }
    document.addEventListener('click', onCopyClick, true)
    if (typeof MutationObserver !== 'undefined') {
        const observer = new MutationObserver(() => scheduleMarkdownCopyMeasure(document))
        observer.observe(document.body || document.documentElement, {
            childList: true,
            subtree: true,
        })
    }
    if (typeof window !== 'undefined') {
        window.addEventListener('resize', () => scheduleMarkdownCopyMeasure(document))
    }
    scheduleMarkdownCopyMeasure(document)
}

export const MarkdownConfig = ()=>{
    const markdown = new MarkdownIt({
        html: true,
        linkify: true,
        break: true,
        typographer: true,
        highlight: function (code, lang) {
            if (lang && hljs.getLanguage(lang)) {
                return hljs.highlight(code, { language: lang }).value;
            }
            return hljs.highlightAuto(code).value;
        }
    }).use(MarkdownItHighlightjs).use(multimdTable).use(MarkdownItAbbr).use(MarkdownItFootnote).use(MarkdownItSub)
        .use(MarkdownItSup)
        .use(MarkdownItTasklists, {
            enabled: false,
            label: false,
            labelAfter: false,
        })
        .use(MarkdownItTOC)

    const copyContainerLinesStack = []
    const renderCopyContainer = function (tokens, idx) {
        const token = tokens[idx]
        if (token.nesting === 1) {
            const info = ((token.info || '') + '').trim()
            const titleMatch = info.match(/title\s*=\s*"([^"]*)"/) || info.match(/title\s*=\s*'([^']*)'/)
            const linesMatch = info.match(/lines\s*=\s*"(\d+)"/) || info.match(/lines\s*=\s*'(\d+)'/) || info.match(/lines\s*=\s*(\d+)/)
            const title = (titleMatch && titleMatch[1]) ? titleMatch[1] : '参考话术'
            const titleEsc = markdown.utils.escapeHtml(title)
            const lines = linesMatch && Number(linesMatch[1]) > 0 ? Number(linesMatch[1]) : 0
            copyContainerLinesStack.push(Boolean(lines))
            const collapseClass = lines ? ' is_collapsed is_toggle_pending' : ''
            const linesStyle = lines ? ` style="--markdown-copy-max-height:${(lines * 23.1 + 28).toFixed(1)}px;"` : ''
            const linesAttr = lines ? ` data-copy-lines="${lines}"` : ''
            return `<div class="markdown_copy_block${collapseClass}"${linesStyle}${linesAttr}><div class="markdown_copy_head"><span class="markdown_copy_title">${titleEsc}</span><button type="button" class="markdown_copy_btn">复制</button></div><div class="markdown_copy_body">\n`
        }
        const hasLines = copyContainerLinesStack.pop()
        const footer = hasLines ? `<div class="markdown_copy_foot"><button type="button" class="markdown_copy_toggle" aria-expanded="false">展开</button></div>` : ''
        return `</div>${footer}</div>\n`
    }
    markdown.use(MarkdownItContainer, 'copy', {
        validate: (params) => isContainerName(params, 'copy'),
        render: renderCopyContainer,
    })
    markdown.use(MarkdownItContainer, '复制', {
        validate: (params) => isContainerName(params, '复制'),
        render: renderCopyContainer,
    })

    const tabsRenderStack = []
    const collectTabInfos = function (tokens, idx) {
        const list = []
        let nestedTabs = 0
        for (let i = idx + 1; i < tokens.length; i++) {
            const item = tokens[i]
            if (item.type === 'container_tabs_open') {
                nestedTabs++
                continue
            }
            if (item.type === 'container_tabs_close') {
                if (nestedTabs === 0) break
                nestedTabs--
                continue
            }
            if (nestedTabs === 0 && item.type === 'container_tab_open') {
                const info = ((item.info || '') + '').trim()
                const title = getContainerAttr(info, 'title') || `页签${list.length + 1}`
                list.push({
                    title,
                    active: isTruthyAttr(getContainerAttr(info, 'active')),
                })
            }
        }
        return list
    }
    const renderTabsContainer = function (tokens, idx) {
        const token = tokens[idx]
        if (token.nesting === 1) {
            const info = ((token.info || '') + '').trim()
            const title = getContainerAttr(info, 'title')
            const titleHtml = title ? `<div class="markdown_tabs_title">${markdown.utils.escapeHtml(title)}</div>` : ''
            const tabs = collectTabInfos(tokens, idx)
            const activeIndex = Math.max(0, tabs.findIndex((item) => item.active))
            tabsRenderStack.push({ activeIndex, nextIndex: 0 })
            const navHtml = tabs.map((item, index) => {
                const active = index === activeIndex
                const titleEsc = markdown.utils.escapeHtml(item.title)
                return `<button type="button" class="markdown_tab_btn${active ? ' is_active' : ''}" role="tab" data-tab-index="${index}" aria-selected="${active ? 'true' : 'false'}">${titleEsc}</button>`
            }).join('')
            return `<div class="markdown_tabs_block">${titleHtml}<div class="markdown_tabs_nav" role="tablist">${navHtml}</div><div class="markdown_tabs_panes">\n`
        }
        tabsRenderStack.pop()
        return `</div></div>\n`
    }
    const renderTabContainer = function (tokens, idx) {
        const token = tokens[idx]
        if (token.nesting === 1) {
            const info = ((token.info || '') + '').trim()
            const tabsState = tabsRenderStack[tabsRenderStack.length - 1] || { activeIndex: 0, nextIndex: 0 }
            const index = tabsState.nextIndex++
            const active = index === tabsState.activeIndex
            const copyable = isTruthyAttr(getContainerAttr(info, 'copy'))
            const copyHtml = copyable ? `<div class="markdown_tab_actions"><button type="button" class="markdown_tab_copy_btn">复制本页</button></div>` : ''
            return `<div class="markdown_tab_pane${active ? ' is_active' : ''}" data-tab-index="${index}" role="tabpanel">${copyHtml}<div class="markdown_tab_content">\n`
        }
        return `</div></div>\n`
    }
    markdown.use(MarkdownItContainer, 'tabs', {
        validate: (params) => isContainerName(params, 'tabs'),
        render: renderTabsContainer,
    })
    markdown.use(MarkdownItContainer, 'tab', {
        validate: (params) => isContainerName(params, 'tab'),
        render: renderTabContainer,
    })

    bindMarkdownCopyDelegation()

    // 自定义列表样式
    markdown.renderer.rules.list_item_open = function (tokens, idx, options, env, self) {
        const token = tokens[idx]
        const className = token.attrGet('class')
        token.attrSet('class', className ? `${className} my-custom-list-item` : 'my-custom-list-item')
        return self.renderToken(tokens, idx, options)
    }
    markdown.renderer.rules.list_item_close = function (tokens, idx, options, env, self) {
        return '</li>'
    }
    markdown.renderer.rules.strong_open = function (tokens, idx, options, env, self) {
        return `<strong class="my-bold-text">`
    }
    markdown.renderer.rules.strong_close = function (tokens, idx, options, env, self) {
        return '</strong>'
    }
    markdown.renderer.rules.code_inline = function (tokens, idx) {
        const token = tokens[idx]
        const tagText = markdown.utils.escapeHtml((token.content || '').trim())
        if (!tagText) return ''
        return `<span class="markdown_tag_item">${tagText}</span>`
    }

    const originalRender = markdown.render.bind(markdown)
    const renderTabsHtml = function (info, tabs) {
        if (!tabs.length) return ''
        const title = getContainerAttr(info, 'title')
        const titleHtml = title ? `<div class="markdown_tabs_title">${markdown.utils.escapeHtml(title)}</div>` : ''
        const activeIndex = Math.max(0, tabs.findIndex((item) => item.active))
        const navHtml = tabs.map((item, index) => {
            const active = index === activeIndex
            const titleEsc = markdown.utils.escapeHtml(item.title || `页签${index + 1}`)
            return `<button type="button" class="markdown_tab_btn${active ? ' is_active' : ''}" role="tab" data-tab-index="${index}" aria-selected="${active ? 'true' : 'false'}">${titleEsc}</button>`
        }).join('')
        const panesHtml = tabs.map((item, index) => {
            const active = index === activeIndex
            const copyHtml = item.copyable ? `<div class="markdown_tab_actions"><button type="button" class="markdown_tab_copy_btn">复制本页</button></div>` : ''
            const contentHtml = originalRender(preprocessTabs(item.content))
            return `<div class="markdown_tab_pane${active ? ' is_active' : ''}" data-tab-index="${index}" role="tabpanel">${copyHtml}<div class="markdown_tab_content">\n${contentHtml}</div></div>`
        }).join('')
        return `<div class="markdown_tabs_block">${titleHtml}<div class="markdown_tabs_nav" role="tablist">${navHtml}</div><div class="markdown_tabs_panes">${panesHtml}</div></div>`
    }
    const parseTabsBlock = function (lines, startIndex) {
        const startLine = lines[startIndex]
        const startMatch = startLine && startLine.match(/^\s*:::\s*tabs\b(.*)$/)
        if (!startMatch) return null
        const tabsInfo = startLine.trim()
        const tabs = []
        let i = startIndex + 1
        const closeRe = /^\s*:::\s*$/
        const tabStartRe = /^\s*:::\s*tab\b/
        const nestedContainerStartRe = /^\s*:::\s*(?!tab\b|tabs\b)\S+/
        while (i < lines.length) {
            const line = lines[i]
            if (closeRe.test(line)) {
                i++
                break
            }
            if (!tabStartRe.test(line)) {
                i++
                continue
            }
            const tabInfo = line.trim()
            const contentLines = []
            let nestedContainerCount = 0
            i++
            while (i < lines.length) {
                const contentLine = lines[i]
                if (nestedContainerCount === 0 && tabStartRe.test(contentLine)) break
                if (nestedContainerCount === 0 && closeRe.test(contentLine)) {
                    i++
                    break
                }
                contentLines.push(contentLine)
                if (nestedContainerCount > 0 && closeRe.test(contentLine)) {
                    nestedContainerCount--
                } else if (nestedContainerStartRe.test(contentLine)) {
                    nestedContainerCount++
                }
                i++
            }
            tabs.push({
                title: getContainerAttr(tabInfo, 'title'),
                active: isTruthyAttr(getContainerAttr(tabInfo, 'active')),
                copyable: isTruthyAttr(getContainerAttr(tabInfo, 'copy')),
                content: contentLines.join('\n'),
            })
        }
        if (!tabs.length) return null
        return {
            html: renderTabsHtml(tabsInfo, tabs),
            nextIndex: i,
        }
    }
    const preprocessTabs = function (src) {
        if (!src || typeof src !== 'string' || src.indexOf(':::tabs') === -1) return src
        const lines = src.split('\n')
        const output = []
        for (let i = 0; i < lines.length;) {
            const parsed = parseTabsBlock(lines, i)
            if (parsed) {
                output.push(parsed.html)
                i = parsed.nextIndex
            } else {
                output.push(lines[i])
                i++
            }
        }
        return output.join('\n')
    }
    markdown.render = function (src) {
        const processed = preprocessEscapedStrong(
            preprocessOrderedList(preprocessTagLines(preprocessStructuredData(src)))
        )
        return originalRender(preprocessTabs(processed))
    }

    return markdown
}
