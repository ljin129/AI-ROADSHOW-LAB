        justify-content: flex-end;
        padding: 0 16px 14px;
    }

    :deep(.markdown_copy_block.is_toggle_pending .markdown_copy_foot),
    :deep(.markdown_copy_block.is_toggle_hidden .markdown_copy_foot) {
