        svg {
            display: block;
            width: 14px;
            height: 14px;
        }

        &.is_active {
            opacity: 1;
        }

        &:active {
            opacity: 0.5;
        }
    }

    .voice_bar_text_content {
        margin-top: 6px;
        font-size: 13px;
        line-height: 1.45;
        opacity: 0.9;
        padding-top: 6px;
        border-top: 1px solid rgba(255, 255, 255, 0.15);
        background: transparent;
    }

    .voice_bar_label {
        flex-shrink: 0;
        font-size: 10px;
        line-height: 16px;
        padding: 0 5px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        color: inherit;
    }

    .voice_bar_collapsed_wave {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: 2px;
        margin-left: 4px;
        opacity: 0.72;
