export default {
    name: 'UserGuide',
    components: {
        PageHead,
    },
    setup() {
        const router = useRouter()
        const sdk = window.bjsdk || {}
        const isPc = ref((sdk.isWinPC || sdk.isMac) && !sdk.isWM)
        const pageTitle = ref(document.title || '使用引导')
        const currentStep = ref(0)
        const activeExample = ref('')
        const scriptRef = ref(null)
        const scriptExpanded = ref(false)
        const scriptCanToggle = ref(false)
        const activeDeepStrategyIndex = ref(0)
        const activeBackupStrategyIndex = ref(0)
        const activeExampleData = computed(() => demoExamples[activeExample.value] || {})
        const activeDeepStrategies = computed(() => activeExampleData.value.deepStrategies || [])
        const activeDeepStrategy = computed(() => {
            return activeDeepStrategies.value[activeDeepStrategyIndex.value] || activeDeepStrategies.value[0] || {}
        })
        const activeBackupStrategies = computed(() => activeExampleData.value.backupStrategies || [])
        const activeBackupStrategy = computed(() => {
            return activeBackupStrategies.value[activeBackupStrategyIndex.value] || activeBackupStrategies.value[0] || {}
        })
        const activeInsightFocusTags = computed(() => splitInsightTags(activeDeepStrategy.value.insight && activeDeepStrategy.value.insight.focus))
        const activeInsightPressureTags = computed(() => splitInsightTags(activeDeepStrategy.value.insight && activeDeepStrategy.value.insight.pressure))
        const activeInsightBehaviors = computed(() => getInsightBehaviors(activeDeepStrategy.value.insight && activeDeepStrategy.value.insight.behavior))

        const updateScriptToggle = () => {
            const el = scriptRef.value
            if (!el) {
                scriptCanToggle.value = false
                return
            }
            const lineHeight = parseFloat(window.getComputedStyle(el).lineHeight) || 0
            scriptCanToggle.value = lineHeight ? el.scrollHeight > lineHeight * 4 + 1 : false
            if (!scriptCanToggle.value) {
                scriptExpanded.value = false
            }
        }

        const copyText = async (text) => {
            if (!text) {
                Toast('暂无可复制内容')
                return
            }
            try {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(text)
                } else {
                    const textarea = document.createElement('textarea')
                    textarea.value = text
                    textarea.setAttribute('readonly', 'readonly')
                    textarea.style.position = 'fixed'
                    textarea.style.left = '-9999px'
                    document.body.appendChild(textarea)
                    textarea.select()
                    document.execCommand('copy')
                    document.body.removeChild(textarea)
                }
                Toast('复制成功')
            } catch (error) {
                Toast('复制失败')
            }
        }

        const copyStrategy = (strategy) => {
            copyText(getStrategyCopyText(strategy))
        }

        const copyScript = () => {
            copyText(activeExampleData.value.script || '')
        }

        const openExample = (key) => {
            scriptExpanded.value = false
            scriptCanToggle.value = false
            activeDeepStrategyIndex.value = 0
            activeBackupStrategyIndex.value = 0
            activeExample.value = key
            nextTick(updateScriptToggle)
        }

        const closeExample = () => {
            activeExample.value = ''
            scriptExpanded.value = false
            scriptCanToggle.value = false
            activeDeepStrategyIndex.value = 0
            activeBackupStrategyIndex.value = 0
        }

        const handleNext = () => {
            if (currentStep.value < 2) {
                currentStep.value += 1
                return
            }
            if (window.bjsdk && typeof window.bjsdk.goTo === 'function') {
                window.bjsdk.goTo('/home', {})
                return
            }
            router.replace('/home')
        }

        return {
            isPc,
            pageTitle,
            currentStep,
            painItems,
            resultItems,
            readyItems,
            startExamples,
            activeExample,
            activeExampleData,
            scriptRef,
            scriptExpanded,
            scriptCanToggle,
            activeDeepStrategyIndex,
            activeDeepStrategies,
            activeDeepStrategy,
            activeBackupStrategyIndex,
            activeBackupStrategies,
            activeBackupStrategy,
            activeInsightFocusTags,
            activeInsightPressureTags,
            activeInsightBehaviors,
            copyScript,
            copyStrategy,
            openExample,
            closeExample,
            handleNext,
        }
    },
}
