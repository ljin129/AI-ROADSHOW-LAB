const getAudioUri = (item) => {
  if (item && item.content_type === 'audio_attachment') return item.audio_data_url || ''
  return (item && item.audio_url) || ''
}

const getAudioText = (item) => {
  if (item && item.content_type === 'audio_attachment') return ''
  return (item && item.audio_text) || ''
