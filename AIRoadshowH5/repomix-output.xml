const getAudioDuration = (item) => {
  if (item && item.content_type === 'audio_attachment' && item.audio_data_payload && item.audio_data_payload.duration_ms) {
    return item.audio_data_payload.duration_ms
  }
  if (item && item.audio_payload && item.audio_payload.duration_ms) {
    return item.audio_payload.duration_ms
  }
  return 0
}

const getAudioPayload = (item) => {
  if (item && item.content_type === 'audio_attachment') return item.audio_data_payload || {}
  return (item && item.audio_payload) || {}
