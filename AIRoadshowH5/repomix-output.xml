            historyPullStartY = e.touches[0].clientY
            historyPulling = true
            historyPullDistance.value = 0
        }
        const onHistoryPullTouchMove = (e) => {
            if (!historyPulling || !e || !e.touches || !e.touches.length) return
            const el = getScrollTargetDom('#contentArea')
            if (!el || el.scrollTop > 0) {
                resetHistoryPullState()
                return
            }
            const delta = e.touches[0].clientY - historyPullStartY
            if (delta <= 0) {
                historyPullDistance.value = 0
                return
            }
            e.preventDefault()
            historyPullDistance.value = Math.min(HISTORY_PULL_MAX_DISTANCE, delta * 0.45)
        }
        const onHistoryPullTouchEnd = async () => {
            if (!historyPulling) {
                resetHistoryPullState()
                return
            }
