        let isStoped = true // 微信小程序停止录音成功标记，只有当停止录音了，才能开启新的录音
		let tochDelay = false // 增加touch延迟，500ms内只允许点击长按一次
        let  outTimer = null
        let handleLongEnd = false // 是否结束长按，为了做快速点击的边界值判断
        let voiceFinalResultHandled = false
        const onVoiceTouchStart = (e) => {
