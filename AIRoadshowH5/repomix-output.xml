    .content_area {
        position: relative;
        flex: 1;
        min-height: 0;
        overflow-y: hidden;
        overflow-x: hidden;
        background: #ffffff;
        padding: 0 12px 0;

        .example_shadow {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
