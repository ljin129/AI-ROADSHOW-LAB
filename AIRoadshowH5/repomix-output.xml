<template>
    <div class="list_container">
        <div class="list_header">
            <div class="list_header_title">我的关系</div>
            <div class="list_header_count">共 {{ list.length }} 条</div>
        </div>
        <div v-if="list.length === 0" class="list_empty">
            <div class="list_empty_text">暂无关系数据</div>
            <div class="list_empty_tip">点击下方按钮新增关系</div>
        </div>
        <div v-else class="list_content">
            <div
                v-for="(item, index) in list"
                :key="index"
                class="list_card"
            >
                <div class="list_card_header">
                    <div class="list_card_name">{{ item.relationName }}</div>
                    <div class="list_card_delete" @click="onDelete(index)">删除</div>
                </div>
                <div class="list_card_row">
                    <span class="list_card_label">手机号码：</span>
                    <span class="list_card_value">{{ item.mobile }}</span>
                </div>
                <div class="list_card_row">
                    <span class="list_card_label">关系现状：</span>
                    <span class="list_card_value list_card_value_multi">{{ item.currentStatus }}</span>
                </div>
                <div class="list_card_row">
                    <span class="list_card_label">描述备注：</span>
                    <span class="list_card_value list_card_value_multi">{{ item.remark }}</span>
                </div>
                <div class="list_card_row">
                    <span class="list_card_label">未来预期：</span>
                    <span class="list_card_value list_card_value_multi">{{ item.futureExpectation }}</span>
                </div>
            </div>
        </div>
        <div class="list_actions">
            <van-button round block type="primary" @click="onAdd">
                新增关系
            </van-button>
        </div>
    </div>
</template>
<script>
import { ref, onMounted } from 'vue'
import { Button, Dialog, Toast } from 'vant'

const CACHE_KEY = 'pRelationList'

export default {
    components: {
        [Button.name]: Button
    },
    setup () {
        const list = ref([])

        function loadList () {
            try {
                const cache = localStorage.getItem(CACHE_KEY)
                const arr = cache ? JSON.parse(cache) : []
                list.value = Array.isArray(arr) ? arr : []
            } catch (e) {
                list.value = []
            }
        }

        function saveList () {
            localStorage.setItem(CACHE_KEY, JSON.stringify(list.value))
        }

        function onDelete (index) {
            Dialog.confirm({
                title: '提示',
                message: '确认删除该关系吗？'
            }).then(() => {
                list.value.splice(index, 1)
                saveList()
                Toast.success('删除成功')
            }).catch(() => {})
        }

        function onAdd () {
            window.bjsdk.goTo('/previewIndex', {})
        }

        onMounted(() => {
            loadList()
        })

        return {
            list,
            onDelete,
            onAdd
        }
    }
}
</script>
