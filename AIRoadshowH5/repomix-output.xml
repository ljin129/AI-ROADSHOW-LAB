<script>
import { ref, reactive, toRefs, onMounted, onUnmounted, computed } from 'vue'
import PageHead from '@/components/pageHead'
import { GetCustomerById, DeleteCustomer } from '@/api/custCustomer'
import { GetByCustomerId } from '@/api/custProfile'
import { MarkdownConfig } from '@/components/markdown/markdownConf.js'
import EmptyCustomerImg from '@/assets/img/home/add_customer_def.png'
import EmptyProfileImg from '@/assets/img/customer/customer_empty.png'

const TAG_COLOR_POOL = [
	{ bg: '#F8FAFC', text: '#64748B', border: '#E2E8F0' },
	{ bg: '#F7F9FF', text: '#5B6B9A', border: '#DCE4F7' },
	{ bg: '#F8FCF7', text: '#5E7D68', border: '#DDEBDF' },
	{ bg: '#FFF9F5', text: '#8B6B52', border: '#F1E1D4' },
	{ bg: '#FFF7FA', text: '#8B6278', border: '#F0DCE7' },
	{ bg: '#F6FBFB', text: '#5C7D80', border: '#D9EAEC' },
	{ bg: '#FAF8FF', text: '#6F658C', border: '#E5DFF3' },
]

export default {
	name: 'CustomerDetail',
	components: {
		PageHead,
	},
	setup() {
		const isPc = ref((window.bjsdk.isWinPC || window.bjsdk.isMac) && !window.bjsdk.isWM)
		const pageTitle = ref(document.title)

		const state = reactive({
			customer: {},
			profile: {},
			deleting: false,
			loaded: false,
			profileLoadingVisible: false,
		})

		let profileLoadingTimer = null

		const startProfileLoadingGuard = () => {
			stopProfileLoadingGuard()
			profileLoadingTimer = window.setTimeout(() => {
				state.profileLoadingVisible = true
			}, 500)
		}

		const stopProfileLoadingGuard = () => {
			if (profileLoadingTimer) {
				window.clearTimeout(profileLoadingTimer)
				profileLoadingTimer = null
			}
			state.profileLoadingVisible = false
		}

		const formatOrg = (c) => {
			const parts = [c.Industry, c.Company, c.Position].filter(Boolean)
			return parts.join(' • ')
		}

		const parseTags = (tagStr) => {
			if (!tagStr) return []
			try {
				const parsed = typeof tagStr === 'string' ? JSON.parse(tagStr) : tagStr
				if (Array.isArray(parsed)) return parsed
			} catch (e) {
				return []
			}
			return []
		}

		const loadData = async () => {
			const customerId = window.bjsdk.query('CustomerId')
			if (!customerId) {
				state.loaded = true
				return
			}

			try {
				startProfileLoadingGuard()

				const customerPromise = GetCustomerById({ customerId }).then((customerRes) => {
					state.customer = {
						...(customerRes.Data || {}),
					}
					return customerRes
				})
				const profilePromise = GetByCustomerId({ customerId })
					.then((profileRes) => {
						state.profile = {
							...(profileRes.Data || {}),
						}
						return profileRes
					})
					.finally(() => {
						stopProfileLoadingGuard()
					})

				const [customerResult, profileResult] = await Promise.allSettled([customerPromise, profilePromise])
				if (customerResult.status === 'rejected') {
					console.error(customerResult.reason)
				}
				if (profileResult.status === 'rejected') {
					console.error(profileResult.reason)
				}
			} catch (error) {
				console.error(error)
			} finally {
				stopProfileLoadingGuard()
				state.loaded = true
			}
		}

		const markdown = MarkdownConfig()
		const hasProfileContent = computed(() => {
			return !!`${state.profile && state.profile.ProfileContent ? state.profile.ProfileContent : ''}`.trim()
		})

		const getCustomerId = () => state.customer.CustomerId || window.bjsdk.query('CustomerId') || ''
		const getSessionId = () => state.customer.SessionId || ''

		const goEdit = () => {
			const customerId = getCustomerId()
			if (!customerId) return
			window.bjsdk.goTo('/customerEdit', {
				append: {
					CustomerId: customerId,
				},
			})
		}

		const goBusiness = () => {
			const customerId = getCustomerId()
			if (!customerId) return
			window.bjsdk.goTo('/home', {
				append: {
					customerId,
					sessionId: getSessionId(),
				},
			})
		}

		const onDelete = async () => {
			const customerId = getCustomerId()
			if (!customerId || state.deleting) return
			const customerName = state.customer.Name || '该客户'
			const confirmed = window.confirm(`确认删除客户【${customerName}】吗？`)
			if (!confirmed) return
			try {
				state.deleting = true
				const res = await DeleteCustomer({ customerId })
				if (!(res && (res.Data === true || res.data === true))) {
					throw new Error('删除失败')
				}
				window.bjsdk.goTo('/customerList', {})
			} catch (error) {
				window.alert((error && (error.ErrorMessage || error.errorMessage || error.message)) || '删除失败')
			} finally {
				state.deleting = false
			}
		}

		onMounted(() => {
			loadData()
		})

		onUnmounted(() => {
			stopProfileLoadingGuard()
		})

		return {
			isPc,
			pageTitle,
			...toRefs(state),
			formatOrg,
			parseTags,
			tagColorPool: TAG_COLOR_POOL,
			emptyCustomerImg: EmptyCustomerImg,
			emptyProfileImg: EmptyProfileImg,
			hasProfileContent,
			markdown,
			goEdit,
			goBusiness,
			onDelete,
		}
	},
}
</script>

