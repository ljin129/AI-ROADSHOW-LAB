						<path d="M17 7l-10 10"></path>
					</svg>
				</button>
			</div>
		</section>
		<section class="customer-list-sum" :style="{ top: sumTop }" v-if="query">
			为您匹配到<span class="customer-list-sum-count">{{ total }}</span>位客户
		</section>
		<section class="customer-list-data" :class="[isPc ? 'pc_container' : '']" :style="{ paddingTop: listPaddingTop }">
			<van-pull-refresh v-model="refreshing" @refresh="onRefresh">
				<van-list
					v-model:loading="loading"
					:finished="finished"
					finished-text="没有更多了"
					@load="onLoad"
				>
					<div
						v-for="(c, cIndex) in customers"
						:key="c.CustomerId || `customer_${cIndex}`"
						class="list-card"
					>
						<div class="list-card-header">
							<div class="list-card-header-name">{{ c.Name }}</div>
							<span class="list-card-header-info" v-if="c.Gender || c.Age">{{ c.Gender ? c.Gender : '' }}{{ c.Gender && c.Age ? ' ' : '' }}{{ c.Age ? c.Age + '岁' : '' }}</span>
							<div class="list-card-more-wrap" @click.stop>
								<button class="list-card-more-btn" type="button" @click.stop="toggleMoreMenu(c)">
									<svg class="list-card-more-icon" viewBox="0 0 24 24" aria-hidden="true">
										<circle cx="6" cy="12" r="1.6"></circle>
										<circle cx="12" cy="12" r="1.6"></circle>
										<circle cx="18" cy="12" r="1.6"></circle>
									</svg>
								</button>
								<div v-if="activeMoreId === c.CustomerId" class="list-card-more-panel">
									<button class="list-card-more-item" type="button" @click.stop="onEditCustomer(c)">编辑</button>
									<button class="list-card-more-item is-delete" type="button" @click.stop="onDeleteCustomer(c)">删除</button>
								</div>
							</div>
						</div>
						<div class="list-card-meta">
							<div class="list-card-meta-contact" v-if="c.LastContactDate">最近联系：{{ c.LastContactDate }}</div>
							<div class="list-card-meta-org">{{ formatOrg(c) }}</div>
						</div>
						<div class="list-card-tag">
							<span
								v-for="(t, index) in parseTags(c.OtherTags).slice(0, c.Company || c.Position || c.Industry ? 3 : undefined)"
								:key="index"
								class="list-card-tag-item"
								:style="{
									backgroundColor: TAG_COLOR_POOL[index % TAG_COLOR_POOL.length].bg,
									color: TAG_COLOR_POOL[index % TAG_COLOR_POOL.length].text,
									border: '1px solid ' + TAG_COLOR_POOL[index % TAG_COLOR_POOL.length].border
								}"
							>
								{{ t.text || t }}
							</span>
						</div>
						<div class="list-card-desc-wrap" v-if="c.CommunicationSummary">
							<div
								v-if="isSummaryExpanded(c, cIndex) || !shouldShowSummaryToggle(c, cIndex)"
								class="list-card-desc"
								:ref="(el) => setSummaryRef(getSummaryKey(c, cIndex), el)"
							>
								{{ c.CommunicationSummary }}
							</div>
							<div
								v-else
								class="list-card-desc is-collapsed-inline"
								:ref="(el) => setSummaryRef(getSummaryKey(c, cIndex), el)"
							>
								<span class="list-card-desc-text">{{ getCollapsedSummary(c, cIndex) }}</span><button
									type="button"
									class="list-card-desc-toggle is-inline-tail"
									@click.stop="expandSummary(c, cIndex)"
								>
									展开
								</button>
							</div>
						</div>
						<div class="list-card-actions">
							<button class="list-card-action list-card-action-detail" type="button" @click.stop="goDetail(c)">详情</button>
							<button class="list-card-action list-card-action-business" type="button" @click.stop="goBusiness(c)">继续经营</button>
						</div>
					</div>
				</van-list>
			</van-pull-refresh>
		</section>
	</div>
</template>

<script>
import { ref, reactive, toRefs, watch, computed, nextTick } from 'vue'
import pageHead from '@/components/pageHead'
import { GetCustomerByUserIdPaged, DeleteCustomer } from '@/api/custCustomer'
import { PullRefresh, List } from 'vant'

const TAG_COLOR_POOL = [
	{ bg: '#F8FAFC', text: '#64748B', border: '#E2E8F0' }, // slate
	{ bg: '#F7F9FF', text: '#5B6B9A', border: '#DCE4F7' }, // indigo
	{ bg: '#F8FCF7', text: '#5E7D68', border: '#DDEBDF' }, // green
	{ bg: '#FFF9F5', text: '#8B6B52', border: '#F1E1D4' }, // orange
	{ bg: '#FFF7FA', text: '#8B6278', border: '#F0DCE7' }, // rose
	{ bg: '#F6FBFB', text: '#5C7D80', border: '#D9EAEC' }, // cyan
	{ bg: '#FAF8FF', text: '#6F658C', border: '#E5DFF3' }, // purple
]

export default {
	name: 'CustomerList',
	components: {
		pageHead,
		[PullRefresh.name]: PullRefresh,
		[List.name]: List
	},
	setup() {
		const isPc = ref((window.bjsdk.isWinPC || window.bjsdk.isMac) && !window.bjsdk.isWM)
		const pageTitle = ref(document.title)
		const query = ref('')
		const activeMoreId = ref('')
		const deletingId = ref('')
		const summaryRefMap = ref({})
		const summaryExpandedMap = reactive({})
		const summaryOverflowMap = reactive({})
		const summaryCollapsedTextMap = reactive({})

		const state = reactive({
			customers: [],
			loading: false,
			finished: false,
			refreshing: false,
			pageIndex: 0,
			pageSize: 10,
			total: 0
		})

		const loadData = async () => {
			try {
				const params = {
					PageIndex: state.pageIndex,
					PageSize: state.pageSize,
					KeyWord: query.value,
					IncludeSessionId: true
				}
				const res = await GetCustomerByUserIdPaged(params)
				if (state.refreshing) {
					clearSummaryStates()
					state.customers = []
					state.refreshing = false
				}

				if (res.Data && res.Data.List) {
					state.customers.push(...res.Data.List)
					state.total = res.Data.TotalCount || 0
					syncSummaryOverflow()

					if (state.customers.length >= state.total || res.Data.List.length === 0) {
						state.finished = true
					}
				} else {
					state.finished = true
				}
			} catch (error) {
				state.finished = true
				console.error(error)
			} finally {
				state.loading = false
			}
		}

		const onLoad = () => {
			state.pageIndex++
			loadData()
		}

		const onRefresh = () => {
			state.finished = false
			state.loading = true
			state.pageIndex = 1
			clearSummaryStates()
			loadData()
		}

		let searchTimer = null
		const onSearch = () => {
			if (searchTimer) clearTimeout(searchTimer)
			activeMoreId.value = ''
			clearSummaryStates()
			state.customers = []
			state.finished = false
			state.loading = true
			state.refreshing = true
			state.pageIndex = 1
			loadData()
		}

		const onCancel = () => {
			query.value = ''
			onSearch()
		}

		const closeMoreMenu = () => {
			activeMoreId.value = ''
		}

		const toggleMoreMenu = (c) => {
			activeMoreId.value = activeMoreId.value === c.CustomerId ? '' : c.CustomerId
		}

		const formatOrg = (c) => {
			const parts = [c.Industry, c.Company, c.Position].filter(Boolean)
			return parts.join(' • ')
		}

		const parseTags = (tagStr) => {
			if (!tagStr) return []
			try {
				const parsed = JSON.parse(tagStr)
				if (Array.isArray(parsed)) return parsed
			} catch (e) {
				return []
			}
			return []
		}

		const getSummaryKey = (c, index = 0) => {
			return `${c.CustomerId || c.customerId || c.Id || c.id || index}`
		}

		const setSummaryRef = (key, el) => {
			if (!key) return
			if (el) summaryRefMap.value[key] = el
			else delete summaryRefMap.value[key]
		}

		const clearSummaryStates = () => {
			summaryRefMap.value = {}
			Object.keys(summaryExpandedMap).forEach((key) => {
				delete summaryExpandedMap[key]
			})
			Object.keys(summaryOverflowMap).forEach((key) => {
				delete summaryOverflowMap[key]
			})
			Object.keys(summaryCollapsedTextMap).forEach((key) => {
				delete summaryCollapsedTextMap[key]
			})
		}

		const measureSummaryOverflow = (text, el) => {
			if (!el || !text) {
				return { isOverflow: false, collapsedText: text || '' }
			}
			const style = window.getComputedStyle(el)
			const lineHeight = parseFloat(style.lineHeight) || 20
			const maxHeight = lineHeight * 2 + 1
			const measureEl = document.createElement('div')
			measureEl.style.position = 'fixed'
			measureEl.style.left = '-9999px'
			measureEl.style.top = '-9999px'
			measureEl.style.visibility = 'hidden'
			measureEl.style.pointerEvents = 'none'
			measureEl.style.boxSizing = 'border-box'
			measureEl.style.width = `${el.clientWidth || el.offsetWidth || 0}px`
			measureEl.style.fontSize = style.fontSize
			measureEl.style.fontWeight = style.fontWeight
			measureEl.style.lineHeight = style.lineHeight
			measureEl.style.letterSpacing = style.letterSpacing
			measureEl.style.whiteSpace = 'pre-wrap'
			measureEl.style.wordBreak = 'break-word'
			measureEl.textContent = text
			document.body.appendChild(measureEl)

			const isOverflow = measureEl.scrollHeight > maxHeight
			let collapsedText = text
			if (isOverflow) {
				let low = 0
				let high = text.length
				let best = 0
				while (low <= high) {
					const mid = Math.floor((low + high) / 2)
					measureEl.textContent = `${text.slice(0, mid)}...展开`
					if (measureEl.scrollHeight <= maxHeight) {
						best = mid
						low = mid + 1
					} else {
						high = mid - 1
					}
				}
				const safeBest = Math.max(0, best - 1)
				collapsedText = `${text.slice(0, safeBest).replace(/\s+$/g, '')}...`
			}
			document.body.removeChild(measureEl)
			return { isOverflow, collapsedText }
		}

		const syncSummaryOverflow = () => {
			nextTick(() => {
				state.customers.forEach((c, index) => {
					const key = getSummaryKey(c, index)
					const el = summaryRefMap.value[key]
					if (!el) return
					const text = ((c.CommunicationSummary || '') + '').trim()
					const { isOverflow, collapsedText } = measureSummaryOverflow(text, el)
					summaryOverflowMap[key] = isOverflow
					summaryCollapsedTextMap[key] = collapsedText
					if (!isOverflow && summaryExpandedMap[key]) {
						summaryExpandedMap[key] = false
					}
				})
			})
		}

		const isSummaryExpanded = (c, index) => {
			const key = getSummaryKey(c, index)
			return summaryExpandedMap[key] === true
		}

		const shouldShowSummaryToggle = (c, index) => {
			const key = getSummaryKey(c, index)
			return summaryOverflowMap[key] === true
		}

		const getCollapsedSummary = (c, index) => {
			const key = getSummaryKey(c, index)
			return summaryCollapsedTextMap[key] || c.CommunicationSummary || ''
		}

		const expandSummary = (c, index) => {
			const key = getSummaryKey(c, index)
			summaryExpandedMap[key] = true
		}

		watch(query, () => {
			if (searchTimer) clearTimeout(searchTimer)
			searchTimer = setTimeout(() => {
				onSearch()
			}, 500)
		})

		const listPaddingTop = computed(() => {
			let top = 16
			top += 66
			if (query.value) top += 46
			return top + 'px'
		})

		const searchTop = computed(() => {
			return isPc.value ? '65px' : '0px'
		})

		const sumTop = computed(() => {
			return isPc.value ? '131px' : '66px'
		})

		const onEditCustomer = (c) => {
			activeMoreId.value = ''
			window.bjsdk.goTo('/customerEdit', {
				append: {
					CustomerId: c.CustomerId,
				},
			})
		}

		const onDeleteCustomer = (c) => {
			activeMoreId.value = ''
			if (!c || !c.CustomerId) return
			if (deletingId.value) return

			const customerName = c.Name || '该客户'
			const confirmed = window.confirm(`确认删除客户【${customerName}】吗？`)
			if (!confirmed) return

			deletingId.value = c.CustomerId
			DeleteCustomer({
				customerId: c.CustomerId,
			})
				.then(() => {
					onSearch()
				})
				.catch((error) => {
					window.alert((error && (error.ErrorMessage || error.errorMessage || error.message)) || '删除失败')
				})
				.finally(() => {
					deletingId.value = ''
				})
		}

		const goDetail = (c) => {
			activeMoreId.value = ''
			window.bjsdk.goTo('/customerDetail', {
				append: {
					CustomerId: c.CustomerId,
				},
			})
		}

		const goBusiness = (c) => {
			activeMoreId.value = ''
			window.bjsdk.goTo('/home', {
				append: {
					customerId: c.CustomerId,
					sessionId: c.SessionId,
				},
			})
		}

		return {
			listPaddingTop,
			searchTop,
			sumTop,
			isPc,
			pageTitle,
			query,
			activeMoreId,
			...toRefs(state),
			onLoad,
			onRefresh,
			onSearch,
			onCancel,
			closeMoreMenu,
			toggleMoreMenu,
			onEditCustomer,
			onDeleteCustomer,
			goDetail,
			goBusiness,
			formatOrg,
			parseTags,
			getSummaryKey,
			setSummaryRef,
			isSummaryExpanded,
			shouldShowSummaryToggle,
			getCollapsedSummary,
			expandSummary,
			TAG_COLOR_POOL
		}
	},
}
</script>

