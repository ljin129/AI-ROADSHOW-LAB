    .voice_bar_collapsed_wave_line {
        display: block;
        width: 2px;
        border-radius: 999px;
        background: currentColor;

        &:nth-child(1) { height: 6px; }
        &:nth-child(2) { height: 10px; }
        &:nth-child(3) { height: 8px; }
        &:nth-child(4) { height: 5px; }
