<script>
import { computed, nextTick, ref } from 'vue'
import { useRouter } from 'vue-router'
import { Toast } from 'vant'
import PageHead from '@/components/pageHead'
import guideSl1 from '@/assets/img/user/guide_sl1.png'
import guideSl2 from '@/assets/img/user/guide_sl2.png'
import guideSl3 from '@/assets/img/user/guide_sl3.png'

const painItems = [
    {
        no: '01',
        title: '开口难',
        desc: '面对想推进的客户，拿不准什么时候联系、怎么开口。',
        image: guideSl1,
    },
    {
        no: '02',
        title: '记不住',
        desc: '刚刚聊完的重点细节和日期，转头就忘，后面跟进容易断档。',
        image: guideSl2,
    },
    {
        no: '03',
        title: '顾不过来',
        desc: '同时跟进多个客户，只靠脑子记，容易出错，也难分清轻重缓急。',
        image: guideSl3,
    },
]

const resultItems = [
    { label: '提醒', text: '跟进提醒已设置 · 下周一', type: 'blue' },
    { label: '信号', text: '识别到可推进的关系信号', type: 'green' },
    { label: '话术', text: '下一步沟通建议已生成', type: 'orange' },
]

const readyItems = [
    { text: '导入联系人清单', active: false },
    { text: '填写客户资料表', active: false },
    { text: '学习怎么使用', active: false },
    { text: '简单说几句话，直接开始', active: true },
]

const startExamples = [
    { key: 'potential', title: '刚认识的潜在客户', desc: '朋友饭局认识，想借留学和保障话题破冰' },
    { key: 'noReply', title: '客户没回复', desc: '方案发出两天未回，想低压自然跟进' },
]

const getStrategyCopyText = (strategy = {}) => {
    const lines = []
    if (strategy.title) {
        lines.push(strategy.title)
    }
    if (Array.isArray(strategy.items)) {
        lines.push(...strategy.items)
    }
    if (Array.isArray(strategy.lines)) {
        lines.push(...strategy.lines.map((line) => `${line.label}${line.text}`))
    }
    if (strategy.insight) {
        lines.push(`关注重点：${strategy.insight.focus}`)
        lines.push(`当前压力：${strategy.insight.pressure}`)
        lines.push(`行为特征：${strategy.insight.behavior}`)
    }
    return lines.filter(Boolean).join('\n')
}

const splitInsightTags = (text) => {
    return String(text || '')
        .split(/[、,，]/)
        .map((item) => item.trim())
        .filter(Boolean)
}

const insightBehaviorMeta = [
    { label: '沟通风格', iconClass: 'talk' },
    { label: '判断习惯', iconClass: 'judge' },
    { label: '个人动机', iconClass: 'motive' },
]

const getInsightBehaviors = (text) => {
    return String(text || '')
        .split(/[；;]/)
        .map((item) => item.trim().replace(/。$/, ''))
        .filter(Boolean)
        .map((item, index) => ({
            label: insightBehaviorMeta[index] ? insightBehaviorMeta[index].label : '行为特征',
            iconClass: insightBehaviorMeta[index] ? insightBehaviorMeta[index].iconClass : '',
            text: item,
        }))
}

const demoExamples = {
    potential: {
        title: '刚认识的潜在客户',
        user: '我做香港保险的，姚总是上周朋友饭局认识的，浙江做货运的老板。前天微信聊了几分钟，他提到孩子可能去英国读书，也关心家庭医疗和重疾保障。我想趁这个话题约他深聊一次，先把信任建起来，我该怎么做？',
        badges: [
            { text: '轻推进', type: 'orange' },
            { text: '先听后提', type: 'gray' },
        ],
        headline: '他给了话题，但还没给你信任位',
        summary: '现在最有价值的，不是马上讲保险方案，而是借“孩子留学 + 家庭保障”这个由头，把他从泛泛聊天带到一次低压力、像请教式的深聊。你们刚认识不久，他愿意提家庭和孩子，说明话题口子已经开了；但如果你一上来就产品化、方案化，他会立刻把你归类成“销售推进”。这一轮赢点不是成交，是让他愿意见你、愿意多说。',
        details: [
            { label: '目标', text: '约成一次 20 分钟轻沟通' },
            { label: '切入', text: '从孩子留学准备顺势展开' },
            { label: '别做', text: '一上来发方案或问预算' },
        ],
        nextSteps: [
            { title: '现在先做：', text: '先发一条轻一点的微信，只约沟通，不谈产品。' },
            { title: '如果对方认可：', text: '见面时先聊孩子留学和家庭安排，再自然过渡到保障缺口。' },
