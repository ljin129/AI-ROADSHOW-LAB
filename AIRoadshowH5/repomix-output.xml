<template>
    <div class="page_home_container" :class="[isPc ? 'pc_page_container pc_container' : '', (showLongRecord || isSelectionDisabled) ? 'is_recording' : '']">
        <page-head v-if="isPc" :title="pageTitle"/>
        <div class="content_area" :class="{ 'has_example': showExample, 'shwo_example': bannerExpanded }">
            <div v-if="bannerExpanded" class="example_shadow" @click="onExampleShadowClick"></div>
            <div
                v-if="showExample"
                class="example_float_card"
                :class="{ 'example_float_card_pc': isPc, is_open: bannerExpanded }"
                :style="{ width: exampleWidth }"
            >
                <div class="top_float_banner" @click="toggleBannerExpand">
                    <van-icon class="icon_question" name="question-o" size="20" color="#2563EB" />
                    <span class="banner_text">不知道怎么描述关系? 点这里查看示例</span>
                    <van-icon class="icon_chevron" name="arrow-down" :class="{ is_open: bannerExpanded }" size="16" color="#2563EB" @click.stop="toggleBannerExpand"/>
                    <van-icon class="icon_chevron icon_close" name="cross" size="16" color="#F43F5E" @click.stop="onCloseExample"/>
                </div>
                <div v-if="bannerExpanded" class="example_panel">
                    <example />
                </div>
            </div>
            <!-- 上方内容区，预留显示聊天/列表等 -->
            <div
                id="contentArea"
                ref="contentAreaRef"
                class="reply_box"
                @touchstart="onContentAreaTouchStart"
                @wheel.passive="onContentAreaWheel"
                @touchmove="onContentAreaTouchMove"
                @touchend="onHistoryPullTouchEnd"
                @touchcancel="onHistoryPullTouchEnd"
            >
                <div
                    v-if="!isPc && (historyPullDistance > 0 || historyLoading)"
                    class="reply_pull_hint"
                    :style="{ height: `${historyPullVisualHeight}px` }"
                >
                    {{ historyPullText }}
                </div>
                <new-session-tip v-if="!sessionId && messageStream.length === 0"></new-session-tip>
                <template v-for="(item, index) in messageStream" :key="getMessageRenderKey(item, index)">
                <div v-if="item.showTimeDivider && item.timeDividerText" class="reply_time_divider">
                    {{ item.timeDividerText }}
                </div>
                <div class="reply_item" :class="[(item.role == 'user' && !item?.metadata?.interaction_data) ? 'reply_item_user' : 'reply_item_ai', (item.role === 'assistant' && ((item.showLoading && !hasVisibleMessageBody(item) && !item.showHeartbeat) || (item.streaming === true && item.showHeartbeat === true))) || (!hasVisibleMessageBody(item) && item.showLoading && !item.showHeartbeat) ? 'question_loading' : '', index === 0 ? 'reply_item_first' : '']">
                     <voice-bar
                        v-if="isPlayableAudioMessage(item) && !item?.metadata?.interaction_data"
                        :uri="getAudioUri(item)"
                        :text-content="getAudioText(item)"
                        :duration-ms="getAudioDuration(item)"
                        :mime-type="getAudioMimeType(item)"
                        :payload="getAudioPayload(item)"
                        :has-content-below="shouldShowMessageContent(item)"
                        :variant="getAudioVariant(item)"
                        :label="getAudioLabel(item)"
                        :show-text-toggle="shouldShowAudioTextToggle(item)"
                    />
                    <div v-if="shouldShowMessageContent(item)" class="reply_item_content" v-html="markdown.render(item.content)" @click="onContentClick"></div>
                    <div v-else-if="Array.isArray(item.content) && item.content.length && !item?.metadata?.interaction_data" class="reply_item_content">
                        {{ item.content.join(' / ') }}
                    </div>
                    <div v-if="item.attachments && item.attachments.length > 0" class="reply_attachments">
                        <template v-for="a in item.attachments" :key="a.id">
                            <voice-bar
                                v-if="a.type === 'audio'"
                                :uri="a.url"
                                :text-content="getAttachmentAudioText(a)"
                                :duration-ms="getAttachmentAudioDuration(a)"
                                :mime-type="getAttachmentAudioMimeType(a)"
                                :payload="getAttachmentAudioPayload(a)"
                                :has-content-below="false"
                                :variant="getAttachmentAudioVariant(a)"
                                :label="getAttachmentAudioLabel(a)"
                                :show-text-toggle="shouldShowAttachmentAudioTextToggle(a)"
                            />
                            <div v-else-if="a.type === 'file'" class="reply_file_item">
                                <a :href="a.url" target="_blank" rel="noopener noreferrer" class="reply_file_link">
                                    <div class="file_icon_box" :class="getFileTypeInfo(a).className">
                                        <span class="file_icon_text">{{ getFileTypeInfo(a).label }}</span>
                                    </div>
                                    <div class="file_text_box">
                                        <span class="file_name">{{ a.fileName || '文件' }}</span>
                                        <span v-if="getFileMetaText(a)" class="file_meta_separator">|</span>
                                        <span v-if="getFileMetaText(a)" class="file_meta">{{ getFileMetaText(a) }}</span>
                                    </div>
                                </a>
                            </div>
                        </template>
                    </div>
                    <cust-task
                        v-if="item.metadata && item.metadata.cust_task_data && Array.isArray(item.metadata.cust_task_data.taskIds) && item.metadata.cust_task_data.taskIds.length"
                        :task-ids="item.metadata.cust_task_data.taskIds"
                        @loaded="onCustTaskLoaded(item, $event)"
                    />
                    <div
                        v-if="shouldShowTaskCreatedHint(item)"
                        class="reply_task_hint"
                    >
                        待办任务已更新，请继续对话
                    </div>
                    <div v-if="item.metadata && item.metadata.interaction_data && getInteractionQuestion(item)">
                        {{ getInteractionQuestion(item) }}
                    </div>
                    <div
                        v-if="item.metadata && item.metadata.interaction_data && Array.isArray(item.metadata.interaction_data.options) && item.metadata.interaction_data.options.length"
                        class="reply_select_box"
                    >
                        <div class="reply_select_options" >
                            <div
                                v-for="(opt, optIndex) in item.metadata.interaction_data.options"
                                :key="`${sessionId}_${index}_${optIndex}`"
                                class="reply_select_option"
                                :class="{'reply_select_option_no_cus': !opt.CustomerId, is_selected: isInteractionOptionSelected(item, opt), is_disabled: isInteractionItemDisabled(item)}"
                                @click="onSelectOption(item, opt, item.metadata.interaction_data.event)"
                            >
                                <customer v-if="opt.CustomerId" :c="opt"></customer>
                                <template v-else>
                                    {{ opt.label || opt.value || '' }}
                                </template>
