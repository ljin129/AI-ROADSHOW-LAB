]
export default {
    props: {
        c: {
            type: Object,
            default: () => {
                return {}
            }
        },
    },
    setup(props) {
        const formatOrg = (c) => {
			const parts = [c.Industry, c.Company, c.Position].filter(Boolean)
			return parts.join(' • ')
		}

        const parseTags = (tagStr) => {
			if (!tagStr) return []
			try {
				// 字符串格式标签，尝试解析 JSON
				const parsed = JSON.parse(tagStr)
				if (Array.isArray(parsed)) return parsed
			} catch (e) {
				return []
			}
		}
        return {
            TAG_COLOR_POOL,
            formatOrg,
            parseTags,
        }
    }
}
