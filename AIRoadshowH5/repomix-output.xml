		}
        // 初始化录音相关内容
        const initRecordRelated = () => {
            if (outTimer) {
				clearTimeout(outTimer)
				outTimer = null
			}
            voiceFinalResultHandled = false
            if ([1].includes(recordStatus.value) || replyController.value || isReplying.value) {
				Toast.fail('AI正在分析中')
