<template>
    <div class="page-user-edit" :class="[isPc ? 'pc_page_container' : '']">
        <PageHead :title="pageTitle" v-if="isPc" />

        <main class="form-main" :class="[isPc ? 'pc_container' : '']">
            <section class="intro-block">
                <h2 class="intro-title">编辑个人信息</h2>
                <p class="intro-desc">完善个人信息，提升账号安全性</p>
            </section>

            <form class="form-card" @submit.prevent>
                <div v-if="showNickNameEdit" class="form-item">
                    <label class="form-item-label">昵称</label>
                    <input
                        v-model.trim="form.nickName"
                        class="form-item-input"
                        type="text"
                        maxlength="20"
                        placeholder="请输入昵称"
                    />
                </div>

                <div class="form-item">
                    <label class="form-item-label">手机号</label>
                    <div class="phone-row">
                        <div class="area-code-wrap">
                            <select v-model="form.areaCode" class="area-code-select">
                                <option
                                    v-for="item in areaCodeOptions"
                                    :key="item.code"
                                    :value="item.code"
                                >
                                    {{ item.label }}
                                </option>
                            </select>
                        </div>
                        <input
                            v-model.trim="form.mobile"
                            class="form-item-input phone-input"
                            type="tel"
                            maxlength="20"
                            inputmode="numeric"
                            placeholder="请输入手机号"
                        />
                    </div>
                </div>

                <div class="form-item">
                    <label class="form-item-label">验证码</label>
                    <div class="code-row">
                        <input
                            v-model.trim="form.verifyCode"
                            class="form-item-input code-input"
                            type="text"
                            maxlength="8"
                            inputmode="numeric"
                            placeholder="请输入验证码"
                        />
                        <button
                            type="button"
                            class="code-btn"
                            :disabled="!canSendCode"
                            @click="handleSendCode"
                        >
                            {{ codeBtnText }}
                        </button>
                    </div>
                </div>
            </form>
        </main>

        <footer class="footer-bar" :class="[isPc ? 'pc_container' : '']">
            <div class="footer-actions">
                <button
                    class="footer-btn footer-btn-save"
                    type="button"
                    :disabled="isSaving"
                    @click="handleSave"
                >
                    保存
                </button>
            </div>
        </footer>
    </div>
</template>

<script>
import { computed, onBeforeUnmount, onMounted, reactive, ref } from 'vue'
import { useRoute, useRouter } from 'vue-router'
import { Toast } from 'vant'
import PageHead from '@/components/pageHead'
import { GetUserInfo, SendSMS, UpdateUserInfo } from '@/api/user'

const COUNTDOWN_SECONDS = 60

export default {
    name: 'UserEdit',
    components: {
        PageHead,
    },
    setup() {
        const route = useRoute()
        const router = useRouter()
        const sdk = window.bjsdk || {}
        const isPc = ref((sdk.isWinPC || sdk.isMac) && !sdk.isWM)
        const pageTitle = ref(document.title || '编辑资料')
        const isSaving = ref(false)
        const isSendingCode = ref(false)
        const countdown = ref(0)
        const hasSentCode = ref(false)
        const showNickNameEdit = ref(false)
        let countdownTimer = null

        const areaCodeOptions = [
            { code: '+86', label: '+86' },
            { code: '+65', label: '+65' },
            { code: '+852', label: '+852' },
            { code: '+853', label: '+853' },
            { code: '+886', label: '+886' }
        ]

        const form = reactive({
            nickName: '',
            areaCode: '+86',
            mobile: '',
            verifyCode: '',
        })

        const normalizeMobile = (value) => String(value || '').replace(/[\s-]+/g, '')
        const normalizeAreaCode = (value) => {
            const codeText = String(value || '').trim()
            if (!codeText) return ''
            return codeText.startsWith('+') ? codeText : `+${codeText}`
        }
        const mobilePatternMap = {
            '+86': /^1[3-9]\d{9}$/,
            '+65': /^[3689]\d{7}$/,
            '+852': /^[5689]\d{7}$/,
            '+853': /^6\d{7}$/,
            '+886': /^9\d{8}$/,
        }
        const isMobileValidByCountryCode = (mobile, countryCode) => {
            const text = normalizeMobile(mobile)
            const code = String(countryCode || '').trim()
            const pattern = mobilePatternMap[code]
            if (pattern) return pattern.test(text)
            return /^\d{5,20}$/.test(text)
        }
        const isMobileValid = computed(() => isMobileValidByCountryCode(form.mobile, form.areaCode))
        const showLightTip = (message) => {
            Toast({
                message,
                duration: 1800,
            })
        }

        const codeBtnText = computed(() => {
            if (isSendingCode.value) return '发送中...'
            if (countdown.value > 0) return `${countdown.value}s`
            return hasSentCode.value ? '重发验证码' : '发送验证码'
        })

        const canSendCode = computed(() => countdown.value === 0 && !isSendingCode.value && isMobileValid.value)

        const clearCountdownTimer = () => {
            if (countdownTimer) {
                clearInterval(countdownTimer)
                countdownTimer = null
            }
        }

        const startCountdown = () => {
            clearCountdownTimer()
            countdown.value = COUNTDOWN_SECONDS
            countdownTimer = setInterval(() => {
                countdown.value -= 1
                if (countdown.value <= 0) {
                    countdown.value = 0
                    clearCountdownTimer()
                }
            }, 1000)
        }

        const validateForm = () => {
            if (showNickNameEdit.value && !String(form.nickName || '').trim()) {
                showLightTip('请输入昵称')
                return false
            }
            if (!String(form.mobile || '').trim()) {
                showLightTip('请输入手机号')
                return false
            }
            if (!isMobileValid.value) {
                showLightTip('手机号格式不正确')
                return false
            }
            if (!String(form.verifyCode || '').trim()) {
                showLightTip('请输入验证码')
                return false
            }
            return true
        }

        const getErrorMessage = (error, fallback) => {
            if (typeof error === 'string' && error.trim()) return error
            if (error && typeof error === 'object') {
                return error.ErrorMessage || error.errorMessage || error.message || fallback
            }
            return fallback
        }
        const getResponseData = (res) => {
            return (res && (res.Data !== undefined ? res.Data : res.data)) || null
        }
        const getField = (data, upperKey, lowerKey) => {
            if (!data || typeof data !== 'object') return ''
            return data[upperKey] !== undefined ? data[upperKey] : data[lowerKey]
        }
        const loadUserInfo = async () => {
            try {
                const res = await GetUserInfo()
                const data = getResponseData(res) || {}
                const nickName = getField(data, 'NickName', 'nickName') || getField(data, 'Name', 'name')
                const mobile = getField(data, 'UserCellPhone', 'userCellPhone') ||
                    getField(data, 'CellPhone', 'cellPhone') ||
                    getField(data, 'Mobile', 'mobile') ||
                    getField(data, 'Phone', 'phone')
                const areaCode = getField(data, 'CountryCode', 'countryCode') || getField(data, 'AreaCode', 'areaCode')

                form.nickName = nickName ? String(nickName) : ''
                form.mobile = mobile ? String(mobile) : ''
                form.areaCode = normalizeAreaCode(areaCode) || '+86'
            } catch (error) {
                showLightTip(getErrorMessage(error, '获取用户信息失败'))
            }
        }

        const handleSendCode = async () => {
            if (!canSendCode.value) return
            if (!isMobileValid.value) {
                showLightTip('手机号格式不正确')
                return
            }
            try {
                isSendingCode.value = true
                const res = await SendSMS({
                    phone: normalizeMobile(form.mobile),
                    countryCode: form.areaCode,
                })
                const ok = (res.Data !== undefined ? res.Data : res.data) === true
                if (!ok) {
                    throw new Error(res.ErrorMessage || res.errorMessage || '验证码发送失败')
                }
                hasSentCode.value = true
                showLightTip('验证码发送成功')
                startCountdown()
            } catch (error) {
                showLightTip(getErrorMessage(error, '验证码发送失败'))
            } finally {
                isSendingCode.value = false
            }
        }

        const handleSave = async () => {
            if (isSaving.value) return
            if (!validateForm()) return

            try {
                isSaving.value = true
                const params = {
                    userCellPhone: normalizeMobile(form.mobile),
                    smsCode: String(form.verifyCode || '').trim(),
                    countryCode: String(form.areaCode || '').trim(),
                }
                if (showNickNameEdit.value) {
                    params.nickName = String(form.nickName || '').trim()
                }
                await UpdateUserInfo(params)
                showLightTip('保存成功')
                setTimeout(() => {
                    const targetPath = showNickNameEdit.value ? '/home' : '/user/guide'
                    if (window.bjsdk && typeof window.bjsdk.goTo === 'function') {
                        window.bjsdk.goTo(targetPath, {})
                        return
                    }
                    router.replace(targetPath)
                }, 500);
            } catch (error) {
                showLightTip(getErrorMessage(error, '保存失败'))
            } finally {
                isSaving.value = false
            }
        }

        const readQuery = (key) => {
            let value = ''
            if (window.bjsdk && typeof window.bjsdk.query === 'function') {
                value = window.bjsdk.query(key) || ''
            }
            return value || route.query[key] || ''
        }

        onMounted(async () => {
            const from = readQuery('from') || readQuery('From')
            const isFromUserCenter = String(from || '') === 'userCenter'

            showNickNameEdit.value = isFromUserCenter
            if (isFromUserCenter) {
                await loadUserInfo()
            }
        })

        onBeforeUnmount(() => {
            clearCountdownTimer()
        })

        return {
            isPc,
            pageTitle,
            form,
            isSaving,
            showNickNameEdit,
            areaCodeOptions,
            canSendCode,
            codeBtnText,
            handleSendCode,
            handleSave,
        }
    },
}
</script>

