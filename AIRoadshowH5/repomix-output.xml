<template>
    <div class="voice_bar" :class="[`is_${variant}`]" :style="showExpandedLayout ? { minWidth: barWidth + 'px', width: '100%', maxWidth: '100%' } : { width: barWidth + 'px' }">
        <div class="voice_bar_main" @click="togglePlay">
            <div class="voice_bar_play_btn" :class="{ is_playing: isPlaying }">
                <svg v-if="!isPlaying" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5.5v13l11-6.5z" />
                </svg>
                <svg v-else viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="6" y="5" width="4" height="14" rx="1" />
                    <rect x="14" y="5" width="4" height="14" rx="1" />
                </svg>
            </div>
            <span v-if="variant === 'attachment' && canToggleText && !showText" class="voice_bar_collapsed_wave" aria-hidden="true">
                <span class="voice_bar_collapsed_wave_line"></span>
                <span class="voice_bar_collapsed_wave_line"></span>
                <span class="voice_bar_collapsed_wave_line"></span>
                <span class="voice_bar_collapsed_wave_line"></span>
            </span>
            <div class="voice_bar_waves">
                <span v-for="i in waveBarCount" :key="i" class="voice_bar_wave_line" :class="{ is_playing: isPlaying }" :style="{ animationDelay: `${(i - 1) * 0.06}s`, height: `${waveBars[(i - 1) % waveBars.length]}%` }" />
            </div>
            <span class="voice_bar_duration">{{ durationText }}</span>
            <span v-if="label" class="voice_bar_label">{{ label }}</span>
            <template v-if="canToggleText">
                <span class="voice_bar_divider"></span>
                <div class="voice_bar_text_toggle" :class="{ is_active: showText }"
                    @touchstart.stop.prevent="onTextToggle"
                    @mousedown.stop.prevent="onTextToggle"
                >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="4 7 4 4 20 4 20 7"></polyline>
                        <line x1="9" y1="20" x2="15" y2="20"></line>
                        <line x1="12" y1="4" x2="12" y2="20"></line>
                    </svg>
                </div>
            </template>
        </div>
        <!-- 当收起文本但下方有内容（图片）时，展示一条分隔线 -->
        <div v-if="!showText && hasContentBelow" class="voice_bar_bottom_divider"></div>
        <div v-if="showText && textContent" class="voice_bar_text_content">
            {{ textContent }}
        </div>
    </div>
</template>
<script>
import { ref, computed, onBeforeUnmount } from 'vue'
import { CreatePlayer } from '@/utils/SAPlayer.js'

export default {
    name: 'VoiceBar',
    props: {
        uri: { type: String, default: '' },
        textContent: { type: String, default: '' },
        durationMs: { type: Number, default: 0 },
        mimeType: { type: String, default: '' },
        payload: { type: Object, default: () => ({}) },
        hasContentBelow: { type: Boolean, default: false },
        variant: { type: String, default: 'voice' },
        label: { type: String, default: '' },
        showTextToggle: { type: Boolean, default: true },
    },
    setup(props) {
        const isPlaying = ref(false)
        const showText = ref(true)
        const canToggleText = computed(() => props.showTextToggle && !!props.textContent)
        const showExpandedLayout = computed(() => !!props.textContent && (showText.value || props.hasContentBelow))
        let player = null
        let playerAudioId = ''

        // 随机生成静态波形高度（生成足够多的条，供动态数量使用）
        const waveBars = Array.from({ length: 40 }, () => 20 + Math.random() * 60)

        // 动态宽度：2s以下最短，60s以上最长，中间线性插值
        const MIN_WIDTH = 120
        const MAX_WIDTH = 260
        const MIN_SEC = 2
        const MAX_SEC = 60

        const minCollapsedWidth = computed(() => {
            if (props.variant === 'attachment' && canToggleText.value) {
                return 144
            }
            return MIN_WIDTH
        })

        const barWidth = computed(() => {
            const ms = props.durationMs || (props.payload && props.payload.duration_ms) || 0
            const sec = Math.max(0, Math.round(ms / 1000))
            if (sec <= MIN_SEC) return minCollapsedWidth.value
            if (sec >= MAX_SEC) return MAX_WIDTH
            const ratio = (sec - MIN_SEC) / (MAX_SEC - MIN_SEC)
            return Math.round(minCollapsedWidth.value + ratio * (MAX_WIDTH - minCollapsedWidth.value))
        })

        // 波形条数也根据宽度动态调整（宽度越大条越多）
        const waveBarCount = computed(() => {
            // 扣除播放按钮(28)、时长文字(约32)、gap(约24)、转文字按钮(约32)后的剩余空间
            const availableWidth = barWidth.value - 120
            // 每条约 4.5px (2.5px width + 2px gap)
            return Math.max(6, Math.min(30, Math.floor(availableWidth / 4.5)))
        })

        const durationText = computed(() => {
            const ms = props.durationMs || (props.payload && props.payload.duration_ms) || 0
            if (!ms) return ''
            const sec = Math.round(ms / 1000)
            if (sec < 60) return `${sec}''`
            const min = Math.floor(sec / 60)
            const remSec = sec % 60
            return `${min}'${remSec < 10 ? '0' : ''}${remSec}''`
        })

        const getAudioFmt = () => {
            const p = props.payload || {}
            if (p.format === 'pcm') {
                return {
                    format: 'pcm',
                    sampleRate: p.sampleRate || p.sample_rate || 8000,
                    channels: p.channels || 1,
                    encoding: p.encoding || 16,
                }
            }
            // 默认 mp3
            return { format: 'mp3' }
        }

        const stopCurrentPlayer = () => {
            if (player) {
                try { player.stop() } catch (e) { /* ignore */ }
                try { player.close(false) } catch (e) { /* ignore */ }
                player = null
            }
            isPlaying.value = false
        }

        const togglePlay = async () => {
            if (!props.uri) return

            if (isPlaying.value) {
                stopCurrentPlayer()
                return
            }

            try {
                player = CreatePlayer({
                    ctxCreator: () => new (window.AudioContext || window.webkitAudioContext)(),
                    onEnded: () => {
                        isPlaying.value = false
                    },
                    onError: (err) => {
                        console.error('VoiceBar playback error:', err)
                        isPlaying.value = false
                    },
                })

                isPlaying.value = true
                playerAudioId = `voice_${Date.now()}`

                const response = await fetch(props.uri)
                if (!response.ok) {
                    throw new Error(`Fetch audio failed: ${response.status}`)
                }
                const arrayBuffer = await response.arrayBuffer()
                const audioFmt = getAudioFmt()

                player.append(new Uint8Array(arrayBuffer), true, playerAudioId, audioFmt)
                // 标记流结束
                player.append(null, false, playerAudioId)
            } catch (err) {
                console.error('VoiceBar fetch/play error:', err)
                stopCurrentPlayer()
            }
        }

        const onTextToggle = () => {
            showText.value = !showText.value
        }

        onBeforeUnmount(() => {
            stopCurrentPlayer()
        })

        return {
            isPlaying,
            showText,
            canToggleText,
            showExpandedLayout,
            waveBars,
            waveBarCount,
            barWidth,
            durationText,
            togglePlay,
            onTextToggle,
        }
    },
}
</script>
