				// 企微跳转 或 app的replace方式跳转
				const p = ops.path || '';//vue路由跳转地址，不带参数
				const par = { ...ops.queryObj };//参数对象
				if (p.indexOf('/') == 0) {
					await router.push({ path: p, replace: rpc, query: par })
				} else {
					await router.push({ name: p, replace: rpc, query: par })
				}
			}
		},
