<template>
    <div class="dialog_list_wrap" @click.self="handleClose">
        <div class="dialog_list_panel" :class="{ is_show: panelShow, 'dialog_list_panel_pc': isPc }">
            <div class="search_bar">
                <van-icon name="search" size="18" color="#999" />
                <input
                    v-model="searchKeyword"
                    type="text"
                    class="search_input"
                    placeholder="搜索历史记录"
                    @keyup.enter="onSearchConfirm"
                />
            </div>
            <button type="button" class="btn_create_session" @click="onCreateSession">创建新对话</button>
            <div ref="listScrollRef" class="list_scroll" @scroll="onListScroll">
                <template v-for="(group, groupKey) in filteredGroups" :key="groupKey">
                    <div class="group_label">{{ group.label }}</div>
                    <template v-if="isPc">
                        <div
                            v-for="item in group.list"
                            :key="item.id"
                            class="list_item list_item_pc"
                            :class="{ is_active: item.id === currentSessionId }"
                            @click="onSelectItem({ item })"
                        >
                            <van-icon
                                class="item_icon"
                                :name="'chat-o'"
                                :color="item.id === currentSessionId ? '#1890ff' : '#999'"
                                size="20"
                            />
                            <span class="item_text">{{ item.title }}</span>
                            <div class="item_actions">
                                <span class="action_btn" @click.stop="onEditItem({ item })">编辑</span>
                                <span class="action_btn action_delete" @click.stop="onDeleteItem({ item })">删除</span>
                            </div>
                        </div>
                    </template>
                    <template v-else>
                        <van-swipe-cell v-for="item in group.list" :key="item.id">
                            <div
                                class="list_item"
                                :class="{ is_active: item.id === currentSessionId }"
                                @click="onSelectItem({ item })"
                            >
                                <van-icon
                                    class="item_icon"
                                    :name="'chat-o'"
                                    :color="item.id === currentSessionId ? '#1890ff' : '#999'"
                                    size="20"
                                />
                                <span class="item_text">{{ item.title }}</span>
                            </div>
                            <template #right>
                                <div class="swipe_actions">
                                    <div class="edit_btn" @click.stop="onEditItem({ item })">编辑</div>
                                    <div class="delete_btn" @click.stop="onDeleteItem({ item })">删除</div>
                                </div>
                            </template>
                        </van-swipe-cell>
                    </template>
                </template>
                <div class="list_footer">
                    <van-loading v-if="loading" size="24px" vertical>加载中...</van-loading>
                    <span v-else-if="!hasMore" class="no_more_tip">没有更多数据了</span>
                </div>
            </div>
            <div class="panel_footer">
                <button type="button" class="btn_user_center" @click="onProfile">
                    <van-icon class="user_center_icon" name="manager-o" size="18" />
                    <span>我的</span>
                </button>
            </div>
        </div>
        <div class="dialog_list_mask" @click="handleClose"></div>
        <!-- 编辑标题弹窗 -->
        <div v-if="showEditDialog" class="edit_dialog_mask" @click.self="closeEditDialog">
            <div class="edit_dialog_box">
                <div class="edit_dialog_title">对话名称</div>
                <input
                    v-model="editTitle"
                    type="text"
                    maxlength="14"
                    class="edit_dialog_input"
                    placeholder="请输入对话名称"
                />
                <div class="edit_dialog_footer">
                    <button type="button" class="edit_dialog_btn cancel" @click="closeEditDialog">取消</button>
                    <button type="button" class="edit_dialog_btn confirm" @click="confirmEdit">确定</button>
                </div>
            </div>
        </div>
    </div>
</template>
<script>
import { ref, computed, watch, nextTick, onMounted } from 'vue'
import { Icon, SwipeCell, Loading, Toast, Dialog } from 'vant'
import { GetByUserIdPaged, UpdateSessionName, DeleteSession } from '@/api/index.js'
import { utcToLocal } from '@/utils/util.js'

const GROUP_LABELS = {
    today: '今天',
    yesterday: '昨天',
    last7: '过去7天',
}

const getTimeGroup = (createTime) => {
    if (!createTime) return 'last7'
    const d = new Date(createTime)
    const today = new Date()
    today.setHours(0, 0, 0, 0)
    const yesterday = new Date(today)
    yesterday.setDate(yesterday.getDate() - 1)
    const dayStart = new Date(d)
    dayStart.setHours(0, 0, 0, 0)
    if (dayStart.getTime() === today.getTime()) return 'today'
    if (dayStart.getTime() === yesterday.getTime()) return 'yesterday'
    return 'last7'
}

export default {
    components: {
        [Icon.name]: Icon,
        [SwipeCell.name]: SwipeCell,
        [Loading.name]: Loading,
        [Toast.name]: Toast,
        [Dialog.name]: Dialog,
    },
    props: {
        visible: {
            type: Boolean,
            default: false,
        },
        currentSessionId: {
            type: String,
            default: '',
        },
    },
    emits: ['close', 'select', 'create', 'profile'],
    setup(props, { emit }) {
        const isPc = ref((window.bjsdk.isWinPC || window.bjsdk.isMac) && !window.bjsdk.isWM)
        const searchKeyword = ref('')
        const panelShow = ref(false)
        const showEditDialog = ref(false)
        const editItem = ref(null)
        const editTitle = ref('')
        const listScrollRef = ref(null)
        const loadMoreEmittedAtBottom = ref(false)
        const LOAD_MORE_THRESHOLD = 50
        const loading = ref(false)
        const hasMore = ref(true)
        let pageIndex = 1
        const PAGE_SIZE = 20

        const listData = ref([])

        const filteredGroups = computed(() => {
            const order = ['today', 'yesterday', 'last7']
            const groups = {}
            order.forEach((key) => {
                groups[key] = { label: GROUP_LABELS[key], list: [] }
            })
            listData.value.forEach((item) => {
                const key = item.timeGroup
                if (groups[key]) groups[key].list.push(item)
            })
            return order.filter((k) => groups[k].list.length > 0).map((k) => ({ key: k, ...groups[k] }))
        })

        const handleClose = () => {
            emit('close')
        }

        const onCreateSession = () => {
            emit('create')
            emit('close')
        }

        const onProfile = () => {
            emit('profile')
            emit('close')
        }

        const currentSessionId = computed(() => props.currentSessionId || '')

        const onSelectItem = ({ item }) => {
            emit('select', item)
            emit('close')
        }

        const onDeleteItem = ({ item }) => {
            Dialog.confirm({
                title: '提示',
                message: '确定删除该条记录？',
            }).then(() => {
                DeleteSession({
                    SessionId: item.SessionId ?? item.id,
                }).then((res) => {
                    if (res.State === 0) {
                        Toast('删除成功')
                        const wasActive = item.id === props.currentSessionId
                        const idx = listData.value.findIndex((i) => i.id === item.id)
                        if (idx > -1) listData.value.splice(idx, 1)
                        if (wasActive && listData.value.length > 0) {
                            const first = listData.value[0]
                            emit('select', first)
                        } else {
                            emit('create')
                        }
                    } else {
                        Toast('删除失败')
                    }
                }).catch((err) => {
                    console.error('DeleteSession error:', err && (err.ErrorMessage || err.message) || '请求失败')
                })
            }).catch(() => {})
        }

        const onEditItem = ({ item }) => {
            editItem.value = item
            editTitle.value = item.title || ''
            showEditDialog.value = true
        }

        const closeEditDialog = () => {
            showEditDialog.value = false
            editItem.value = null
            editTitle.value = ''
        }

        const confirmEdit = () => {
            const title = (editTitle.value || '').trim()
            if (editItem.value && title) {
                UpdateSessionName({
                    sessionId: editItem.value.id,
                    sessionName: title,
                }).then((res) => {
                    if (res.State === 0) {
                        Toast('保存成功')
                        const idx = listData.value.findIndex((i) => i.id === editItem.value.id)
                        if (idx > -1) {
                            listData.value[idx].title = title
                        }
                    } else {
                        Toast('保存失败')
                    }
                }).catch((err) => {
                    console.error('UpdateSessionName error:', err &&(err.ErrorMessage || err.message) || '请求失败')
                }).finally(() => {
                    closeEditDialog()
                })
            }
            
        }

        const onListScroll = () => {
            const el = listScrollRef.value
            if (!el) return
            const { scrollTop, clientHeight, scrollHeight } = el
            const isAtBottom = scrollTop + clientHeight >= scrollHeight - LOAD_MORE_THRESHOLD
            if (isAtBottom && !loadMoreEmittedAtBottom.value) {
                loadMoreEmittedAtBottom.value = true
                loadMoreData()
            } else if (!isAtBottom) {
                loadMoreEmittedAtBottom.value = false
            }
        }

        const checkAndLoadIfNeeded = () => {
            const el = listScrollRef.value
            if (!el || loading.value || !hasMore.value) return
            const { scrollHeight, clientHeight } = el
            if (scrollHeight <= clientHeight) {
                loadMoreEmittedAtBottom.value = true
                loadMoreData()
            }
        }

        const loadMoreData = () => {
            if (loading.value || !hasMore.value) return
            loading.value = true
            GetByUserIdPaged({
                PageIndex: pageIndex,
                PageSize: PAGE_SIZE,
                KeyWord: searchKeyword.value,
            })
                .then((res) => {
                    if (res.State === 0 && res.Data) {
                        const list = res.Data.List || res.Data.list || []
                        const rows = Array.isArray(list) ? list : []
                        if (rows.length) {
                            const mapItem = (row) => {
                                const nCreateTime = utcToLocal(row.CreateTime)
                                return {
                                    ...row,
                                    id: row.SessionId ?? row.sessionId ?? '',
                                    title: row.SessionName ?? row.sessionName ?? '',
                                    timeGroup: getTimeGroup(nCreateTime ?? nCreateTime),
                                    active: false,
                                    nCreateTime,
                                }
                            }
                            listData.value.push(...rows.map(mapItem))
                        }
                        // console.log('listData', listData)
                        hasMore.value = Array.isArray(list) && list.length > 0
                        if (rows.length) pageIndex += 1
                    } else {
                        hasMore.value = false
                    }
                })
                .catch((err) => {
                    hasMore.value = false
                })
                .finally(() => {
                    loading.value = false
                    loadMoreEmittedAtBottom.value = false
                    nextTick(() => {
                        checkAndLoadIfNeeded()
                    })
                })
        }

        const appendListData = (items) => {
            if (Array.isArray(items) && items.length) {
                listData.value.push(...items)
            }
            loadMoreEmittedAtBottom.value = false
        }

        const onSearchConfirm = () => {
            if (loading.value) return
            loadMoreEmittedAtBottom.value = false
            pageIndex = 1
            listData.value = []
            hasMore.value = true
            loadMoreData()
        }

        watch(
            () => props.visible,
            (newVal) => {
                if (!newVal) {
                    searchKeyword.value = ''
                } else {
                    loadMoreEmittedAtBottom.value = false
                    pageIndex = 1
                    listData.value = []
                    loading.value = false
                    hasMore.value = true
                    loadMoreData()
                }
            },
            { immediate: true }
        )

        onMounted(() => {
            nextTick(() => {
                panelShow.value = true
            })
        })

        return {
            isPc,
            panelShow,
            searchKeyword,
            currentSessionId,
            filteredGroups,
            showEditDialog,
            editTitle,
            loading,
            hasMore,
            listScrollRef,
            handleClose,
            onCreateSession,
            onProfile,
            onSelectItem,
            onDeleteItem,
            onEditItem,
            closeEditDialog,
            confirmEdit,
            onListScroll,
            appendListData,
            onSearchConfirm,
        }
    },
}
</script>
<style lang="less" scoped>
.dialog_list_wrap {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 999;
    display: flex;
    flex-direction: row;
}

.dialog_list_panel {
    width: 74%;
    height: 100%;
    background: #fff;
    border-radius: 0 16px 0 0;
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    overflow: hidden;
    z-index: 991;

    &.is_show {
        transform: translateX(0);
    }

    .search_bar {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        margin: 16px 16px 12px;
        padding: 10px 12px;
        background: #f5f5f5;
        border-radius: 20px;

        .search_input {
            flex: 1;
            min-width: 0;
            margin-left: 8px;
            border: none;
            background: transparent;
            font-size: 14px;
            outline: none;

            &::placeholder {
                color: #999;
            }
        }
    }

    .btn_create_session {
        flex-shrink: 0;
        margin: 0 16px 12px;
        padding: 10px 14px;
        width: calc(100% - 32px);
        box-sizing: border-box;
        background: #e8f4ff;
        color: #1890ff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        cursor: pointer;
    }

    .list_scroll {
        flex: 1;
        min-height: 0;
        width: calc(100% - 32px);
        max-width: 100%;
        overflow-x: hidden;
        overflow-y: auto;
