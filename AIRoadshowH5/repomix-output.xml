				</div>
				<button class="detail-info-header-edit" type="button" @click="goEdit">
					<svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
						<path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm2.92 2.33H5v-.92l8.06-8.06.92.92L5.92 19.58zM20.71 7.04a1.003 1.003 0 0 0 0-1.42l-2.34-2.34a1.003 1.003 0 0 0-1.42 0l-1.83 1.83 3.75 3.75 1.84-1.82z"/>
					</svg>
				</button>
			</div>
			<div class="detail-info-meta">
				<div class="detail-info-meta-contact" v-if="customer.LastContactDate">最近联系：{{ customer.LastContactDate }}</div>
				<div class="detail-info-meta-org">
					{{ formatOrg(customer) }}
				</div>
			</div>
			<div v-if="customer.OtherTags && parseTags(customer.OtherTags).length" class="detail-info-tag">
				<span
					v-for="(t, index) in parseTags(customer.OtherTags).slice(0, customer.Company || customer.Position || customer.Industry ? 3 : undefined)"
					:key="index"
					class="detail-info-tag-item"
					:style="{
						backgroundColor: tagColorPool[index % tagColorPool.length].bg,
						color: tagColorPool[index % tagColorPool.length].text,
						border: '1px solid ' + tagColorPool[index % tagColorPool.length].border
					}"
				>
					{{ t.text || t }}
				</span>
			</div>
		</section>
		<section v-else-if="loaded" class="detail-empty">
			<img class="detail-empty-image" :src="emptyCustomerImg" alt="暂无客户信息" />
			<div class="detail-empty-text">暂无客户信息</div>
		</section>
		<section class="detail-markdown" v-if="customer.Name && hasProfileContent" :class="[isPc ? 'pc_container' : '']">
			<div class="detail-markdown-content" v-html="markdown.render(profile.ProfileContent)"></div>
		</section>
		<section class="detail-profile-loading" v-else-if="customer.Name && profileLoadingVisible" :class="[isPc ? 'pc_container' : '']">
			<div class="detail-profile-loading-box">
				<div class="detail-profile-loading-main">
					<span class="detail-profile-loading-spinner"></span>
					<span class="detail-profile-loading-text">客户画像生成中</span>
				</div>
				<div class="detail-profile-loading-hint">生成耗时约30秒，可先退出，稍后再来查看。</div>
			</div>
		</section>
		<section class="detail-profile-empty" v-else-if="customer.Name && loaded" :class="[isPc ? 'pc_container' : '']">
			<img class="detail-profile-empty-image" :src="emptyProfileImg" alt="客户画像生成中" />
			<div class="detail-profile-empty-text">客户画像生成中</div>
